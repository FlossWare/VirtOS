# EditorConfig configuration for VirtOS project
# Ensures consistent coding style across all editors and IDEs
# See: https://editorconfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Shell scripts (bash/sh)
[*.{sh,bash}]
indent_style = space
indent_size = 4
max_line_length = 120

# Shell scripts in specific directories
[{config/custom-scripts/**,packages/*/src/**}/virtos-*]
indent_style = space
indent_size = 4
max_line_length = 120

# Markdown files
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
max_line_length = off

# YAML files (GitHub Actions, configs)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Makefiles require tabs
[{Makefile,*.mk}]
indent_style = tab
indent_size = 4

# Configuration files
[*.conf]
indent_style = space
indent_size = 4

# Documentation
[*.{txt,rst}]
indent_style = space
indent_size = 4

# Python scripts (build scripts)
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# JavaScript/Node (if used)
[*.{js,json}]
indent_style = space
indent_size = 2

# BATS test files
[*.bats]
indent_style = space
indent_size = 4

# Git files
[.git{ignore,attributes}]
indent_style = space
indent_size = 2

# GitHub workflow files
[.github/**/*.yml]
indent_style = space
indent_size = 2

# License and legal files
[LICENSE*]
indent_style = space
indent_size = 2
insert_final_newline = false
