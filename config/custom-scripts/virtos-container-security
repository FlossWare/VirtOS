EOF
}

# Container security status
security_status() {
    echo "=== VirtOS Container Security Status ==="
    echo

    # Image scanner
    if [ -f "$SECURITY_CONFIG_DIR/image-scanner.conf" ]; then
        local scanner=$(cat "$SECURITY_CONFIG_DIR/image-scanner.conf")
        echo "Image Scanner: $scanner"
    else
        echo "Image Scanner: Not configured"
    fi

    # Runtime security
    if [ -f "$SECURITY_CONFIG_DIR/runtime-security.conf" ]; then
        local runtime=$(cat "$SECURITY_CONFIG_DIR/runtime-security.conf")
        echo "Runtime Security: $runtime"
    else
        echo "Runtime Security: Not configured"
    fi

    # Falco status
    if [ -f "$SECURITY_CONFIG_DIR/falco.pid" ] && kill -0 $(cat "$SECURITY_CONFIG_DIR/falco.pid") 2>/dev/null; then
        echo "Falco: Running (PID: $(cat $SECURITY_CONFIG_DIR/falco.pid))"
    else
        echo "Falco: Not running"
    fi

    echo
    echo "Scans performed: $(ls -1 "$SECURITY_CONFIG_DIR"/scan-*.txt 2>/dev/null | wc -l)"
    echo "Policies defined: $(ls -1 "$SECURITY_CONFIG_DIR"/policy-*.rego 2>/dev/null | wc -l)"

    echo
    echo "Configuration: $SECURITY_CONFIG_DIR"
    echo "Logs: $SECURITY_LOG"
}

# Interactive wizard
security_wizard() {
    dialog --title "VirtOS Container Security" \
        --msgbox "This wizard will help you set up container security.\n\nConfigure image scanning, runtime security, and compliance." 12 60

    local choice=$(dialog --title "Choose Action" \
        --menu "Select security action:" 16 60 5 \
        1 "Setup Image Scanner" \
        2 "Setup Runtime Security" \
        3 "Scan Container Image" \
        4 "Compliance Check" \
        5 "Secrets Scanning" \
        2>&1 >/dev/tty)

    case "$choice" in
        1)
            local scanner=$(dialog --menu "Image Scanner:" 13 60 4 \
                trivy "Trivy (Aqua Security)" \
                clair "Clair (CoreOS)" \
                anchore "Anchore Engine" \
                snyk "Snyk" \
                2>&1 >/dev/tty)
            setup_image_scanner "$scanner"
            ;;

        2)
            local tool=$(dialog --menu "Runtime Security:" 12 60 3 \
                falco "Falco (CNCF)" \
                sysdig "Sysdig" \
                aqua "Aqua Security" \
                2>&1 >/dev/tty)
            setup_runtime_security "$tool"
            ;;

        3)
            local image=$(dialog --inputbox "Image to scan:" 10 60 "nginx:latest" 2>&1 >/dev/tty)
            scan_image "$image" | dialog --title "Scan Results" --programbox 30 100
            ;;

        4)
            local framework=$(dialog --menu "Compliance Framework:" 12 60 3 \
                cis "CIS Docker Benchmark" \
                pci-dss "PCI-DSS" \
                hipaa "HIPAA" \
                2>&1 >/dev/tty)
            compliance_check "$framework" | dialog --title "Compliance Report" --programbox 30 100
            ;;

        5)
            local target=$(dialog --inputbox "Target (image/directory):" 10 60 2>&1 >/dev/tty)
            scan_secrets "$target" | dialog --title "Secrets Scan" --programbox 30 100
            ;;
    esac

    dialog --title "Setup Complete" \
        --msgbox "Container security configured!" 8 40
}

# Show usage
usage() {
    cat <<EOF
VirtOS Container Security - Image scanning, runtime security, compliance

Usage: virtos-container-security <command> [options]

Image Scanning Commands:
  setup-scanner <tool>                         Setup image scanner (trivy/clair/anchore/snyk)
  scan-image <image>                           Scan container image

Runtime Security Commands:
  setup-runtime <tool>                         Setup runtime security (falco/sysdig/aqua)

Compliance Commands:
  compliance-check <framework>                 Check compliance (cis/pci-dss/hipaa)

Secrets Commands:
  scan-secrets <target>                        Scan for hardcoded secrets

Policy Commands:
  enforce-policy <name>                        Enforce security policy

Reporting Commands:
  security-report                              Generate security report

Status Commands:
  status                                       Show security status
  wizard                                       Interactive setup wizard

Examples:
  virtos-container-security setup-scanner trivy
  virtos-container-security scan-image nginx:latest
  virtos-container-security setup-runtime falco
  virtos-container-security compliance-check cis
  virtos-container-security scan-secrets myapp:latest
  virtos-container-security security-report
  virtos-container-security wizard

Version: $VERSION
EOF
}

# Main command dispatcher
case "$1" in
    setup-scanner)
        setup_image_scanner "$2"
        ;;
    scan-image)
        scan_image "$2"
        ;;
    setup-runtime)
        setup_runtime_security "$2"
        ;;
    compliance-check)
        compliance_check "$2"
        ;;
    scan-secrets)
        scan_secrets "$2"
        ;;
    enforce-policy)
        enforce_policy "$2"
        ;;
    security-report)
        security_report
        ;;
    status)
        security_status
        ;;
    wizard)
        security_wizard
        ;;
    --version|-v|version)
        echo "virtos-container-security version $VERSION"
        exit 0
        ;;
    --help|-h|help|"")
        usage
        exit 0
        ;;
    *)
        usage
        exit 1
        ;;
esac
