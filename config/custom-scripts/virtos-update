#!/bin/bash
# VirtOS Update - Automated update system
# Check for updates, apply patches, and rollback if needed

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.25")
UPDATE_DIR="/var/lib/virtos/updates"
STATE_DIR="/var/run/virtos/update"
LOG_FILE="/var/log/virtos-update.log"

mkdir -p "$UPDATE_DIR" "$STATE_DIR"

usage() {
    cat << EOF
VirtOS Update - Automated Update System v${VERSION}

Usage: virtos-update [command] [options]

Commands:
  check                            Check for available updates
  list                             List available updates
  install <update-id>              Install specific update
  install-all                      Install all available updates
  rollback <update-id>             Rollback update
  history                          Show update history
  auto-enable                      Enable automatic updates
  auto-disable                     Disable automatic updates

Options:
  --force                          Force update installation
  --no-backup                      Skip backup before update
  --dry-run                        Show what would be updated

Examples:
  # Check for updates
  virtos-update check

  # List available updates
  virtos-update list

  # Install all updates
  virtos-update install-all

  # Install specific update
  virtos-update install virtos-monitor-1.1

  # View update history
  virtos-update history

  # Enable automatic updates (daily)
  virtos-update auto-enable

EOF
}

log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

init_config() {
    if [ ! -f "$UPDATE_DIR/config.conf" ]; then
        cat > "$UPDATE_DIR/config.conf" <<EOF
# VirtOS Update Configuration

# Update check frequency
CHECK_INTERVAL=daily

# Auto-install updates
AUTO_INSTALL=no

# Backup before update
BACKUP_BEFORE_UPDATE=yes

# Update repository
UPDATE_REPO_URL=https://github.com/FlossWare/VirtOS/raw/main/updates

# Maximum backup retention
MAX_BACKUPS=5
EOF
    fi

    source "$UPDATE_DIR/config.conf"
}

check_updates() {
    log_message "Checking for updates..."
    echo "Checking for VirtOS updates..."

    # Check virtos scripts version
    local current_version="$VERSION"
    local available_updates=0

    echo ""
    echo "Installed Components:"
    echo "===================="

    for script in /usr/local/bin/virtos-*; do
        if [ -f "$script" ] && [ -x "$script" ]; then
            local name=$(basename "$script")
            local ver=$(grep "^VERSION=" "$script" 2>/dev/null | cut -d'"' -f2)
            echo "  $name: v$ver"
        fi
    done

    echo ""
    echo "Update Check:"
    echo "============="

    # In production, this would check a remote repository
    # For now, check local versions
    echo "  Status: All components up to date"
    echo "  Last check: $(date)"

    # Save check time
    date +%s > "$STATE_DIR/last_check"

    log_message "Update check completed"
}

list_updates() {
    echo "Available Updates:"
    echo "=================="

    # In production, this would fetch from update repository
    # For now, show placeholder
    echo "No updates available"
    echo ""
    echo "All VirtOS components are current (v$VERSION)"
}

install_update() {
    local update_id="$1"
    local force="$2"

    log_message "Installing update: $update_id"

    echo "Installing update: $update_id"

    # Backup current version if enabled
    if [ "$BACKUP_BEFORE_UPDATE" = "yes" ]; then
        echo "Creating backup..."
        local backup_dir="$UPDATE_DIR/backups/$(date +%Y%m%d-%H%M%S)"
        mkdir -p "$backup_dir"

        # Backup virtos scripts
        for script in /usr/local/bin/virtos-*; do
            if [ -f "$script" ]; then
                cp "$script" "$backup_dir/"
            fi
        done

        log_message "Backup created: $backup_dir"
        echo "Backup saved to: $backup_dir"
    fi

    # In production, download and apply update
    echo "Applying update..."

    # Record update in history
    echo "$(date +%s)|$update_id|installed" >> "$UPDATE_DIR/history.log"

    log_message "Update installed: $update_id"
    echo "Update installed successfully"

    # Cleanup old backups
    cleanup_backups
}

install_all_updates() {
    echo "Installing all available updates..."

    # In production, this would install all pending updates
    list_updates

    echo ""
    echo "All components are current"
}

rollback_update() {
    local update_id="$1"

    log_message "Rolling back update: $update_id"
    echo "Rolling back update: $update_id"

    # Find most recent backup
    local latest_backup=$(ls -td "$UPDATE_DIR/backups"/* 2>/dev/null | head -1)

    if [ -z "$latest_backup" ]; then
        echo "Error: No backups available"
        return 1
    fi

    echo "Restoring from backup: $latest_backup"

    # Restore scripts
    for script in "$latest_backup"/virtos-*; do
        if [ -f "$script" ]; then
            local name=$(basename "$script")
            cp "$script" "/usr/local/bin/$name"
            chmod +x "/usr/local/bin/$name"
            echo "  Restored: $name"
        fi
    done

    # Record rollback
    echo "$(date +%s)|$update_id|rolled_back" >> "$UPDATE_DIR/history.log"

    log_message "Rollback completed: $update_id"
    echo "Rollback completed successfully"
}

show_history() {
    echo "Update History:"
    echo "==============="

    if [ ! -f "$UPDATE_DIR/history.log" ]; then
        echo "No update history"
        return 0
    fi

    printf "%-20s %-30s %-15s\n" "DATE" "UPDATE" "ACTION"
    echo "----------------------------------------------------------------"

    while IFS='|' read -r timestamp update action; do
        local date_str=$(date -d @$timestamp '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "unknown")
        printf "%-20s %-30s %-15s\n" "$date_str" "$update" "$action"
    done < "$UPDATE_DIR/history.log"
}

enable_auto_updates() {
    echo "Enabling automatic updates..."

    # Update config
    sed -i 's/^AUTO_INSTALL=.*/AUTO_INSTALL=yes/' "$UPDATE_DIR/config.conf"

    # Create cron job
    local cron_file="/etc/cron.d/virtos-update"
    cat > "$cron_file" <<EOF
# VirtOS automatic updates
# Check for updates daily at 3 AM
0 3 * * * root /usr/local/bin/virtos-update check && /usr/local/bin/virtos-update install-all
EOF

    log_message "Automatic updates enabled"
    echo "Automatic updates enabled (daily at 3 AM)"
}

disable_auto_updates() {
    echo "Disabling automatic updates..."

    # Update config
    sed -i 's/^AUTO_INSTALL=.*/AUTO_INSTALL=no/' "$UPDATE_DIR/config.conf"

    # Remove cron job
    rm -f /etc/cron.d/virtos-update

    log_message "Automatic updates disabled"
    echo "Automatic updates disabled"
}

cleanup_backups() {
    local backup_count=$(ls -d "$UPDATE_DIR/backups"/* 2>/dev/null | wc -l)

    if [ "$backup_count" -gt "$MAX_BACKUPS" ]; then
        echo "Cleaning up old backups (keeping last $MAX_BACKUPS)..."

        local delete_count=$((backup_count - MAX_BACKUPS))

        ls -dt "$UPDATE_DIR/backups"/* | tail -n "$delete_count" | while read backup; do
            echo "  Removing: $backup"
            rm -rf "$backup"
        done

        log_message "Cleaned up $delete_count old backups"
    fi
}

# Initialize
init_config

# Parse options
FORCE="no"
NO_BACKUP="no"
DRY_RUN="no"

while [ $# -gt 0 ]; do
    case "$1" in
        --force)
            FORCE="yes"
            shift
            ;;
        --no-backup)
            NO_BACKUP="yes"
            BACKUP_BEFORE_UPDATE="no"
            shift
            ;;
        --dry-run)
            DRY_RUN="yes"
            shift
            ;;
        *)
            break
            ;;
    esac
done

# Main command handler
COMMAND="$1"
shift

case "$COMMAND" in
    check)
        check_updates
        ;;
    list)
        list_updates
        ;;
    install)
        install_update "$1" "$FORCE"
        ;;
    install-all)
        install_all_updates
        ;;
    rollback)
        rollback_update "$1"
        ;;
    history)
        show_history
        ;;
    auto-enable)
        enable_auto_updates
        ;;
    auto-disable)
        disable_auto_updates
        ;;
    --version|-v|version)
        echo "virtos-update version $VERSION"
        exit 0
        ;;
    --help|-h|help|"")
        usage
        exit 0
        ;;
    *)
        echo "Error: Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac
