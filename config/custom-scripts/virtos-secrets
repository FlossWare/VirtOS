# Secrets status
secrets_status() {
    echo "=== VirtOS Secrets Management Status ==="
    echo

    # Backend
    if [ -f "$SECRETS_CONFIG_DIR/secrets-backend.conf" ]; then
        local backend=$(cat "$SECRETS_CONFIG_DIR/secrets-backend.conf")
        echo "Secrets Backend: $backend"
    else
        echo "Secrets Backend: Not configured"
    fi

    # Vault status
    if command -v vault &>/dev/null; then
        export VAULT_ADDR='http://127.0.0.1:8200'
        echo "Vault: $(vault status 2>&1 | grep "Sealed" || echo "Installed")"
    fi

    echo
    echo "Auto-rotation scripts: $(ls -1 "$SECRETS_CONFIG_DIR"/rotation-*.sh 2>/dev/null | wc -l)"
    echo "Encrypted files: $(ls -1 "$SECRETS_CONFIG_DIR"/*.age 2>/dev/null | wc -l)"

    echo
    echo "Configuration: $SECRETS_CONFIG_DIR"
    echo "Logs: $SECRETS_LOG"
}

# Interactive wizard
secrets_wizard() {
    dialog --title "VirtOS Secrets Management" \
        --msgbox "This wizard will help you set up secrets management.\n\nConfigure Vault, rotation, and encryption." 12 60

    local choice=$(dialog --title "Choose Action" \
        --menu "Select secrets action:" 16 60 5 \
        1 "Setup Secrets Manager" \
        2 "Store Secret" \
        3 "Setup Auto-Rotation" \
        4 "Encrypt Data" \
        5 "Audit Secrets Access" \
        2>&1 >/dev/tty)

    case "$choice" in
        1)
            local backend=$(dialog --menu "Secrets Backend:" 13 60 4 \
                vault "HashiCorp Vault" \
                sealed-secrets "Sealed Secrets (K8s)" \
                sops "Mozilla SOPS" \
                aws-secrets "AWS Secrets Manager" \
                2>&1 >/dev/tty)
            setup_secrets_manager "$backend"
            ;;

        2)
            local path=$(dialog --inputbox "Secret path:" 10 60 "secret/data/myapp" 2>&1 >/dev/tty)
            local key=$(dialog --inputbox "Key name:" 10 60 "password" 2>&1 >/dev/tty)
            local value=$(dialog --passwordbox "Secret value:" 10 60 2>&1 >/dev/tty)

            store_secret "$path" "$key" "$value"
            ;;

        3)
            local path=$(dialog --inputbox "Secret path:" 10 60 2>&1 >/dev/tty)
            local interval=$(dialog --menu "Rotation interval:" 12 60 3 \
                daily "Daily" \
                weekly "Weekly" \
                monthly "Monthly" \
                2>&1 >/dev/tty)

            setup_auto_rotation "$path" "$interval"
            ;;

        4)
            local input=$(dialog --inputbox "Input file:" 10 60 2>&1 >/dev/tty)
            local output=$(dialog --inputbox "Output file:" 10 60 "${input}.encrypted" 2>&1 >/dev/tty)
            local method=$(dialog --menu "Encryption method:" 12 60 3 \
                age "Age (modern)" \
                gpg "GPG" \
                openssl "OpenSSL" \
                2>&1 >/dev/tty)

            encrypt_data "$input" "$output" "$method"
            ;;

        5)
            audit_secrets | dialog --title "Secrets Audit" --programbox 30 100
            ;;
    esac

    dialog --title "Setup Complete" \
        --msgbox "Secrets management configured!" 8 40
}

# Show usage
usage() {
    cat <<EOF
VirtOS Secrets Management - Vault, rotation, encryption

Usage: virtos-secrets <command> [options]

Setup Commands:
  setup-manager <backend>                      Setup secrets manager (vault/sealed-secrets/sops/aws-secrets)

Secret Operations:
  store-secret <path> <key> <value>            Store a secret
  retrieve-secret <path> <key>                 Retrieve a secret
  rotate-secret <path> <key> <new_value>       Rotate a secret

Rotation Commands:
  setup-auto-rotation <path> <interval>        Setup auto-rotation (daily/weekly/monthly)

Encryption Commands:
  encrypt-data <input> <output> <method>       Encrypt data (age/gpg/openssl)
  decrypt-data <input> <output> <method>       Decrypt data

Audit Commands:
  audit-secrets                                Audit secrets access

Status Commands:
  status                                       Show secrets status
  wizard                                       Interactive setup wizard

Examples:
  virtos-secrets setup-manager vault
  virtos-secrets store-secret secret/data/myapp password "s3cr3t"
  virtos-secrets retrieve-secret secret/data/myapp password
  virtos-secrets rotate-secret secret/data/myapp password "n3ws3cr3t"
  virtos-secrets setup-auto-rotation secret/data/myapp weekly
  virtos-secrets encrypt-data config.yaml config.yaml.age age
  virtos-secrets audit-secrets
  virtos-secrets wizard

Version: $VERSION
EOF
}

# Main command dispatcher
case "$1" in
    setup-manager)
        setup_secrets_manager "$2"
        ;;
    store-secret)
        store_secret "$2" "$3" "$4"
        ;;
    retrieve-secret)
        retrieve_secret "$2" "$3"
        ;;
    rotate-secret)
        rotate_secret "$2" "$3" "$4"
        ;;
    setup-auto-rotation)
        setup_auto_rotation "$2" "$3"
        ;;
    encrypt-data)
        encrypt_data "$2" "$3" "$4"
        ;;
    decrypt-data)
        decrypt_data "$2" "$3" "$4"
        ;;
    audit-secrets)
        audit_secrets
        ;;
    status)
        secrets_status
        ;;
    wizard)
        secrets_wizard
        ;;
    version|--version|-v)
        echo "virtos-secrets version $VERSION"
        ;;
    *)
        usage
        ;;
esac
