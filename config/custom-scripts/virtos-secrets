#!/bin/bash
set -e
# VirtOS Secrets Management
# HashiCorp Vault, secrets rotation, encryption

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.25")

# Configuration
SECRETS_CONFIG_DIR="/etc/virtos/secrets"
SECRETS_LOG="/var/log/virtos-secrets.log"

# Ensure config directory exists
mkdir -p "$SECRETS_CONFIG_DIR"

# Logging function
log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$SECRETS_LOG"
}

# Setup secrets manager
setup_secrets_manager() {
    local backend="$1"  # vault, sealed-secrets, sops, aws-secrets

    log_message "Setting up secrets manager: $backend..."

    case "$backend" in
        vault)
            # Install HashiCorp Vault
            wget -q https://releases.hashicorp.com/vault/1.13.0/vault_1.13.0_linux_amd64.zip
            unzip -o vault_1.13.0_linux_amd64.zip -d /usr/local/bin/
            chmod +x /usr/local/bin/vault

            # Create Vault config
            mkdir -p /etc/vault.d

            cat > /etc/vault.d/vault.hcl <<EOF
storage "file" {
  path = "/var/lib/vault/data"
}

listener "tcp" {
  address     = "0.0.0.0:8200"
  tls_disable = 1
}

api_addr = "http://127.0.0.1:8200"
ui = true
EOF

            # Create systemd service
            cat > /etc/systemd/system/vault.service <<EOF
[Unit]
Description=HashiCorp Vault
Documentation=https://www.vaultproject.io/docs/
Requires=network-online.target
After=network-online.target

[Service]
Type=notify
ExecStart=/usr/local/bin/vault server -config=/etc/vault.d/vault.hcl
ExecReload=/bin/kill --signal HUP \$MAINPID
KillMode=process
Restart=on-failure
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
EOF

            # Start Vault
            systemctl daemon-reload
            systemctl enable vault
            systemctl start vault

            # Initialize Vault
            export VAULT_ADDR='http://127.0.0.1:8200'
            vault operator init -key-shares=5 -key-threshold=3 > "$SECRETS_CONFIG_DIR/vault-init.txt"

            log_message "Vault installed. Init keys saved to $SECRETS_CONFIG_DIR/vault-init.txt"
            log_message "IMPORTANT: Securely store unseal keys and root token!"
            ;;

        sealed-secrets)
            # Install Sealed Secrets (Kubernetes)
            kubectl apply -f https://github.com/bitnami-labs/sealed-secrets/releases/download/v0.20.0/controller.yaml

            # Install kubeseal CLI
            wget -q https://github.com/bitnami-labs/sealed-secrets/releases/download/v0.20.0/kubeseal-0.20.0-linux-amd64.tar.gz
            tar -xzf kubeseal-0.20.0-linux-amd64.tar.gz -C /usr/local/bin/

            log_message "Sealed Secrets installed for Kubernetes"
            ;;

        sops)
            # Install SOPS
            wget -q https://github.com/mozilla/sops/releases/download/v3.7.3/sops-v3.7.3.linux -O /usr/local/bin/sops
            chmod +x /usr/local/bin/sops

            # Create SOPS config
            cat > "$SECRETS_CONFIG_DIR/.sops.yaml" <<EOF
creation_rules:
  - path_regex: \.yaml$
    encrypted_regex: ^(data|stringData)$
    age: age1234567890abcdef
EOF

            log_message "SOPS installed. Configure encryption keys in $SECRETS_CONFIG_DIR/.sops.yaml"
            ;;

        aws-secrets)
            # Install AWS CLI if not present
            command -v aws &>/dev/null || {
                curl "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "awscliv2.zip"
                unzip awscliv2.zip
                ./aws/install
                rm -rf aws awscliv2.zip
            }

            log_message "AWS Secrets Manager available via AWS CLI"
            ;;
    esac

    echo "$backend" > "$SECRETS_CONFIG_DIR/secrets-backend.conf"
}

# Store secret
store_secret() {
    local path="$1"
    local key="$2"
    local value="$3"
    local backend=$(cat "$SECRETS_CONFIG_DIR/secrets-backend.conf" 2>/dev/null || echo "vault")

    log_message "Storing secret at $path/$key..."

    case "$backend" in
        vault)
            export VAULT_ADDR='http://127.0.0.1:8200'
            vault kv put "$path" "$key=$value"
            ;;

        aws-secrets)
            aws secretsmanager create-secret \
                --name "$path/$key" \
                --secret-string "$value"
            ;;

        sops)
            # Create or update SOPS file
            local file="$SECRETS_CONFIG_DIR/secrets-$path.yaml"
            if [ ! -f "$file" ]; then
                echo "$key: $value" | sops -e > "$file"
            else
                # Decrypt, update, re-encrypt
                sops -d "$file" | sed "s/$key:.*/$key: $value/" | sops -e > "$file.tmp"
                mv "$file.tmp" "$file"
            fi
            ;;
    esac

    log_message "Secret stored successfully"
}

# Retrieve secret
retrieve_secret() {
    local path="$1"
    local key="$2"
    local backend=$(cat "$SECRETS_CONFIG_DIR/secrets-backend.conf" 2>/dev/null || echo "vault")

    log_message "Retrieving secret from $path/$key..."

    case "$backend" in
        vault)
            export VAULT_ADDR='http://127.0.0.1:8200'
            vault kv get -field="$key" "$path"
            ;;

        aws-secrets)
            aws secretsmanager get-secret-value \
                --secret-id "$path/$key" \
                --query SecretString \
                --output text
            ;;

        sops)
            local file="$SECRETS_CONFIG_DIR/secrets-$path.yaml"
            sops -d "$file" | grep "^$key:" | cut -d: -f2- | xargs
            ;;
    esac
}

# Rotate secret
rotate_secret() {
    local path="$1"
    local key="$2"
    local new_value="$3"

    log_message "Rotating secret at $path/$key..."

    # Store old value as backup
    local old_value=$(retrieve_secret "$path" "$key")
    store_secret "$path" "${key}_backup_$(date +%Y%m%d)" "$old_value"

    # Store new value
    store_secret "$path" "$key" "$new_value"

    log_message "Secret rotated successfully. Backup created."
}

# Auto-rotate secrets
setup_auto_rotation() {
    local path="$1"
    local interval="$2"  # daily, weekly, monthly

    log_message "Setting up auto-rotation for $path ($interval)..."

    cat > "$SECRETS_CONFIG_DIR/rotation-$path.sh" <<EOF
#!/bin/bash
# Auto-rotation script for $path

# Generate new secret (example: random password)
NEW_SECRET=\$(openssl rand -base64 32)

# Rotate the secret
virtos-secrets rotate-secret $path password "\$NEW_SECRET"

# Update dependent services
# Add your service update logic here
# systemctl restart myservice

echo "Secret rotated at \$(date)" >> /var/log/secrets-rotation.log
EOF

    chmod +x "$SECRETS_CONFIG_DIR/rotation-$path.sh"

    # Add to crontab
    case "$interval" in
        daily)
            echo "0 2 * * * $SECRETS_CONFIG_DIR/rotation-$path.sh" | crontab -
            ;;
        weekly)
            echo "0 2 * * 0 $SECRETS_CONFIG_DIR/rotation-$path.sh" | crontab -
            ;;
        monthly)
            echo "0 2 1 * * $SECRETS_CONFIG_DIR/rotation-$path.sh" | crontab -
            ;;
    esac

    log_message "Auto-rotation configured for $path"
}

# Encrypt data
encrypt_data() {
    local input_file="$1"
    local output_file="$2"
    local method="$3"  # age, gpg, openssl

    log_message "Encrypting $input_file with $method..."

    case "$method" in
        age)
            # Install age if needed
            command -v age &>/dev/null || {
                wget -q https://github.com/FiloSottile/age/releases/download/v1.1.1/age-v1.1.1-linux-amd64.tar.gz
                tar -xzf age-v1.1.1-linux-amd64.tar.gz
                mv age/age /usr/local/bin/
            }

            # Generate key if doesn't exist
            if [ ! -f "$SECRETS_CONFIG_DIR/age-key.txt" ]; then
                age-keygen -o "$SECRETS_CONFIG_DIR/age-key.txt"
                log_message "Age key generated: $SECRETS_CONFIG_DIR/age-key.txt"
            fi

            # Encrypt
            age -r $(cat "$SECRETS_CONFIG_DIR/age-key.txt" | grep "public key:" | cut -d: -f2) \
                -o "$output_file" "$input_file"
            ;;

        gpg)
            gpg --encrypt --recipient virtos@example.com --output "$output_file" "$input_file"
            ;;

        openssl)
            openssl enc -aes-256-cbc -salt -in "$input_file" -out "$output_file" -k $(openssl rand -base64 32)
            ;;
    esac

    log_message "Data encrypted to $output_file"
}

# Decrypt data
decrypt_data() {
    local input_file="$1"
    local output_file="$2"
    local method="$3"

    log_message "Decrypting $input_file with $method..."

    case "$method" in
        age)
            age -d -i "$SECRETS_CONFIG_DIR/age-key.txt" -o "$output_file" "$input_file"
            ;;

        gpg)
            gpg --decrypt --output "$output_file" "$input_file"
            ;;

        openssl)
            openssl enc -aes-256-cbc -d -in "$input_file" -out "$output_file"
            ;;
    esac

    log_message "Data decrypted to $output_file"
}

