#!/bin/bash
set -e
# virtos-security - Security hardening and policy management for VirtOS
# Part of Phase 10: Metrics, Telemetry, and Advanced Features

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.25")
SCRIPT_NAME="virtos-security"
LOG_FILE="/var/log/virtos-security.log"
CONFIG_FILE="/etc/virtos/security.conf"
POLICY_DIR="/etc/virtos/security-policies"
AUDIT_DIR="/var/log/virtos/security-audits"

# Security configuration defaults
SELINUX_MODE="enforcing"
APPARMOR_MODE="enforce"
FIREWALL_DEFAULT_POLICY="drop"
SSH_HARDENING_ENABLED="yes"
AUDIT_LOGGING_ENABLED="yes"
VULNERABILITY_SCAN_ENABLED="yes"
COMPLIANCE_FRAMEWORK="cis"  # CIS, NIST, PCI-DSS, HIPAA
AUTO_REMEDIATION="no"
SCAN_INTERVAL="86400"  # 24 hours

# Initialize logging
init_logging() {
    mkdir -p "$(dirname "$LOG_FILE")"
    mkdir -p "$POLICY_DIR"
    mkdir -p "$AUDIT_DIR"
}

# Log message
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

# Load configuration
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
}

# Save configuration
save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" << EOF
# VirtOS Security Configuration
# Generated by virtos-security version $VERSION

SELINUX_MODE="$SELINUX_MODE"
APPARMOR_MODE="$APPARMOR_MODE"
FIREWALL_DEFAULT_POLICY="$FIREWALL_DEFAULT_POLICY"
SSH_HARDENING_ENABLED="$SSH_HARDENING_ENABLED"
AUDIT_LOGGING_ENABLED="$AUDIT_LOGGING_ENABLED"
VULNERABILITY_SCAN_ENABLED="$VULNERABILITY_SCAN_ENABLED"
COMPLIANCE_FRAMEWORK="$COMPLIANCE_FRAMEWORK"
AUTO_REMEDIATION="$AUTO_REMEDIATION"
SCAN_INTERVAL="$SCAN_INTERVAL"
EOF
    log "Configuration saved to $CONFIG_FILE"
}

# Initialize SELinux
selinux_init() {
    local mode="${1:-enforcing}"

    log "Initializing SELinux in $mode mode..."

    # Check if SELinux is available
    if ! command -v setenforce &> /dev/null; then
        log "ERROR: SELinux not available. Installing..."
        tce-load -wi selinux-policy-targeted
        if [ $? -ne 0 ]; then
            log "ERROR: Failed to install SELinux"
            return 1
        fi
    fi

    # Set SELinux mode
    case "$mode" in
        enforcing)
            setenforce 1
            sed -i 's/^SELINUX=.*/SELINUX=enforcing/' /etc/selinux/config
            ;;
        permissive)
            setenforce 0
            sed -i 's/^SELINUX=.*/SELINUX=permissive/' /etc/selinux/config
            ;;
        disabled)
            sed -i 's/^SELINUX=.*/SELINUX=disabled/' /etc/selinux/config
            log "SELinux disabled - reboot required"
            ;;
        *)
            log "ERROR: Invalid mode: $mode (use enforcing, permissive, or disabled)"
            return 1
            ;;
    esac

    SELINUX_MODE="$mode"
    save_config

    log "SELinux initialized in $mode mode"
    log "Current status: $(getenforce)"
}

# Create SELinux policy
selinux_policy_create() {
    local name="$1"
    local type="${2:-targeted}"

    if [ -z "$name" ]; then
        log "ERROR: Policy name required"
        return 1
    fi

    log "Creating SELinux policy: $name (type: $type)..."

    local policy_file="$POLICY_DIR/${name}.te"

    cat > "$policy_file" << EOF
policy_module($name, 1.0)

# VirtOS custom SELinux policy
# Generated by virtos-security

require {
    type virtos_t;
    type virtos_exec_t;
    class process { fork signal };
    class file { read write open };
}

# Allow virtos processes to fork and signal
allow virtos_t self:process { fork signal };

# Allow virtos to read/write files
allow virtos_t virtos_exec_t:file { read write open };
EOF

    log "Policy template created at $policy_file"
    log "Edit the policy file and run: virtos-security selinux-policy-compile $name"
}

# Compile SELinux policy
selinux_policy_compile() {
    local name="$1"

    if [ -z "$name" ]; then
        log "ERROR: Policy name required"
        return 1
    fi

    local policy_file="$POLICY_DIR/${name}.te"

    if [ ! -f "$policy_file" ]; then
        log "ERROR: Policy file not found: $policy_file"
        return 1
    fi

    log "Compiling SELinux policy: $name..."

    cd "$POLICY_DIR" || return 1

    checkmodule -M -m -o "${name}.mod" "${name}.te"
    if [ $? -ne 0 ]; then
        log "ERROR: Failed to compile policy module"
        return 1
    fi

    semodule_package -o "${name}.pp" -m "${name}.mod"
    if [ $? -ne 0 ]; then
        log "ERROR: Failed to package policy module"
        return 1
    fi

    semodule -i "${name}.pp"
    if [ $? -ne 0 ]; then
        log "ERROR: Failed to install policy module"
        return 1
    fi

    log "SELinux policy $name compiled and installed successfully"
}

# Initialize AppArmor
apparmor_init() {
    local mode="${1:-enforce}"

    log "Initializing AppArmor in $mode mode..."

    # Check if AppArmor is available
    if ! command -v aa-status &> /dev/null; then
        log "ERROR: AppArmor not available. Installing..."
        tce-load -wi apparmor
        if [ $? -ne 0 ]; then
            log "ERROR: Failed to install AppArmor"
            return 1
        fi
    fi

    # Enable AppArmor
    systemctl enable apparmor 2>/dev/null || true
    systemctl start apparmor 2>/dev/null || true

    APPARMOR_MODE="$mode"
    save_config

    log "AppArmor initialized in $mode mode"
    aa-status
}

# Create AppArmor profile
apparmor_profile_create() {
    local name="$1"
    local binary="${2:-/usr/local/bin/$name}"

    if [ -z "$name" ]; then
        log "ERROR: Profile name required"
        return 1
    fi

    log "Creating AppArmor profile: $name..."

    local profile_file="/etc/apparmor.d/$name"

    cat > "$profile_file" << EOF
# VirtOS AppArmor profile for $name
# Generated by virtos-security

#include <tunables/global>

$binary {
    #include <abstractions/base>

    # Allow network access
    network inet stream,
    network inet dgram,

    # Allow file operations
    /etc/** r,
    /var/log/** rw,
    /tmp/** rw,

    # Allow execution
    $binary mr,
    /bin/** ix,
    /usr/bin/** ix,
}
EOF

    log "Profile created at $profile_file"
    log "Load profile with: virtos-security apparmor-profile-load $name"
}

# Load AppArmor profile
apparmor_profile_load() {
    local name="$1"

    if [ -z "$name" ]; then
        log "ERROR: Profile name required"
        return 1
    fi

    local profile_file="/etc/apparmor.d/$name"

    if [ ! -f "$profile_file" ]; then
        log "ERROR: Profile not found: $profile_file"
        return 1
    fi

    log "Loading AppArmor profile: $name..."

    apparmor_parser -r "$profile_file"
    if [ $? -ne 0 ]; then
        log "ERROR: Failed to load AppArmor profile"
        return 1
    fi

    log "AppArmor profile $name loaded successfully"
}

# Harden SSH configuration
ssh_harden() {
    log "Hardening SSH configuration..."

    local sshd_config="/etc/ssh/sshd_config"

    if [ ! -f "$sshd_config" ]; then
        log "ERROR: SSH configuration not found"
        return 1
    fi

    # Backup original configuration
    cp "$sshd_config" "${sshd_config}.backup"

    # Apply hardening settings
    cat >> "$sshd_config" << 'EOF'

# VirtOS SSH Hardening
# Applied by virtos-security

# Disable root login
PermitRootLogin no

# Use public key authentication only
PubkeyAuthentication yes
PasswordAuthentication no
ChallengeResponseAuthentication no

# Disable empty passwords
PermitEmptyPasswords no

# Limit authentication attempts
MaxAuthTries 3

# Session timeout
ClientAliveInterval 300
ClientAliveCountMax 2

# Disable X11 forwarding
X11Forwarding no

# Use strong ciphers only
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes256-ctr
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
KexAlgorithms curve25519-sha256,diffie-hellman-group-exchange-sha256

# Log more information
LogLevel VERBOSE
EOF

    # Restart SSH service
    systemctl restart sshd 2>/dev/null || /etc/init.d/ssh restart

    SSH_HARDENING_ENABLED="yes"
    save_config

    log "SSH hardening applied successfully"
    log "Backup saved to ${sshd_config}.backup"
}

# Configure firewall
firewall_init() {
    local default_policy="${1:-drop}"

    log "Initializing firewall with default policy: $default_policy..."

    # Install iptables if needed
    if ! command -v iptables &> /dev/null; then
        tce-load -wi iptables
    fi

    # Flush existing rules
    iptables -F
    iptables -X
    iptables -t nat -F
    iptables -t nat -X
    iptables -t mangle -F
    iptables -t mangle -X

    # Set default policies
    case "$default_policy" in
        drop)
            iptables -P INPUT DROP
            iptables -P FORWARD DROP
            iptables -P OUTPUT ACCEPT
            ;;
        reject)
            iptables -P INPUT REJECT
            iptables -P FORWARD REJECT
            iptables -P OUTPUT ACCEPT
            ;;
        accept)
            iptables -P INPUT ACCEPT
            iptables -P FORWARD ACCEPT
            iptables -P OUTPUT ACCEPT
            ;;
    esac

    # Allow loopback
    iptables -A INPUT -i lo -j ACCEPT

    # Allow established connections
    iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

    # Allow SSH (port 22)
    iptables -A INPUT -p tcp --dport 22 -j ACCEPT

    # Allow libvirt (if installed)
    if command -v virsh &> /dev/null; then
        iptables -A INPUT -p tcp --dport 16509 -j ACCEPT  # libvirt
    fi

    # Save rules
    iptables-save > /etc/iptables.rules

    FIREWALL_DEFAULT_POLICY="$default_policy"
    save_config

    log "Firewall initialized with default policy: $default_policy"
}

# Add firewall rule
firewall_rule_add() {
    local protocol="$1"
    local port="$2"
    local action="${3:-ACCEPT}"

    if [ -z "$protocol" ] || [ -z "$port" ]; then
        log "ERROR: Protocol and port required"
        return 1
    fi

    log "Adding firewall rule: $protocol/$port -> $action..."

    iptables -A INPUT -p "$protocol" --dport "$port" -j "$action"

    # Save rules
    iptables-save > /etc/iptables.rules

    log "Firewall rule added successfully"
}

# Run vulnerability scan
vulnerability_scan() {
    local target="${1:-.}"

    log "Running vulnerability scan on: $target..."

    # Install scanner if needed
    if ! command -v lynis &> /dev/null; then
        log "Installing Lynis security scanner..."
        tce-load -wi lynis
    fi

    # Run Lynis audit
    local audit_file="$AUDIT_DIR/audit-$(date +%Y%m%d-%H%M%S).log"

    lynis audit system --quick --quiet > "$audit_file" 2>&1

    log "Vulnerability scan completed"
    log "Results saved to: $audit_file"

    # Show summary
    grep -A 5 "Hardening index" "$audit_file" | tee -a "$LOG_FILE"
}

# Run compliance check
compliance_check() {
    local framework="${1:-$COMPLIANCE_FRAMEWORK}"

    log "Running compliance check for framework: $framework..."

    local report_file="$AUDIT_DIR/compliance-$framework-$(date +%Y%m%d-%H%M%S).log"

    case "$framework" in
        cis)
            log "Checking CIS benchmarks..."
            # CIS benchmark checks
            {
                echo "=== CIS Benchmark Compliance Check ==="
                echo ""
                echo "1. Ensure mounting of cramfs filesystems is disabled"
                lsmod | grep cramfs && echo "FAIL" || echo "PASS"

                echo "2. Ensure /tmp is configured"
                mount | grep /tmp && echo "PASS" || echo "FAIL"

                echo "3. Ensure SSH Protocol is set to 2"
                grep "^Protocol 2" /etc/ssh/sshd_config && echo "PASS" || echo "FAIL"

                echo "4. Ensure permissions on /etc/passwd are configured"
                stat -L -c "%a" /etc/passwd | grep 644 && echo "PASS" || echo "FAIL"

                echo "5. Ensure no duplicate UIDs exist"
                cut -f3 -d":" /etc/passwd | sort -n | uniq -c | grep -v " 1 " && echo "FAIL" || echo "PASS"
            } > "$report_file"
            ;;
        nist)
            log "Checking NIST 800-53 controls..."
            echo "=== NIST 800-53 Compliance Check ===" > "$report_file"
            echo "Controls check not yet implemented" >> "$report_file"
            ;;
        pci-dss)
            log "Checking PCI-DSS requirements..."
            echo "=== PCI-DSS Compliance Check ===" > "$report_file"
            echo "Requirements check not yet implemented" >> "$report_file"
            ;;
        hipaa)
            log "Checking HIPAA requirements..."
            echo "=== HIPAA Compliance Check ===" > "$report_file"
            echo "Requirements check not yet implemented" >> "$report_file"
            ;;
        *)
            log "ERROR: Unknown framework: $framework"
            return 1
            ;;
    esac

    log "Compliance check completed"
    log "Report saved to: $report_file"

    cat "$report_file"
}

# Enable security audit logging
audit_enable() {
    log "Enabling security audit logging..."

    # Install auditd if needed
    if ! command -v auditctl &> /dev/null; then
        log "Installing auditd..."
        tce-load -wi audit
    fi

    # Enable auditd
    systemctl enable auditd 2>/dev/null || true
    systemctl start auditd 2>/dev/null || true

    # Add audit rules
    cat > /etc/audit/rules.d/virtos.rules << 'EOF'
# VirtOS Audit Rules
# Generated by virtos-security

# Log all commands executed by root
-a always,exit -F arch=b64 -F euid=0 -S execve -k root-commands

# Monitor changes to system configuration
-w /etc/ -p wa -k etc-changes
-w /boot/ -p wa -k boot-changes

# Monitor libvirt operations
-w /etc/libvirt/ -p wa -k libvirt-config
-w /var/lib/libvirt/ -p wa -k libvirt-data

# Monitor user and group changes
-w /etc/passwd -p wa -k user-changes
-w /etc/group -p wa -k group-changes
-w /etc/shadow -p wa -k shadow-changes

# Monitor network configuration
-w /etc/network/ -p wa -k network-changes
-a always,exit -F arch=b64 -S socket -S connect -k network-connect
EOF

    # Reload audit rules
    auditctl -R /etc/audit/rules.d/virtos.rules

    AUDIT_LOGGING_ENABLED="yes"
    save_config

    log "Security audit logging enabled"
}

# View audit logs
audit_logs() {
    local filter="${1:-}"

    log "Viewing audit logs..."

    if [ -z "$filter" ]; then
        ausearch -i | tail -50
    else
        ausearch -i -k "$filter" | tail -50
    fi
}

# Security status
security_status() {
    log "=== VirtOS Security Status ==="
    echo ""

    echo "SELinux:"
    if command -v getenforce &> /dev/null; then
        echo "  Status: $(getenforce)"
    else
        echo "  Status: Not installed"
    fi
    echo ""

    echo "AppArmor:"
    if command -v aa-status &> /dev/null; then
        aa-status --profiled
    else
        echo "  Status: Not installed"
    fi
    echo ""

    echo "Firewall:"
    if command -v iptables &> /dev/null; then
        echo "  Rules: $(iptables -L INPUT | wc -l) INPUT rules"
        echo "  Default: $FIREWALL_DEFAULT_POLICY"
    else
        echo "  Status: Not configured"
    fi
    echo ""

    echo "SSH Hardening:"
    echo "  Enabled: $SSH_HARDENING_ENABLED"
    if [ "$SSH_HARDENING_ENABLED" = "yes" ]; then
        echo "  Root login: $(grep PermitRootLogin /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}')"
        echo "  Password auth: $(grep PasswordAuthentication /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}')"
    fi
    echo ""

    echo "Audit Logging:"
    echo "  Enabled: $AUDIT_LOGGING_ENABLED"
    if command -v auditctl &> /dev/null; then
        echo "  Rules: $(auditctl -l | wc -l)"
    fi
    echo ""

    echo "Compliance Framework: $COMPLIANCE_FRAMEWORK"
    echo "Auto-remediation: $AUTO_REMEDIATION"
}

# Run security wizard
security_wizard() {
    log "Starting VirtOS Security Setup Wizard..."

    echo "=== VirtOS Security Setup Wizard ==="
    echo ""

    # SELinux setup
    echo "1. SELinux Configuration"
    echo "   Choose mode:"
    echo "   1) Enforcing (recommended)"
    echo "   2) Permissive"
    echo "   3) Disabled"
    read -p "   Selection [1]: " selinux_choice

    case "${selinux_choice:-1}" in
        1) selinux_init enforcing ;;
        2) selinux_init permissive ;;
        3) selinux_init disabled ;;
    esac

    # Firewall setup
    echo ""
    echo "2. Firewall Configuration"
    read -p "   Default policy (drop/accept) [drop]: " fw_policy
    firewall_init "${fw_policy:-drop}"

    # SSH hardening
    echo ""
    echo "3. SSH Hardening"
    read -p "   Apply SSH hardening? (y/n) [y]: " ssh_choice
    if [ "${ssh_choice:-y}" = "y" ]; then
        ssh_harden
    fi

    # Audit logging
    echo ""
    echo "4. Audit Logging"
    read -p "   Enable audit logging? (y/n) [y]: " audit_choice
    if [ "${audit_choice:-y}" = "y" ]; then
        audit_enable
    fi

    # Compliance framework
    echo ""
    echo "5. Compliance Framework"
    echo "   Choose framework:"
    echo "   1) CIS Benchmarks (recommended)"
    echo "   2) NIST 800-53"
    echo "   3) PCI-DSS"
    echo "   4) HIPAA"
    read -p "   Selection [1]: " compliance_choice

    case "${compliance_choice:-1}" in
        1) COMPLIANCE_FRAMEWORK="cis" ;;
        2) COMPLIANCE_FRAMEWORK="nist" ;;
        3) COMPLIANCE_FRAMEWORK="pci-dss" ;;
        4) COMPLIANCE_FRAMEWORK="hipaa" ;;
    esac

    save_config

    echo ""
    log "Security wizard completed!"
    echo ""
    echo "Next steps:"
    echo "  - Review configuration: virtos-security status"
    echo "  - Run compliance check: virtos-security compliance-check"
    echo "  - Run vulnerability scan: virtos-security vulnerability-scan"
}

# Show usage
usage() {
    cat << EOF
VirtOS Security Management - Version $VERSION

Usage: $SCRIPT_NAME <command> [options]

Commands:
  selinux-init <mode>                     Initialize SELinux (enforcing/permissive/disabled)
  selinux-policy-create <name> [type]    Create SELinux policy template
  selinux-policy-compile <name>          Compile and install SELinux policy

  apparmor-init [mode]                   Initialize AppArmor (enforce/complain)
  apparmor-profile-create <name> [bin]   Create AppArmor profile
  apparmor-profile-load <name>           Load AppArmor profile

  ssh-harden                             Harden SSH configuration

  firewall-init [policy]                 Initialize firewall (drop/reject/accept)
  firewall-rule-add <proto> <port> [act] Add firewall rule

  vulnerability-scan [target]            Run vulnerability scan with Lynis
  compliance-check [framework]           Check compliance (cis/nist/pci-dss/hipaa)

  audit-enable                           Enable security audit logging
  audit-logs [filter]                    View audit logs

  status                                 Show security status
  wizard                                 Run interactive setup wizard

  version                                Show version
  help                                   Show this help

Examples:
  # Setup wizard (recommended for first-time setup)
  $SCRIPT_NAME wizard

  # Initialize SELinux in enforcing mode
  $SCRIPT_NAME selinux-init enforcing

  # Harden SSH
  $SCRIPT_NAME ssh-harden

  # Setup firewall
  $SCRIPT_NAME firewall-init drop
  $SCRIPT_NAME firewall-rule-add tcp 80 ACCEPT

  # Run security scans
  $SCRIPT_NAME vulnerability-scan
  $SCRIPT_NAME compliance-check cis

  # Check status
  $SCRIPT_NAME status

EOF
}

# Main
main() {
    init_logging
    load_config

    case "${1:-help}" in
        selinux-init)
            selinux_init "$2"
            ;;
        selinux-policy-create)
            selinux_policy_create "$2" "$3"
            ;;
        selinux-policy-compile)
            selinux_policy_compile "$2"
            ;;
        apparmor-init)
            apparmor_init "$2"
            ;;
        apparmor-profile-create)
            apparmor_profile_create "$2" "$3"
            ;;
        apparmor-profile-load)
            apparmor_profile_load "$2"
            ;;
        ssh-harden)
            ssh_harden
            ;;
        firewall-init)
            firewall_init "$2"
            ;;
        firewall-rule-add)
            firewall_rule_add "$2" "$3" "$4"
            ;;
        vulnerability-scan)
            vulnerability_scan "$2"
            ;;
        compliance-check)
            compliance_check "$2"
            ;;
        audit-enable)
            audit_enable
            ;;
        audit-logs)
            audit_logs "$2"
            ;;
        status)
            security_status
            ;;
        wizard)
            security_wizard
            ;;
        version|--version|-v)
            echo "$SCRIPT_NAME version $VERSION"
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            echo "Unknown command: $1"
            echo "Run '$SCRIPT_NAME help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
