set -e
# virtos-billing - Cost tracking and billing management for VirtOS
# Part of Phase 10: Metrics, Telemetry, and Advanced Features

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.23")
SCRIPT_NAME="virtos-billing"
LOG_FILE="/var/log/virtos-billing.log"
CONFIG_FILE="/etc/virtos/billing.conf"
BILLING_DIR="/var/lib/virtos/billing"
INVOICE_DIR="/var/lib/virtos/invoices"
PRICE_FILE="/etc/virtos/pricing.conf"

# Billing configuration defaults
BILLING_ENABLED="yes"
BILLING_PERIOD="monthly"  # hourly, daily, weekly, monthly
CURRENCY="USD"
PRICE_CPU_HOUR="0.05"      # $ per vCPU hour
PRICE_RAM_GB_HOUR="0.01"   # $ per GB RAM hour
PRICE_DISK_GB_MONTH="0.10" # $ per GB disk month
PRICE_NETWORK_GB="0.01"    # $ per GB transfer
TAX_RATE="0.0"             # Default no tax
BILLING_CONTACT=""
AUTO_INVOICE="yes"
PAYMENT_TERMS="net30"

# Initialize logging
init_logging() {
    mkdir -p "$(dirname "$LOG_FILE")"
    mkdir -p "$BILLING_DIR"
    mkdir -p "$INVOICE_DIR"
}

# Log message
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

# Load configuration
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
    if [ -f "$PRICE_FILE" ]; then
        source "$PRICE_FILE"
    fi
}

# Save configuration
save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" << EOF
# VirtOS Billing Configuration
# Generated by virtos-billing version $VERSION

BILLING_ENABLED="$BILLING_ENABLED"
BILLING_PERIOD="$BILLING_PERIOD"
CURRENCY="$CURRENCY"
TAX_RATE="$TAX_RATE"
BILLING_CONTACT="$BILLING_CONTACT"
AUTO_INVOICE="$AUTO_INVOICE"
PAYMENT_TERMS="$PAYMENT_TERMS"
EOF

    mkdir -p "$(dirname "$PRICE_FILE")"
    cat > "$PRICE_FILE" << EOF
# VirtOS Pricing Configuration
# Generated by virtos-billing version $VERSION

PRICE_CPU_HOUR="$PRICE_CPU_HOUR"
PRICE_RAM_GB_HOUR="$PRICE_RAM_GB_HOUR"
PRICE_DISK_GB_MONTH="$PRICE_DISK_GB_MONTH"
PRICE_NETWORK_GB="$PRICE_NETWORK_GB"
EOF

    log "Configuration saved"
}

# Initialize billing system
billing_init() {
    log "Initializing billing system..."

    # Create database
    local db_file="$BILLING_DIR/billing.db"

    sqlite3 "$db_file" << 'EOF'
CREATE TABLE IF NOT EXISTS resources (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    vm_name TEXT NOT NULL,
    resource_type TEXT NOT NULL,
    amount REAL NOT NULL,
    start_time INTEGER NOT NULL,
    end_time INTEGER,
    cost REAL DEFAULT 0,
    billed INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS invoices (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    invoice_number TEXT UNIQUE NOT NULL,
    customer TEXT,
    period_start INTEGER NOT NULL,
    period_end INTEGER NOT NULL,
    subtotal REAL NOT NULL,
    tax REAL NOT NULL,
    total REAL NOT NULL,
    status TEXT DEFAULT 'pending',
    created_at INTEGER NOT NULL,
    paid_at INTEGER
);

CREATE TABLE IF NOT EXISTS line_items (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    invoice_id INTEGER NOT NULL,
    description TEXT NOT NULL,
    quantity REAL NOT NULL,
    unit_price REAL NOT NULL,
    amount REAL NOT NULL,
    FOREIGN KEY (invoice_id) REFERENCES invoices(id)
);

CREATE INDEX IF NOT EXISTS idx_resources_vm ON resources(vm_name);
CREATE INDEX IF NOT EXISTS idx_resources_billed ON resources(billed);
CREATE INDEX IF NOT EXISTS idx_invoices_status ON invoices(status);
EOF

    if [ $? -eq 0 ]; then
        log "Billing database initialized at $db_file"
    else
        log "ERROR: Failed to initialize billing database"
        return 1
    fi

    save_config
}

# Track resource usage
track_usage() {
    local vm_name="$1"

    if [ -z "$vm_name" ]; then
        log "ERROR: VM name required"
        return 1
    fi

    log "Tracking usage for VM: $vm_name..."

    # Get VM info
    local vm_info=$(virsh dominfo "$vm_name" 2>/dev/null)
    if [ $? -ne 0 ]; then
        log "ERROR: VM not found: $vm_name"
        return 1
    fi

    # Extract resources
    local cpu_count=$(echo "$vm_info" | grep "CPU(s)" | awk '{print $2}')
    local ram_kb=$(echo "$vm_info" | grep "Max memory" | awk '{print $3}')
    local ram_gb=$(echo "scale=2; $ram_kb / 1024 / 1024" | bc)

    # Get disk usage
    local disk_gb=0
    for disk in $(virsh domblklist "$vm_name" | grep -v "^Target" | grep -v "^--" | awk '{print $2}'); do
        if [ -f "$disk" ]; then
            local disk_size=$(du -b "$disk" | awk '{print $1}')
            disk_gb=$(echo "scale=2; $disk_gb + $disk_size / 1024 / 1024 / 1024" | bc)
        fi
    done

    # Get network usage (from /proc/net/dev for VM interfaces)
    local network_gb=0
    # This is simplified - real implementation would track per-VM network usage

    local db_file="$BILLING_DIR/billing.db"
    local now=$(date +%s)

    # Record CPU usage
    sqlite3 "$db_file" "INSERT INTO resources (vm_name, resource_type, amount, start_time) VALUES ('$vm_name', 'cpu', $cpu_count, $now);"

    # Record RAM usage
    sqlite3 "$db_file" "INSERT INTO resources (vm_name, resource_type, amount, start_time) VALUES ('$vm_name', 'ram', $ram_gb, $now);"

    # Record disk usage
    sqlite3 "$db_file" "INSERT INTO resources (vm_name, resource_type, amount, start_time) VALUES ('$vm_name', 'disk', $disk_gb, $now);"

    log "Usage tracked for $vm_name: ${cpu_count}vCPU, ${ram_gb}GB RAM, ${disk_gb}GB disk"
}

# Calculate costs
calculate_costs() {
    local vm_name="${1:-}"
    local start_date="${2:-}"
    local end_date="${3:-}"

    log "Calculating costs..."

    local db_file="$BILLING_DIR/billing.db"
    local where_clause="WHERE billed = 0"

    if [ -n "$vm_name" ]; then
        where_clause="$where_clause AND vm_name = '$vm_name'"
    fi

    if [ -n "$start_date" ]; then
        local start_ts=$(date -d "$start_date" +%s 2>/dev/null || echo "0")
        where_clause="$where_clause AND start_time >= $start_ts"
    fi

    if [ -n "$end_date" ]; then
        local end_ts=$(date -d "$end_date" +%s 2>/dev/null || echo "999999999999")
        where_clause="$where_clause AND start_time <= $end_ts"
    fi

    # Calculate costs for each resource type
    local total_cost=0

    # CPU costs
    local cpu_records=$(sqlite3 "$db_file" "SELECT id, amount, start_time, end_time FROM resources $where_clause AND resource_type = 'cpu';")
    while IFS='|' read -r id amount start_time end_time; do
        local hours=1  # Default to 1 hour if end_time not set
        if [ -n "$end_time" ] && [ "$end_time" != "" ]; then
            hours=$(echo "scale=2; ($end_time - $start_time) / 3600" | bc)
        fi
        local cost=$(echo "scale=4; $amount * $hours * $PRICE_CPU_HOUR" | bc)
        sqlite3 "$db_file" "UPDATE resources SET cost = $cost WHERE id = $id;"
        total_cost=$(echo "scale=2; $total_cost + $cost" | bc)
    done <<< "$cpu_records"

    # RAM costs
    local ram_records=$(sqlite3 "$db_file" "SELECT id, amount, start_time, end_time FROM resources $where_clause AND resource_type = 'ram';")
    while IFS='|' read -r id amount start_time end_time; do
        local hours=1
        if [ -n "$end_time" ] && [ "$end_time" != "" ]; then
            hours=$(echo "scale=2; ($end_time - $start_time) / 3600" | bc)
        fi
        local cost=$(echo "scale=4; $amount * $hours * $PRICE_RAM_GB_HOUR" | bc)
        sqlite3 "$db_file" "UPDATE resources SET cost = $cost WHERE id = $id;"
        total_cost=$(echo "scale=2; $total_cost + $cost" | bc)
    done <<< "$ram_records"

    # Disk costs (monthly)
    local disk_records=$(sqlite3 "$db_file" "SELECT id, amount FROM resources $where_clause AND resource_type = 'disk';")
    while IFS='|' read -r id amount; do
        local cost=$(echo "scale=4; $amount * $PRICE_DISK_GB_MONTH" | bc)
        sqlite3 "$db_file" "UPDATE resources SET cost = $cost WHERE id = $id;"
        total_cost=$(echo "scale=2; $total_cost + $cost" | bc)
    done <<< "$disk_records"

    log "Costs calculated: $CURRENCY $total_cost"
    echo "$total_cost"
}

# Generate invoice
generate_invoice() {
    local customer="${1:-Default Customer}"
    local period_start="${2:-}"
    local period_end="${3:-}"

    if [ -z "$period_start" ] || [ -z "$period_end" ]; then
        log "ERROR: Period start and end dates required"
        return 1
    fi

    log "Generating invoice for period: $period_start to $period_end..."

    local db_file="$BILLING_DIR/billing.db"
    local start_ts=$(date -d "$period_start" +%s)
    local end_ts=$(date -d "$period_end" +%s)
    local now=$(date +%s)

    # Generate invoice number
    local invoice_number="INV-$(date +%Y%m%d)-$(date +%s | tail -c 6)"

    # Calculate subtotal
    local subtotal=$(calculate_costs "" "$period_start" "$period_end")

    # Calculate tax
    local tax=$(echo "scale=2; $subtotal * $TAX_RATE" | bc)

    # Calculate total
    local total=$(echo "scale=2; $subtotal + $tax" | bc)

    # Create invoice record
    sqlite3 "$db_file" "INSERT INTO invoices (invoice_number, customer, period_start, period_end, subtotal, tax, total, created_at) VALUES ('$invoice_number', '$customer', $start_ts, $end_ts, $subtotal, $tax, $total, $now);"

    local invoice_id=$(sqlite3 "$db_file" "SELECT id FROM invoices WHERE invoice_number = '$invoice_number';")

    # Add line items from unbilled resources
    local resources=$(sqlite3 "$db_file" "SELECT vm_name, resource_type, SUM(amount), SUM(cost) FROM resources WHERE billed = 0 AND start_time >= $start_ts AND start_time <= $end_ts GROUP BY vm_name, resource_type;")

    while IFS='|' read -r vm_name resource_type quantity amount; do
        local description="$vm_name - $resource_type"
        local unit_price=$(echo "scale=4; $amount / $quantity" | bc)

        sqlite3 "$db_file" "INSERT INTO line_items (invoice_id, description, quantity, unit_price, amount) VALUES ($invoice_id, '$description', $quantity, $unit_price, $amount);"
    done <<< "$resources"

    # Mark resources as billed
    sqlite3 "$db_file" "UPDATE resources SET billed = 1 WHERE start_time >= $start_ts AND start_time <= $end_ts;"

    # Generate invoice PDF/text file
    local invoice_file="$INVOICE_DIR/$invoice_number.txt"

    cat > "$invoice_file" << EOF
================================================================================
                              INVOICE
================================================================================

Invoice Number: $invoice_number
Date: $(date '+%Y-%m-%d')
Customer: $customer
Billing Period: $period_start to $period_end
Payment Terms: $PAYMENT_TERMS

--------------------------------------------------------------------------------
DESCRIPTION                              QTY      UNIT PRICE      AMOUNT
--------------------------------------------------------------------------------
EOF

    # Add line items
    sqlite3 "$db_file" "SELECT description, quantity, unit_price, amount FROM line_items WHERE invoice_id = $invoice_id;" | \
    while IFS='|' read -r description quantity unit_price amount; do
        printf "%-40s %8.2f %12.4f %12.2f\n" "$description" "$quantity" "$unit_price" "$amount" >> "$invoice_file"
    done

    cat >> "$invoice_file" << EOF

--------------------------------------------------------------------------------
                                                Subtotal:  $CURRENCY $subtotal
                                                     Tax:  $CURRENCY $tax
                                                   Total:  $CURRENCY $total
================================================================================

EOF

    if [ -n "$BILLING_CONTACT" ]; then
        echo "Questions? Contact: $BILLING_CONTACT" >> "$invoice_file"
    fi

    log "Invoice generated: $invoice_file"
    log "Invoice total: $CURRENCY $total"

    echo "$invoice_number"
}

# List invoices
list_invoices() {
    local status="${1:-all}"

    log "Listing invoices (status: $status)..."

    local db_file="$BILLING_DIR/billing.db"
    local where_clause=""

    if [ "$status" != "all" ]; then
        where_clause="WHERE status = '$status'"
    fi

    echo "Invoice Number       Customer            Period                  Total        Status"
    echo "-------------------- ------------------- ----------------------- ------------ -----------"

    sqlite3 "$db_file" "SELECT invoice_number, customer, period_start, period_end, total, status FROM invoices $where_clause ORDER BY created_at DESC;" | \
    while IFS='|' read -r invoice_number customer period_start period_end total status; do
        local period_start_fmt=$(date -d "@$period_start" '+%Y-%m-%d')
        local period_end_fmt=$(date -d "@$period_end" '+%Y-%m-%d')
        printf "%-20s %-19s %s to %s %12.2f %-11s\n" \
            "$invoice_number" "$customer" "$period_start_fmt" "$period_end_fmt" "$total" "$status"
    done
}

# View invoice
view_invoice() {
    local invoice_number="$1"

    if [ -z "$invoice_number" ]; then
        log "ERROR: Invoice number required"
        return 1
    fi

    local invoice_file="$INVOICE_DIR/$invoice_number.txt"

    if [ ! -f "$invoice_file" ]; then
        log "ERROR: Invoice not found: $invoice_number"
        return 1
    fi

    cat "$invoice_file"
}

# Mark invoice as paid
mark_paid() {
    local invoice_number="$1"

    if [ -z "$invoice_number" ]; then
        log "ERROR: Invoice number required"
        return 1
    fi

    log "Marking invoice as paid: $invoice_number..."

    local db_file="$BILLING_DIR/billing.db"
    local now=$(date +%s)

    sqlite3 "$db_file" "UPDATE invoices SET status = 'paid', paid_at = $now WHERE invoice_number = '$invoice_number';"

    if [ $? -eq 0 ]; then
        log "Invoice marked as paid"
    else
        log "ERROR: Failed to update invoice"
        return 1
    fi
}

# Cost report
cost_report() {
    local vm_name="${1:-}"
    local period="${2:-month}"

    log "Generating cost report..."

    local db_file="$BILLING_DIR/billing.db"
    local start_ts=""

    case "$period" in
        day)
            start_ts=$(date -d "1 day ago" +%s)
            ;;
        week)
            start_ts=$(date -d "1 week ago" +%s)
            ;;
        month)
            start_ts=$(date -d "1 month ago" +%s)
            ;;
        year)
            start_ts=$(date -d "1 year ago" +%s)
            ;;
        *)
            log "ERROR: Invalid period: $period (use day/week/month/year)"
            return 1
            ;;
    esac

    echo "=== Cost Report (Last $period) ==="
    echo ""

    local where_clause="WHERE start_time >= $start_ts"
    if [ -n "$vm_name" ]; then
        where_clause="$where_clause AND vm_name = '$vm_name'"
    fi

    echo "By VM:"
    echo "VM Name              CPU Cost    RAM Cost    Disk Cost   Total"
    echo "-------------------- ----------- ----------- ----------- -----------"

    sqlite3 "$db_file" "SELECT vm_name,
        SUM(CASE WHEN resource_type = 'cpu' THEN cost ELSE 0 END),
        SUM(CASE WHEN resource_type = 'ram' THEN cost ELSE 0 END),
        SUM(CASE WHEN resource_type = 'disk' THEN cost ELSE 0 END),
        SUM(cost)
        FROM resources $where_clause GROUP BY vm_name;" | \
    while IFS='|' read -r vm cpu_cost ram_cost disk_cost total; do
        printf "%-20s %11.2f %11.2f %11.2f %11.2f\n" \
            "$vm" "$cpu_cost" "$ram_cost" "$disk_cost" "$total"
    done

    echo ""
    echo "Total: $CURRENCY $(sqlite3 "$db_file" "SELECT SUM(cost) FROM resources $where_clause;")"
}

# Set pricing
set_pricing() {
    local resource="$1"
    local price="$2"

    if [ -z "$resource" ] || [ -z "$price" ]; then
        log "ERROR: Resource and price required"
        return 1
    fi

    case "$resource" in
        cpu)
            PRICE_CPU_HOUR="$price"
            ;;
        ram)
            PRICE_RAM_GB_HOUR="$price"
            ;;
        disk)
            PRICE_DISK_GB_MONTH="$price"
            ;;
        network)
            PRICE_NETWORK_GB="$price"
            ;;
        *)
            log "ERROR: Invalid resource: $resource (use cpu/ram/disk/network)"
            return 1
            ;;
    esac

    save_config
    log "Pricing updated: $resource = $CURRENCY $price"
}

# Show pricing
show_pricing() {
    echo "=== Current Pricing ($CURRENCY) ==="
    echo ""
    echo "CPU:     $PRICE_CPU_HOUR per vCPU hour"
    echo "RAM:     $PRICE_RAM_GB_HOUR per GB hour"
    echo "Disk:    $PRICE_DISK_GB_MONTH per GB month"
    echo "Network: $PRICE_NETWORK_GB per GB transfer"
    echo ""
    echo "Tax Rate: $(echo "scale=2; $TAX_RATE * 100" | bc)%"
}

# Billing wizard
billing_wizard() {
    log "Starting VirtOS Billing Setup Wizard..."

    echo "=== VirtOS Billing Setup Wizard ==="
    echo ""

    # Currency
    echo "1. Currency"
    read -p "   Enter currency code [USD]: " currency
    CURRENCY="${currency:-USD}"

    # Pricing
    echo ""
    echo "2. Pricing"
    read -p "   CPU price per vCPU hour [$PRICE_CPU_HOUR]: " cpu_price
    PRICE_CPU_HOUR="${cpu_price:-$PRICE_CPU_HOUR}"

    read -p "   RAM price per GB hour [$PRICE_RAM_GB_HOUR]: " ram_price
    PRICE_RAM_GB_HOUR="${ram_price:-$PRICE_RAM_GB_HOUR}"

    read -p "   Disk price per GB month [$PRICE_DISK_GB_MONTH]: " disk_price
    PRICE_DISK_GB_MONTH="${disk_price:-$PRICE_DISK_GB_MONTH}"

    read -p "   Network price per GB [$PRICE_NETWORK_GB]: " net_price
    PRICE_NETWORK_GB="${net_price:-$PRICE_NETWORK_GB}"

    # Tax
    echo ""
    echo "3. Tax Configuration"
    read -p "   Tax rate (0.0-1.0) [$TAX_RATE]: " tax_rate
    TAX_RATE="${tax_rate:-$TAX_RATE}"

    # Contact
    echo ""
    echo "4. Billing Contact"
    read -p "   Contact email: " billing_contact
    BILLING_CONTACT="$billing_contact"

    # Payment terms
    echo ""
    echo "5. Payment Terms"
    echo "   1) Net 15"
    echo "   2) Net 30 (default)"
    echo "   3) Net 60"
    echo "   4) Due on receipt"
    read -p "   Selection [2]: " terms_choice

    case "${terms_choice:-2}" in
        1) PAYMENT_TERMS="net15" ;;
        2) PAYMENT_TERMS="net30" ;;
        3) PAYMENT_TERMS="net60" ;;
        4) PAYMENT_TERMS="due_on_receipt" ;;
    esac

    # Initialize
    echo ""
    log "Initializing billing system..."
    billing_init

    save_config

    echo ""
    log "Billing wizard completed!"
    echo ""
    echo "Next steps:"
    echo "  - Review pricing: virtos-billing show-pricing"
    echo "  - Track VM usage: virtos-billing track-usage <vm-name>"
    echo "  - Generate report: virtos-billing cost-report"
}

# Show usage
usage() {
    cat << EOF
VirtOS Billing and Cost Management - Version $VERSION

Usage: $SCRIPT_NAME <command> [options]

Commands:
  init                                   Initialize billing system
  wizard                                 Run interactive setup wizard

  track-usage <vm-name>                  Track resource usage for VM
  calculate-costs [vm] [start] [end]    Calculate costs
  cost-report [vm] [period]              Generate cost report (day/week/month/year)

  generate-invoice <customer> <start> <end>  Generate invoice
  list-invoices [status]                 List invoices (all/pending/paid)
  view-invoice <invoice-number>          View invoice
  mark-paid <invoice-number>             Mark invoice as paid

  set-pricing <resource> <price>         Set pricing (cpu/ram/disk/network)
  show-pricing                           Show current pricing

  version                                Show version
  help                                   Show this help

Examples:
  # Setup wizard (recommended for first-time setup)
  $SCRIPT_NAME wizard

  # Track VM usage
  $SCRIPT_NAME track-usage web-server

  # Generate cost report
  $SCRIPT_NAME cost-report web-server month

  # Generate invoice
  $SCRIPT_NAME generate-invoice "Acme Corp" "2026-05-01" "2026-05-31"

  # List unpaid invoices
  $SCRIPT_NAME list-invoices pending

  # Mark invoice as paid
  $SCRIPT_NAME mark-paid INV-20260531-123456

  # Update pricing
  $SCRIPT_NAME set-pricing cpu 0.10
  $SCRIPT_NAME show-pricing

EOF
}

# Main
main() {
    # Handle help/version first (before init to avoid permission issues in tests)
    case "${1:-}" in
        version|--version|-v)
            echo "$SCRIPT_NAME version $VERSION"
            exit 0
            ;;
        help|--help|-h|"")
            usage
            exit 0
            ;;
    esac

    # Now init for actual commands
    init_logging
    load_config

    # Install sqlite3 if needed
    if ! command -v sqlite3 &> /dev/null; then
        log "Installing sqlite3..."
        tce-load -wi sqlite3
    fi

    case "${1}" in
        init)
            billing_init
            ;;
        wizard)
            billing_wizard
            ;;
        track-usage)
            track_usage "$2"
            ;;
        calculate-costs)
            calculate_costs "$2" "$3" "$4"
            ;;
        cost-report)
            cost_report "$2" "$3"
            ;;
        generate-invoice)
            generate_invoice "$2" "$3" "$4"
            ;;
        list-invoices)
            list_invoices "$2"
            ;;
        view-invoice)
            view_invoice "$2"
            ;;
        mark-paid)
            mark_paid "$2"
            ;;
        set-pricing)
            set_pricing "$2" "$3"
            ;;
        show-pricing)
            show_pricing
            ;;        *)
            echo "Unknown command: $1"
            echo "Run '$SCRIPT_NAME help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
