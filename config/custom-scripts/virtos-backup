set -e
# VirtOS Backup - Automated VM backup and restore
# Supports scheduling, retention, compression, and remote destinations

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.21")

# Handle --help and --version early (before any filesystem operations)
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "help" ] || [ "${1:-}" = "" ]; then
    # Skip mkdir - will show usage at end
    SKIP_INIT=yes
elif [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ] || [ "${1:-}" = "version" ]; then
    echo "virtos-backup version $VERSION"
    exit 0
fi


# Configuration
BACKUP_DIR="${BACKUP_DIR:-/var/lib/virtos/backups}"
RETENTION_DAYS="${RETENTION_DAYS:-7}"
COMPRESSION="${COMPRESSION:-yes}"
REMOTE_DEST="${REMOTE_DEST:-}"  # Optional: user@host:/path or s3://bucket/path

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

usage() {
    cat << EOF
VirtOS Backup v${VERSION}

Usage: virtos-backup [command] [options]

Commands:
  backup <vm-name>         Backup a VM
  restore <vm-name> <date> Restore a VM from backup
  list [vm-name]           List available backups
  schedule <vm-name>       Schedule automated backups
  cleanup                  Remove old backups per retention policy
  verify <backup-path>     Verify backup integrity

Backup Options:
  --full                   Full backup (default)
  --incremental            Incremental backup
  --compress               Compress backup (default)
  --no-compress            Don't compress
  --destination <path>     Backup destination (default: $BACKUP_DIR)
  --remote <dest>          Remote destination (scp or s3)
  --exclude-disk <disk>    Exclude specific disk

Restore Options:
  --target <name>          Restore with different name
  --disk-only              Restore disks only (not XML)
  --verify                 Verify before restore

Schedule Options:
  --daily <time>           Daily backup at time (HH:MM)
  --weekly <day> <time>    Weekly backup (mon-sun HH:MM)
  --retention <days>       Keep backups for N days (default: 7)

Examples:
  # Backup a VM
  virtos-backup backup web-server-1

  # Backup with compression to remote
  virtos-backup backup db-server --remote user@backup:/backups

  # Schedule daily backup at 2 AM
  virtos-backup schedule web-server-1 --daily 02:00

  # Restore from specific date
  virtos-backup restore web-server-1 2026-05-22

  # List all backups
  virtos-backup list

  # Cleanup old backups
  virtos-backup cleanup

EOF
}

log() {
    echo -e "${BLUE}[$(date +'%Y-%m-%d %H:%M:%S')]${NC} $*"
}

error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
}

success() {
    echo -e "${GREEN}[SUCCESS]${NC} $*"
}

warn() {
    echo -e "${YELLOW}[WARNING]${NC} $*"
}

# Ensure backup directory exists (skip for --help/--version)
if [ "${SKIP_INIT:-no}" != "yes" ]; then
    mkdir -p "$BACKUP_DIR" || true
fi

#==============================================================================
# Backup Functions
#==============================================================================

backup_vm() {
    local vm_name="$1"
    local backup_type="${2:-full}"
    local timestamp=$(date +%Y%m%d-%H%M%S)
    local backup_path="$BACKUP_DIR/$vm_name/$timestamp"

    # SECURITY: Validate VM name before using in commands
    if ! validate_vm_name "$vm_name" 2>/dev/null; then
        error "Invalid VM name '$vm_name'"
        return 1
    fi

    log "Starting backup of VM: $vm_name"

    # Check if VM exists
    if ! virsh list --all | grep -q " $vm_name "; then
        error "VM '$vm_name' not found" >&2
        echo "" >&2
        echo "Available VMs:" >&2
        virsh list --all --name 2>/dev/null | grep -v '^$' | sed 's/^/  • /' >&2 || echo "  (none)" >&2
        echo "" >&2
        echo "To backup a VM, specify an existing VM name:" >&2
        echo "  virtos-backup backup <vm-name>" >&2
        return 1
    fi

    # Create backup directory
    mkdir -p "$backup_path" || true

    # Save VM state
    local vm_state=$(virsh domstate "$vm_name")
    echo "$vm_state" > "$backup_path/vm-state.txt"
    log "VM state: $vm_state"

    # Backup VM XML definition
    log "Backing up VM configuration..."
    virsh dumpxml "$vm_name" > "$backup_path/$vm_name.xml"

    # Get disk list
    local disks=$(virsh domblklist "$vm_name" --details | grep disk | awk '{print $4}')

    if [ -z "$disks" ]; then
        error "No disks found for VM '$vm_name'" >&2
        echo "" >&2
        echo "The VM has no attached disk devices to backup." >&2
        echo "" >&2
        echo "This could indicate:" >&2
        echo "  • VM configuration error (no disks defined)" >&2
        echo "  • Disk devices are not accessible" >&2
        echo "" >&2
        echo "Check VM configuration:" >&2
        echo "  virsh domblklist $vm_name --details" >&2
        echo "  virsh dumpxml $vm_name | grep -A5 disk" >&2
        return 1
    fi

    # Backup each disk
    local disk_num=0
    for disk in $disks; do
        if [ ! -f "$disk" ]; then
            warn "Disk not found: $disk (skipping)"
            continue
        fi

        disk_num=$((disk_num + 1))
        local disk_name=$(basename "$disk")
        local backup_disk="$backup_path/disk-$disk_num-$disk_name"

        log "Backing up disk $disk_num: $disk"

        # Check if VM is running
        if [ "$vm_state" = "running" ]; then
            # Create snapshot for consistent backup
            log "Creating temporary snapshot for consistent backup..."
            virsh snapshot-create-as "$vm_name" backup-snapshot-$timestamp \
                "Temporary snapshot for backup" --disk-only --atomic 2>/dev/null

            if [ $? -eq 0 ]; then
                # Copy the backing file (original disk)
                if [ "$COMPRESSION" = "yes" ]; then
                    log "Compressing disk image..."
                    qemu-img convert -c -O qcow2 "$disk" "$backup_disk.qcow2"
                else
                    cp "$disk" "$backup_disk"
                fi

                # Delete snapshot (merges changes back)
                virsh snapshot-delete "$vm_name" backup-snapshot-$timestamp --metadata
            else
                warn "Snapshot failed, backing up live disk (may be inconsistent)"
                if [ "$COMPRESSION" = "yes" ]; then
                    qemu-img convert -c -O qcow2 "$disk" "$backup_disk.qcow2"
                else
                    cp "$disk" "$backup_disk"
                fi
            fi
        else
            # VM is not running, safe to backup directly
            if [ "$COMPRESSION" = "yes" ]; then
                log "Compressing disk image..."
                qemu-img convert -c -O qcow2 "$disk" "$backup_disk.qcow2"
            else
                cp "$disk" "$backup_disk"
            fi
        fi

        if [ $? -eq 0 ]; then
            success "Disk $disk_num backed up successfully"

            # Save disk info
            echo "$disk" >> "$backup_path/disk-mapping.txt"
            qemu-img info "$disk" > "$backup_path/disk-$disk_num-info.txt"
        else
            error "Failed to backup disk $disk_num"
            return 1
        fi
    done

    # Create backup manifest
    cat > "$backup_path/manifest.txt" <<EOF
Backup Manifest
===============
VM Name: $vm_name
Backup Type: $backup_type
Timestamp: $timestamp
Date: $(date)
VM State: $vm_state
Disks: $disk_num
Compression: $COMPRESSION
VirtOS Version: $(cat /etc/virtos/version.txt 2>/dev/null || echo "unknown")
EOF

    # Create checksums
    log "Creating checksums..."
    (cd "$backup_path" && sha256sum * > checksums.sha256)

    # Compress entire backup if requested
    if [ "$COMPRESSION" = "yes" ]; then
        log "Creating backup archive..."
        tar -czf "$backup_path.tar.gz" -C "$BACKUP_DIR/$vm_name" "$timestamp"
        rm -rf "$backup_path"
        backup_path="$backup_path.tar.gz"
    fi

    # Copy to remote if specified
    if [ -n "$REMOTE_DEST" ]; then
        log "Copying to remote destination: $REMOTE_DEST"

        if [[ "$REMOTE_DEST" == s3://* ]]; then
            # S3 destination (requires aws CLI)
            if ! command -v aws >/dev/null 2>&1; then
                error "AWS CLI not installed (required for S3 destinations)" >&2
                echo "" >&2
                echo "To install AWS CLI:" >&2
                echo "  tce-load -wi awscli" >&2
                echo "" >&2
                echo "Or use SCP destination instead:" >&2
                echo "  virtos-backup backup $vm_name --remote user@host:/backup/path" >&2
                return 1
            fi
            aws s3 cp "$backup_path" "$REMOTE_DEST/$vm_name/" || {
                error "Failed to copy backup to S3: $REMOTE_DEST" >&2
                echo "" >&2
                echo "Possible causes:" >&2
                echo "  • Invalid AWS credentials (check: aws configure)" >&2
                echo "  • Bucket doesn't exist or lacks write permissions" >&2
                echo "  • Network connectivity issues" >&2
                echo "" >&2
                echo "Local backup saved at: $backup_path" >&2
                return 1
            }
        else
            # SCP destination
            scp -r "$backup_path" "$REMOTE_DEST/$vm_name/" || {
                error "Failed to copy backup to remote: $REMOTE_DEST" >&2
                echo "" >&2
                echo "Possible causes:" >&2
                echo "  • SSH authentication failed (check: ssh-copy-id)" >&2
                echo "  • Remote path doesn't exist or lacks write permissions" >&2
                echo "  • Network connectivity issues" >&2
                echo "" >&2
                echo "Local backup saved at: $backup_path" >&2
                echo "" >&2
                echo "Retry after fixing remote access:" >&2
                echo "  scp -r $backup_path $REMOTE_DEST/$vm_name/" >&2
                return 1
            }
        fi
        success "Backup copied to remote successfully"
    fi

    success "Backup completed: $backup_path"

    # Show backup size
    if [ -f "$backup_path" ]; then
        local size=$(du -h "$backup_path" | cut -f1)
        log "Backup size: $size"
    else
        local size=$(du -sh "$backup_path" | cut -f1)
        log "Backup size: $size"
    fi

    return 0
}

#==============================================================================
# Restore Functions
#==============================================================================

restore_vm() {
    local vm_name="$1"
    local backup_date="$2"
    local target_name="${3:-$vm_name}"

    # SECURITY: Validate VM names before using in commands
    if ! validate_vm_name "$vm_name" 2>/dev/null; then
        error "Invalid VM name '$vm_name'"
        return 1
    fi
    if ! validate_vm_name "$target_name" 2>/dev/null; then
        error "Invalid target VM name '$target_name'"
        return 1
    fi

    log "Starting restore of VM: $vm_name from backup: $backup_date"

    # Find backup
    local backup_path=""

    # Check for compressed backup
    if [ -f "$BACKUP_DIR/$vm_name/$backup_date.tar.gz" ]; then
        backup_path="$BACKUP_DIR/$vm_name/$backup_date.tar.gz"
        log "Found compressed backup: $backup_path"

        # Extract
        log "Extracting backup..."
        local temp_dir=$(mktemp -d)
        tar -xzf "$backup_path" -C "$temp_dir"
        backup_path="$temp_dir/$backup_date"
    elif [ -d "$BACKUP_DIR/$vm_name/$backup_date" ]; then
        backup_path="$BACKUP_DIR/$vm_name/$backup_date"
    else
        error "Backup not found: $vm_name / $backup_date"
        return 1
    fi

    # Verify checksums
    log "Verifying backup integrity..."
    if [ -f "$backup_path/checksums.sha256" ]; then
        (cd "$backup_path" && sha256sum -c checksums.sha256 --quiet)
        if [ $? -eq 0 ]; then
            success "Backup integrity verified"
        else
            error "Backup integrity check failed!"
            return 1
        fi
    else
        warn "No checksums found, skipping verification"
    fi

    # Read manifest
    if [ -f "$backup_path/manifest.txt" ]; then
        log "Backup information:"
        grep -E "^(VM Name|Timestamp|VM State|Disks):" "$backup_path/manifest.txt"
    fi

    # Check if target VM already exists
    if virsh list --all | grep -q " $target_name "; then
        error "VM '$target_name' already exists. Please remove it first or use --target to restore with different name"
        return 1
    fi

    # Restore VM definition
    log "Restoring VM definition..."
    local vm_xml="$backup_path/$vm_name.xml"

    if [ ! -f "$vm_xml" ]; then
        error "VM XML not found in backup"
        return 1
    fi

    # If target name is different, update XML
    if [ "$target_name" != "$vm_name" ]; then
        log "Updating VM name to: $target_name"
        sed "s|<name>$vm_name</name>|<name>$target_name</name>|" "$vm_xml" > /tmp/restore-vm.xml
        # Generate new UUID
        local new_uuid=$(uuidgen)
        sed -i "s|<uuid>.*</uuid>|<uuid>$new_uuid</uuid>|" /tmp/restore-vm.xml
        vm_xml="/tmp/restore-vm.xml"
    fi

    # Restore disks
    local disk_num=0
    for disk_backup in "$backup_path"/disk-*.qcow2 "$backup_path"/disk-*.img "$backup_path"/disk-*.raw; do
        if [ ! -f "$disk_backup" ]; then
            continue
        fi

        disk_num=$((disk_num + 1))

        # Determine restore location
        local restore_disk="/var/lib/vms/$target_name-disk-$disk_num.qcow2"
        mkdir -p "$(dirname "$restore_disk")" || true

        log "Restoring disk $disk_num to: $restore_disk"

        # Copy disk
        qemu-img convert -O qcow2 "$disk_backup" "$restore_disk"

        if [ $? -eq 0 ]; then
            success "Disk $disk_num restored successfully"

            # Update XML with new disk path
            # This is simplified - in production would need proper XML parsing
            sed -i "s|source file='[^']*disk-${disk_num}[^']*'|source file='$restore_disk'|" "$vm_xml"
        else
            error "Failed to restore disk $disk_num"
            return 1
        fi
    done

    # Define VM
    log "Defining VM in libvirt..."
    virsh define "$vm_xml"

    if [ $? -eq 0 ]; then
        success "VM '$target_name' restored successfully"

        # Cleanup temp files
        if [ -n "$temp_dir" ] && [ -d "$temp_dir" ]; then
            rm -rf "$temp_dir"
        fi

        log "VM restored. Start with: virsh start $target_name"
        return 0
    else
        error "Failed to define VM"
        return 1
    fi
}

#==============================================================================
# List Backups
#==============================================================================

list_backups() {
    local vm_name="$1"

    if [ -n "$vm_name" ]; then
        log "Backups for VM: $vm_name"
        local vm_backup_dir="$BACKUP_DIR/$vm_name"

        if [ ! -d "$vm_backup_dir" ]; then
            echo "No backups found for VM: $vm_name"
            return 0
        fi

        echo ""
        printf "%-20s %-15s %-10s\n" "BACKUP DATE" "SIZE" "TYPE"
        echo "------------------------------------------------------------"

        for backup in "$vm_backup_dir"/*; do
            if [ ! -e "$backup" ]; then
                continue
            fi

            local backup_name=$(basename "$backup")
            local backup_date="${backup_name%.tar.gz}"
            local size=$(du -sh "$backup" | cut -f1)
            local type="full"

            if [[ "$backup" == *.tar.gz ]]; then
                type="compressed"
            fi

            printf "%-20s %-15s %-10s\n" "$backup_date" "$size" "$type"
        done
    else
        log "All VM backups:"
        echo ""

        for vm_dir in "$BACKUP_DIR"/*; do
            if [ ! -d "$vm_dir" ]; then
                continue
            fi

            local vm=$(basename "$vm_dir")
            local count=$(find "$vm_dir" -maxdepth 1 -type f -o -type d | wc -l)
            count=$((count - 1))  # Subtract parent dir

            echo "VM: $vm ($count backups)"

            for backup in "$vm_dir"/*; do
                if [ ! -e "$backup" ]; then
                    continue
                fi

                local backup_name=$(basename "$backup")
                local backup_date="${backup_name%.tar.gz}"
                local size=$(du -sh "$backup" | cut -f1)

                echo "  - $backup_date ($size)"
            done
            echo ""
        done
    fi
}

#==============================================================================
# Schedule Backups
#==============================================================================

schedule_backup() {
    local vm_name="$1"
    local schedule_type="$2"  # daily or weekly
    local schedule_time="$3"
    local schedule_day="$4"   # for weekly

    log "Scheduling backup for VM: $vm_name"

    # Create cron job
    local cron_file="/etc/cron.d/virtos-backup-$vm_name"

    if [ "$schedule_type" = "daily" ]; then
        local hour=$(echo "$schedule_time" | cut -d: -f1)
        local minute=$(echo "$schedule_time" | cut -d: -f2)

        cat > "$cron_file" <<EOF
# VirtOS automated backup for $vm_name
# Runs daily at $schedule_time
$minute $hour * * * root /usr/local/bin/virtos-backup backup $vm_name
EOF
        success "Daily backup scheduled at $schedule_time"
    elif [ "$schedule_type" = "weekly" ]; then
        local hour=$(echo "$schedule_time" | cut -d: -f1)
        local minute=$(echo "$schedule_time" | cut -d: -f2)

        # Convert day name to number (0=Sunday)
        case "$schedule_day" in
            sun*) day_num=0 ;;
            mon*) day_num=1 ;;
            tue*) day_num=2 ;;
            wed*) day_num=3 ;;
            thu*) day_num=4 ;;
            fri*) day_num=5 ;;
            sat*) day_num=6 ;;
            *) error "Invalid day: $schedule_day"; return 1 ;;
        esac

        cat > "$cron_file" <<EOF
# VirtOS automated backup for $vm_name
# Runs weekly on $schedule_day at $schedule_time
$minute $hour * * $day_num root /usr/local/bin/virtos-backup backup $vm_name
EOF
        success "Weekly backup scheduled for $schedule_day at $schedule_time"
    fi

    log "Cron job created: $cron_file"

    # Also schedule cleanup
    local cleanup_cron="/etc/cron.d/virtos-backup-cleanup"
    if [ ! -f "$cleanup_cron" ]; then
        cat > "$cleanup_cron" <<EOF
# VirtOS backup cleanup - runs daily at 3 AM
0 3 * * * root /usr/local/bin/virtos-backup cleanup
EOF
        log "Cleanup cron job created: $cleanup_cron"
    fi
}

#==============================================================================
# Cleanup Old Backups
#==============================================================================

cleanup_backups() {
    log "Cleaning up backups older than $RETENTION_DAYS days..."

    local removed=0

    for vm_dir in "$BACKUP_DIR"/*; do
        if [ ! -d "$vm_dir" ]; then
            continue
        fi

        local vm=$(basename "$vm_dir")

        for backup in "$vm_dir"/*; do
            if [ ! -e "$backup" ]; then
                continue
            fi

            # Check age
            local age_days=$(( ($(date +%s) - $(stat -c %Y "$backup")) / 86400 ))

            if [ $age_days -gt $RETENTION_DAYS ]; then
                log "Removing old backup: $vm / $(basename "$backup") (${age_days} days old)"
                rm -rf "$backup"
                removed=$((removed + 1))
            fi
        done
    done

    if [ $removed -gt 0 ]; then
        success "Removed $removed old backups"
    else
        log "No old backups to remove"
    fi
}

#==============================================================================
# Main Command Handler
#==============================================================================

COMMAND="${1:-}"
[ -n "$COMMAND" ] && shift

case "$COMMAND" in
    backup)
        VM_NAME="$1"
        if [ -z "$VM_NAME" ]; then
            error "VM name required"
            usage
            exit 1
        fi
        backup_vm "$VM_NAME"
        ;;

    restore)
        VM_NAME="$1"
        BACKUP_DATE="$2"
        if [ -z "$VM_NAME" ] || [ -z "$BACKUP_DATE" ]; then
            error "VM name and backup date required"
            usage
            exit 1
        fi
        restore_vm "$VM_NAME" "$BACKUP_DATE"
        ;;

    list)
        list_backups "$1"
        ;;

    schedule)
        VM_NAME="$1"
        shift

        # Parse schedule options
        while [ $# -gt 0 ]; do
            case "$1" in
                --daily)
                    SCHEDULE_TYPE="daily"
                    SCHEDULE_TIME="$2"
                    shift 2
                    ;;
                --weekly)
                    SCHEDULE_TYPE="weekly"
                    SCHEDULE_DAY="$2"
                    SCHEDULE_TIME="$3"
                    shift 3
                    ;;
                --retention)
                    RETENTION_DAYS="$2"
                    shift 2
                    ;;
                *)
                    shift
                    ;;
            esac
        done

        if [ -z "$SCHEDULE_TYPE" ]; then
            error "Schedule type required (--daily or --weekly)"
            usage
            exit 1
        fi

        schedule_backup "$VM_NAME" "$SCHEDULE_TYPE" "$SCHEDULE_TIME" "$SCHEDULE_DAY"
        ;;

    cleanup)
        cleanup_backups
        ;;

    verify)
        BACKUP_PATH="$1"
        if [ -z "$BACKUP_PATH" ]; then
            error "Backup path required"
            exit 1
        fi
        log "Verifying backup: $BACKUP_PATH"
        if [ -f "$BACKUP_PATH/checksums.sha256" ]; then
            (cd "$(dirname "$BACKUP_PATH")/$(basename "$BACKUP_PATH")" && sha256sum -c checksums.sha256)
        else
            error "No checksums found"
            exit 1
        fi
        ;;

    --version|-v|version)
        echo "virtos-backup version $VERSION"
        exit 0
        ;;

    --help|-h|help|"")
        usage
        exit 0
        ;;

    *)
        error "Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac

exit $?
