set -e
# virtos-edge - Edge computing optimizations for VirtOS
# Part of Phase 11: Multi-Datacenter and Advanced Features

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.27")
SCRIPT_NAME="virtos-edge"
LOG_FILE="/var/log/virtos-edge.log"
CONFIG_FILE="/etc/virtos/edge.conf"
EDGE_DIR="/var/lib/virtos/edge"
SYNC_DIR="/var/lib/virtos/edge-sync"

# Edge configuration defaults
EDGE_MODE="disabled"  # disabled, edge-node, cloud-hub
CLOUD_HUB=""
EDGE_LOCATION=""
BANDWIDTH_LIMIT="100"  # Mbps
OFFLINE_CAPABLE="yes"
SYNC_ENABLED="yes"
SYNC_STRATEGY="incremental"  # incremental, full
LATENCY_THRESHOLD="50"  # ms
CACHE_ENABLED="yes"
CACHE_SIZE="10G"

# Initialize logging
init_logging() {
    mkdir -p "$(dirname "$LOG_FILE")"
    mkdir -p "$EDGE_DIR"
    mkdir -p "$SYNC_DIR"
}

# Log message
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

# Load configuration
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
}

# Save configuration
save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" << EOF
# VirtOS Edge Configuration
# Generated by virtos-edge version $VERSION

EDGE_MODE="$EDGE_MODE"
CLOUD_HUB="$CLOUD_HUB"
EDGE_LOCATION="$EDGE_LOCATION"
BANDWIDTH_LIMIT="$BANDWIDTH_LIMIT"
OFFLINE_CAPABLE="$OFFLINE_CAPABLE"
SYNC_ENABLED="$SYNC_ENABLED"
SYNC_STRATEGY="$SYNC_STRATEGY"
LATENCY_THRESHOLD="$LATENCY_THRESHOLD"
CACHE_ENABLED="$CACHE_ENABLED"
CACHE_SIZE="$CACHE_SIZE"
EOF
    log "Configuration saved to $CONFIG_FILE"
}

# Initialize edge node
edge_init() {
    local mode="${1:-edge-node}"
    local location="${2:-edge1}"

    log "Initializing edge node: $location (mode: $mode)..."

    EDGE_MODE="$mode"
    EDGE_LOCATION="$location"

    # Create edge node metadata
    local edge_file="$EDGE_DIR/edge-node.json"

    cat > "$edge_file" << EOF
{
  "location": "$location",
  "mode": "$mode",
  "hostname": "$(hostname)",
  "ip": "$(hostname -I | awk '{print $1}')",
  "initialized_at": "$(date -Iseconds)",
  "status": "active",
  "offline_capable": "$OFFLINE_CAPABLE"
}
EOF

    # Setup edge cache
    if [ "$CACHE_ENABLED" = "yes" ]; then
        mkdir -p "$EDGE_DIR/cache"
        log "Edge cache initialized: $EDGE_DIR/cache"
    fi

    save_config

    log "Edge node initialized: $location"
}

# Register edge node with cloud hub
edge_register() {
    local hub_host="$1"

    if [ -z "$hub_host" ]; then
        log "ERROR: Cloud hub host required"
        return 1
    fi

    log "Registering edge node with cloud hub: $hub_host..."

    CLOUD_HUB="$hub_host"
    save_config

    # Test connectivity to hub
    if ping -c 1 -W 2 "$hub_host" &>/dev/null; then
        log "Cloud hub reachable: $hub_host"
    else
        log "WARNING: Cloud hub not reachable (will retry periodically)"
    fi

    # Setup SSH trust if possible
    if command -v ssh &>/dev/null; then
        log "Consider setting up SSH key trust: ssh-copy-id vmadmin@$hub_host"
    fi

    log "Edge node registered with hub: $hub_host"
}

# Deploy workload to edge
edge_deploy() {
    local workload="$1"
    local source="${2:-cloud}"

    if [ -z "$workload" ]; then
        log "ERROR: Workload name required"
        return 1
    fi

    log "Deploying workload to edge: $workload (source: $source)..."

    # Create workload directory
    local workload_dir="$EDGE_DIR/workloads/$workload"
    mkdir -p "$workload_dir"

    if [ "$source" = "cloud" ] && [ -n "$CLOUD_HUB" ]; then
        # Pull from cloud hub
        log "Pulling workload from cloud hub: $CLOUD_HUB..."

        if command -v rsync &>/dev/null; then
            rsync -avz --bwlimit="$BANDWIDTH_LIMIT" \
                "vmadmin@$CLOUD_HUB:/var/lib/virtos/workloads/$workload/" \
                "$workload_dir/" 2>&1 | tee -a "$LOG_FILE"
        else
            log "ERROR: rsync not available"
            return 1
        fi
    else
        log "Workload directory created: $workload_dir"
        log "Deploy workload files manually to: $workload_dir"
    fi

    log "Workload deployed: $workload"
}

# Workload placement decision
workload_place() {
    local workload="$1"
    local latency_req="${2:-100}"  # ms

    if [ -z "$workload" ]; then
        log "ERROR: Workload name required"
        return 1
    fi

    log "Determining optimal placement for workload: $workload..."

    # Measure latency to cloud hub
    local cloud_latency=999999
    if [ -n "$CLOUD_HUB" ]; then
        if command -v ping &>/dev/null; then
            cloud_latency=$(ping -c 3 "$CLOUD_HUB" 2>/dev/null | tail -1 | awk -F'/' '{print $5}' | cut -d. -f1)
            cloud_latency=${cloud_latency:-999999}
        fi
    fi

    log "Cloud hub latency: ${cloud_latency}ms"
    log "Latency requirement: ${latency_req}ms"

    # Placement decision
    if [ "$cloud_latency" -lt "$latency_req" ]; then
        log "Recommendation: CLOUD (latency acceptable)"
        echo "cloud"
    else
        log "Recommendation: EDGE (latency too high for cloud)"
        echo "edge"
    fi
}

# Sync to cloud
sync_to_cloud() {
    local path="${1:-.}"
    local strategy="${2:-$SYNC_STRATEGY}"

    if [ -z "$CLOUD_HUB" ]; then
        log "ERROR: Cloud hub not configured"
        return 1
    fi

    log "Syncing to cloud hub: $CLOUD_HUB (strategy: $strategy)..."

    if ! command -v rsync &>/dev/null; then
        log "ERROR: rsync not available"
        return 1
    fi

    local rsync_opts="-avz --bwlimit=$BANDWIDTH_LIMIT"

    if [ "$strategy" = "incremental" ]; then
        rsync_opts="$rsync_opts --update"
    fi

    rsync $rsync_opts "$path" "vmadmin@$CLOUD_HUB:/var/lib/virtos/edge-data/$EDGE_LOCATION/" \
        2>&1 | tee -a "$LOG_FILE"

    if [ $? -eq 0 ]; then
        log "Sync to cloud completed successfully"
    else
        log "ERROR: Sync to cloud failed"
        return 1
    fi
}

# Sync from cloud
sync_from_cloud() {
    local path="${1:-.}"
    local strategy="${2:-$SYNC_STRATEGY}"

    if [ -z "$CLOUD_HUB" ]; then
        log "ERROR: Cloud hub not configured"
        return 1
    fi

    log "Syncing from cloud hub: $CLOUD_HUB (strategy: $strategy)..."

    if ! command -v rsync &>/dev/null; then
        log "ERROR: rsync not available"
        return 1
    fi

    local rsync_opts="-avz --bwlimit=$BANDWIDTH_LIMIT"

    if [ "$strategy" = "incremental" ]; then
        rsync_opts="$rsync_opts --update"
    fi

    rsync $rsync_opts "vmadmin@$CLOUD_HUB:/var/lib/virtos/cloud-data/" "$path" \
        2>&1 | tee -a "$LOG_FILE"

    if [ $? -eq 0 ]; then
        log "Sync from cloud completed successfully"
    else
        log "ERROR: Sync from cloud failed"
        return 1
    fi
}

# Auto-sync daemon
sync_start() {
    local interval="${1:-300}"  # 5 minutes default

    log "Starting auto-sync daemon (interval: ${interval}s)..."

    # Create sync script
    local sync_script="/usr/local/bin/virtos-edge-sync.sh"

    cat > "$sync_script" << 'SYNCEOF'
#!/bin/bash
# Auto-generated edge sync daemon

source /etc/virtos/edge.conf

while true; do
    echo "[$(date)] Starting sync cycle..."

    # Sync to cloud
    if [ "$SYNC_ENABLED" = "yes" ] && [ -n "$CLOUD_HUB" ]; then
        /usr/local/bin/virtos-edge sync-to-cloud /var/lib/virtos/edge-data/
    fi

    echo "[$(date)] Sync cycle completed. Waiting SYNC_INTERVAL seconds..."
    sleep SYNC_INTERVAL
done
SYNCEOF

    sed -i "s/SYNC_INTERVAL/$interval/" "$sync_script"
    chmod +x "$sync_script"

    # Start sync daemon
    nohup "$sync_script" &>/dev/null &
    local pid=$!
    echo "$pid" > "$EDGE_DIR/sync.pid"

    log "Auto-sync daemon started (PID: $pid)"
}

# Stop auto-sync
sync_stop() {
    log "Stopping auto-sync daemon..."

    local pid_file="$EDGE_DIR/sync.pid"

    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid"
            log "Auto-sync stopped (PID: $pid)"
        else
            log "Sync daemon not running"
        fi
        rm -f "$pid_file"
    else
        log "No active sync daemon found"
    fi
}

# Sync status
sync_status() {
    log "Auto-sync status..."

    local pid_file="$EDGE_DIR/sync.pid"
    local status="stopped"
    local pid="-"

    if [ -f "$pid_file" ]; then
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            status="running"
        else
            status="stopped"
            pid="-"
        fi
    fi

    echo "Status: $status"
    echo "PID: $pid"
    echo "Cloud hub: $CLOUD_HUB"
    echo "Bandwidth limit: ${BANDWIDTH_LIMIT}Mbps"
    echo "Strategy: $SYNC_STRATEGY"
}

# Offline mode
offline_enable() {
    log "Enabling offline mode..."

    # Create offline marker
    touch "$EDGE_DIR/offline-mode"

    # Stop sync
    sync_stop

    log "Offline mode enabled"
    log "System will operate independently of cloud hub"
}

# Online mode
offline_disable() {
    log "Disabling offline mode..."

    # Remove offline marker
    rm -f "$EDGE_DIR/offline-mode"

    # Resume sync if configured
    if [ "$SYNC_ENABLED" = "yes" ]; then
        sync_start
    fi

    log "Offline mode disabled"
    log "System will resume cloud synchronization"
}

# Offline status
offline_status() {
    if [ -f "$EDGE_DIR/offline-mode" ]; then
        echo "Offline mode: ENABLED"
        echo "Operating independently"
    else
        echo "Offline mode: DISABLED"
        echo "Connected to cloud hub"
    fi
}

# Bandwidth optimization
bandwidth_optimize() {
    local limit="${1:-$BANDWIDTH_LIMIT}"

    log "Optimizing bandwidth usage (limit: ${limit}Mbps)..."

    BANDWIDTH_LIMIT="$limit"
    save_config

    # Apply traffic shaping if tc is available
    if command -v tc &>/dev/null; then
        local interface=$(ip route | grep default | awk '{print $5}' | head -1)
        if [ -n "$interface" ]; then
            # Clear existing rules
            tc qdisc del dev "$interface" root 2>/dev/null

            # Add rate limiting
            tc qdisc add dev "$interface" root tbf rate "${limit}mbit" burst 32kbit latency 400ms

            log "Traffic shaping applied on $interface"
        fi
    fi

    log "Bandwidth limit set to ${limit}Mbps"
}

# Latency test
latency_test() {
    local target="${1:-$CLOUD_HUB}"

    if [ -z "$target" ]; then
        log "ERROR: Target host required"
        return 1
    fi

    log "Testing latency to: $target..."

    if ! command -v ping &>/dev/null; then
        log "ERROR: ping not available"
        return 1
    fi

    local result=$(ping -c 10 "$target" 2>&1)

    echo "$result"
    echo ""

    local avg_latency=$(echo "$result" | tail -1 | awk -F'/' '{print $5}' | cut -d. -f1)
    avg_latency=${avg_latency:-0}

    echo "Average latency: ${avg_latency}ms"

    if [ "$avg_latency" -lt "$LATENCY_THRESHOLD" ]; then
        echo "Status: GOOD (< ${LATENCY_THRESHOLD}ms threshold)"
    else
        echo "Status: HIGH (> ${LATENCY_THRESHOLD}ms threshold)"
        echo "Recommendation: Consider edge placement for latency-sensitive workloads"
    fi
}

# Edge status
edge_status() {
    log "=== VirtOS Edge Computing Status ==="
    echo ""

    echo "Edge Mode: $EDGE_MODE"
    echo "Location: $EDGE_LOCATION"
    echo "Cloud Hub: ${CLOUD_HUB:-Not configured}"
    echo ""

    echo "Bandwidth:"
    echo "  Limit: ${BANDWIDTH_LIMIT}Mbps"
    echo ""

    echo "Synchronization:"
    echo "  Enabled: $SYNC_ENABLED"
    echo "  Strategy: $SYNC_STRATEGY"
    sync_status
    echo ""

    echo "Offline Mode:"
    offline_status
    echo ""

    echo "Cache:"
    echo "  Enabled: $CACHE_ENABLED"
    echo "  Size: $CACHE_SIZE"
    if [ -d "$EDGE_DIR/cache" ]; then
        local cache_usage=$(du -sh "$EDGE_DIR/cache" 2>/dev/null | awk '{print $1}')
        echo "  Usage: $cache_usage"
    fi
}

# Edge wizard
edge_wizard() {
    log "Starting VirtOS Edge Computing Setup Wizard..."

    echo "=== VirtOS Edge Computing Setup Wizard ==="
    echo ""

    # Edge mode
    echo "1. Edge Configuration"
    echo "   Select mode:"
    echo "   1) Edge Node (at edge location)"
    echo "   2) Cloud Hub (central datacenter)"
    read -p "   Selection [1]: " mode_choice

    case "${mode_choice:-1}" in
        1) EDGE_MODE="edge-node" ;;
        2) EDGE_MODE="cloud-hub" ;;
    esac

    read -p "   Location name [edge1]: " location
    EDGE_LOCATION="${location:-edge1}"

    # Cloud hub registration
    if [ "$EDGE_MODE" = "edge-node" ]; then
        echo ""
        echo "2. Cloud Hub Connection"
        read -p "   Cloud hub hostname/IP: " hub_host
        CLOUD_HUB="$hub_host"
    fi

    # Bandwidth
    echo ""
    echo "3. Bandwidth Configuration"
    read -p "   WAN bandwidth limit (Mbps) [100]: " bw_limit
    BANDWIDTH_LIMIT="${bw_limit:-100}"

    # Sync
    echo ""
    echo "4. Synchronization"
    read -p "   Enable cloud synchronization? (y/n) [y]: " sync_choice
    SYNC_ENABLED="${sync_choice:-y}"

    if [ "$SYNC_ENABLED" = "y" ]; then
        echo "   Sync strategy:"
        echo "   1) Incremental (only changed files)"
        echo "   2) Full (all files)"
        read -p "   Selection [1]: " strategy_choice

        case "${strategy_choice:-1}" in
            1) SYNC_STRATEGY="incremental" ;;
            2) SYNC_STRATEGY="full" ;;
        esac
    fi

    # Offline capability
    echo ""
    echo "5. Offline Operation"
    read -p "   Enable offline capability? (y/n) [y]: " offline_choice
    OFFLINE_CAPABLE="${offline_choice:-y}"

    # Cache
    echo ""
    echo "6. Edge Cache"
    read -p "   Enable edge cache? (y/n) [y]: " cache_choice
    CACHE_ENABLED="${cache_choice:-y}"

    if [ "$CACHE_ENABLED" = "y" ]; then
        read -p "   Cache size [10G]: " cache_size
        CACHE_SIZE="${cache_size:-10G}"
    fi

    # Initialize
    echo ""
    log "Initializing edge node..."
    edge_init "$EDGE_MODE" "$EDGE_LOCATION"

    if [ -n "$CLOUD_HUB" ]; then
        edge_register "$CLOUD_HUB"
    fi

    echo ""
    log "Edge computing wizard completed!"
    echo ""
    echo "Next steps:"
    echo "  - Deploy workloads: virtos-edge edge-deploy <workload>"
    echo "  - Start auto-sync: virtos-edge sync-start"
    echo "  - Check status: virtos-edge edge-status"
}

# Show usage
usage() {
    cat << EOF
VirtOS Edge Computing Optimizations - Version $VERSION

Usage: $SCRIPT_NAME <command> [options]

Commands:
  edge-init <mode> <location>            Initialize edge node
  edge-register <hub-host>               Register with cloud hub
  edge-deploy <workload> [source]        Deploy workload to edge

  workload-place <workload> [latency]    Determine optimal placement

  sync-to-cloud [path] [strategy]        Sync to cloud hub
  sync-from-cloud [path] [strategy]      Sync from cloud hub
  sync-start [interval]                  Start auto-sync daemon (default: 300s)
  sync-stop                              Stop auto-sync daemon
  sync-status                            Show sync status

  offline-enable                         Enable offline mode
  offline-disable                        Disable offline mode
  offline-status                         Check offline status

  bandwidth-optimize [limit]             Set bandwidth limit (Mbps)
  latency-test [target]                  Test latency to target

  edge-status                            Show edge status
  wizard                                 Run interactive setup wizard

  version                                Show version
  help                                   Show this help

Examples:
  # Setup wizard (recommended for first-time setup)
  $SCRIPT_NAME wizard

  # Initialize edge node
  $SCRIPT_NAME edge-init edge-node retail-store-1

  # Register with cloud hub
  $SCRIPT_NAME edge-register 192.168.1.100

  # Deploy workload
  $SCRIPT_NAME edge-deploy pos-system cloud

  # Workload placement decision
  $SCRIPT_NAME workload-place web-app 50

  # Start auto-sync
  $SCRIPT_NAME sync-start 300

  # Enable offline mode
  $SCRIPT_NAME offline-enable

  # Test latency
  $SCRIPT_NAME latency-test 192.168.1.100

  # Optimize bandwidth
  $SCRIPT_NAME bandwidth-optimize 50

EOF
}

# Main
main() {
    # Handle help/version first (before init to avoid permission issues in tests)
    case "${1:-}" in
        version|--version|-v)
            echo "$SCRIPT_NAME version $VERSION"
            exit 0
            ;;
        help|--help|-h|"")
            usage
            exit 0
            ;;
    esac

    # Now safe to init (only for actual commands)
    init_logging
    load_config

    case "${1}" in
        edge-init)
            edge_init "$2" "$3"
            ;;
        edge-register)
            edge_register "$2"
            ;;
        edge-deploy)
            edge_deploy "$2" "$3"
            ;;
        workload-place)
            workload_place "$2" "$3"
            ;;
        sync-to-cloud)
            sync_to_cloud "$2" "$3"
            ;;
        sync-from-cloud)
            sync_from_cloud "$2" "$3"
            ;;
        sync-start)
            sync_start "$2"
            ;;
        sync-stop)
            sync_stop
            ;;
        sync-status)
            sync_status
            ;;
        offline-enable)
            offline_enable
            ;;
        offline-disable)
            offline_disable
            ;;
        offline-status)
            offline_status
            ;;
        bandwidth-optimize)
            bandwidth_optimize "$2"
            ;;
        latency-test)
            latency_test "$2"
            ;;
        edge-status)
            edge_status
            ;;
        wizard)
            edge_wizard
            ;;        *)
            echo "Unknown command: $1"
            echo "Run '$SCRIPT_NAME help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
