set -e
# VirtOS Setup Wizard - First-time configuration TUI
# Interactive ncurses-based setup for VirtOS

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.17")

# Parse arguments early to allow --help and --version without dialog/whiptail
case "${1:-}" in
    -h|--help|help)
        cat <<EOF
VirtOS Setup Wizard - First-time configuration TUI

Usage: virtos-setup [OPTIONS]

Interactive ncurses-based setup wizard for VirtOS configuration.

OPTIONS:
    -h, --help      Show this help message
    -v, --version   Show version
    version         Show version

FEATURES:
    • Hostname and networking configuration
    • Storage setup for VMs
    • Clustering configuration (optional)
    • Services auto-start selection
    • Admin user account creation

REQUIREMENTS:
    • Must run as root
    • Requires dialog or whiptail

EXAMPLES:
    sudo virtos-setup
    virtos-setup --help
    virtos-setup --version

EXIT CODES:
    0    Success
    1    General error
    2    Invalid arguments
    3    Dialog/whiptail not available
    4    Configuration failed
    5    Permission denied (not root)

EOF
        exit 0
        ;;
    -v|--version|version)
        echo "virtos-setup version $VERSION"
        exit 0
        ;;
esac

# Check for dialog/whiptail (only needed for interactive mode)
if command -v dialog >/dev/null 2>&1; then
    DIALOG="dialog"
    DIALOG_OPTS="--backtitle \"VirtOS Setup Wizard v${VERSION}\" --colors"
elif command -v whiptail >/dev/null 2>&1; then
    DIALOG="whiptail"
    DIALOG_OPTS="--title \"VirtOS Setup v${VERSION}\""
else
    echo "Error: Setup wizard requires 'dialog' or 'whiptail' for the interactive interface" >&2
    echo "" >&2
    echo "Install with one of:" >&2
    echo "  tce-load -wi dialog" >&2
    echo "  tce-load -wi whiptail" >&2
    echo "" >&2
    echo "Alternatively, configure manually by editing:" >&2
    echo "  /etc/virtos/setup.conf" >&2
    exit 1
fi

# Temp file for dialog output
TEMP_FILE=$(mktemp)
trap "rm -f $TEMP_FILE" EXIT

# Configuration storage
CONFIG_DIR="/etc/virtos"
CONFIG_FILE="$CONFIG_DIR/setup.conf"

mkdir -p "$CONFIG_DIR"

# Color setup
export DIALOGRC=/tmp/dialogrc.setup.$$
cat > $DIALOGRC << 'EOF'
use_colors = ON
screen_color = (WHITE,BLUE,ON)
title_color = (YELLOW,BLUE,ON)
button_active_color = (WHITE,GREEN,ON)
button_inactive_color = (BLACK,WHITE,OFF)
EOF

#==============================================================================
# Configuration Variables
#==============================================================================

SETUP_HOSTNAME=""
SETUP_DOMAIN=""
SETUP_IP_MODE=""  # dhcp or static
SETUP_IP_ADDR=""
SETUP_NETMASK=""
SETUP_GATEWAY=""
SETUP_DNS=""
SETUP_STORAGE_DISK=""
SETUP_STORAGE_FS=""  # ext4, btrfs, lvm, zfs
SETUP_VM_DIR="/var/lib/vms"
SETUP_CLUSTERING="no"
SETUP_CLUSTER_NAME=""
SETUP_NFS_ROLE=""  # none, server, client
SETUP_SERVICES=()  # Array of services to enable
SETUP_ADMIN_USER=""
SETUP_ADMIN_PASS=""

#==============================================================================
# Helper Functions
#==============================================================================

save_config() {
    cat > "$CONFIG_FILE" <<EOF
# VirtOS Configuration - Generated by virtos-setup
# $(date)

HOSTNAME="$SETUP_HOSTNAME"
DOMAIN="$SETUP_DOMAIN"
IP_MODE="$SETUP_IP_MODE"
IP_ADDR="$SETUP_IP_ADDR"
NETMASK="$SETUP_NETMASK"
GATEWAY="$SETUP_GATEWAY"
DNS="$SETUP_DNS"
STORAGE_DISK="$SETUP_STORAGE_DISK"
STORAGE_FS="$SETUP_STORAGE_FS"
VM_DIR="$SETUP_VM_DIR"
CLUSTERING="$SETUP_CLUSTERING"
CLUSTER_NAME="$SETUP_CLUSTER_NAME"
NFS_ROLE="$SETUP_NFS_ROLE"
SERVICES="${SETUP_SERVICES[*]}"
ADMIN_USER="$SETUP_ADMIN_USER"
EOF

    echo "Configuration saved to $CONFIG_FILE"
}

apply_config() {
    # Apply all configuration settings

    # Hostname
    if [ -n "$SETUP_HOSTNAME" ]; then
        echo "$SETUP_HOSTNAME" > /etc/hostname
        hostname "$SETUP_HOSTNAME"
        echo "✓ Hostname set to $SETUP_HOSTNAME"
    fi

    # Networking
    if [ "$SETUP_IP_MODE" = "static" ]; then
        # Configure static IP (method depends on Tiny Core version)
        cat >> /opt/bootlocal.sh <<EOF

# Static IP configuration
ifconfig eth0 $SETUP_IP_ADDR netmask $SETUP_NETMASK up
route add default gw $SETUP_GATEWAY
echo "nameserver $SETUP_DNS" > /etc/resolv.conf
EOF
        echo "✓ Static IP configured: $SETUP_IP_ADDR"
    else
        echo "✓ DHCP enabled (default)"
    fi

    # Storage
    if [ -n "$SETUP_STORAGE_DISK" ]; then
        case "$SETUP_STORAGE_FS" in
            ext4)
                mkfs.ext4 -F "$SETUP_STORAGE_DISK"
                ;;
            btrfs)
                mkfs.btrfs -f "$SETUP_STORAGE_DISK"
                ;;
            zfs)
                zpool create vmpool "$SETUP_STORAGE_DISK"
                zfs create vmpool/vms
                zfs set compression=lz4 vmpool/vms
                SETUP_VM_DIR="/vmpool/vms"
                ;;
            lvm)
                pvcreate "$SETUP_STORAGE_DISK"
                vgcreate vg_vms "$SETUP_STORAGE_DISK"
                lvcreate -l 100%FREE -n vms vg_vms
                mkfs.ext4 /dev/vg_vms/vms
                SETUP_STORAGE_DISK="/dev/vg_vms/vms"
                ;;
        esac

        if [ "$SETUP_STORAGE_FS" != "zfs" ]; then
            mkdir -p "$SETUP_VM_DIR"
            echo "$SETUP_STORAGE_DISK $SETUP_VM_DIR $SETUP_STORAGE_FS defaults 0 0" >> /etc/fstab
            mount "$SETUP_VM_DIR"
        fi
        echo "✓ Storage configured: $SETUP_STORAGE_FS on $SETUP_STORAGE_DISK"
    fi

    # Clustering
    if [ "$SETUP_CLUSTERING" = "yes" ]; then
        sed -i "s/CLUSTER_NAME=.*/CLUSTER_NAME=\"$SETUP_CLUSTER_NAME\"/" /etc/virtos/cluster.conf 2>/dev/null || \
            echo "CLUSTER_NAME=\"$SETUP_CLUSTER_NAME\"" > /etc/virtos/cluster.conf
        echo "✓ Clustering enabled: $SETUP_CLUSTER_NAME"
    fi

    # NFS
    if [ "$SETUP_NFS_ROLE" = "server" ]; then
        mkdir -p /export/vms
        echo "/export/vms *(rw,sync,no_subtree_check,no_root_squash)" >> /etc/exports
        exportfs -av
        echo "✓ NFS server configured"
    fi

    # Services
    for service in "${SETUP_SERVICES[@]}"; do
        case "$service" in
            libvirt)
                echo "/usr/local/etc/init.d/libvirtd start" >> /opt/bootlocal.sh
                /usr/local/etc/init.d/libvirtd start 2>/dev/null
                ;;
            docker)
                echo "/usr/local/etc/init.d/docker start" >> /opt/bootlocal.sh
                /usr/local/etc/init.d/docker start 2>/dev/null
                ;;
            avahi)
                echo "/usr/local/etc/init.d/avahi-daemon start" >> /opt/bootlocal.sh
                /usr/local/etc/init.d/avahi-daemon start 2>/dev/null
                ;;
            k3s)
                echo "/usr/local/bin/k3s server &" >> /opt/bootlocal.sh
                ;;
        esac
        echo "✓ Service enabled: $service"
    done

    # Admin user
    if [ -n "$SETUP_ADMIN_USER" ]; then
        if command -v /usr/local/bin/add-user.sh >/dev/null 2>&1; then
            /usr/local/bin/add-user.sh "$SETUP_ADMIN_USER" "$SETUP_ADMIN_PASS"
            echo "✓ Admin user created: $SETUP_ADMIN_USER"
        fi
    fi

    # Save configuration for persistence
    filetool.sh -b

    echo ""
    echo "Configuration complete!"
}

#==============================================================================
# Setup Wizard Steps
#==============================================================================

welcome_screen() {
    $DIALOG $DIALOG_OPTS \
        --title "Welcome to VirtOS" \
        --yesno "\n\Z4Welcome to VirtOS Setup Wizard\Zn\n\nThis wizard will help you configure:\n\n • Hostname and networking\n • Storage for VMs\n • Clustering (optional)\n • Services to enable\n • Admin user account\n\nSetup takes 5-10 minutes.\n\nReady to begin?" 18 60

    if [ $? -ne 0 ]; then
        exit 0
    fi
}

setup_hostname() {
    $DIALOG $DIALOG_OPTS \
        --title "Hostname Configuration" \
        --inputbox "Enter hostname for this VirtOS instance:\n\n(Examples: virtos, virtos-1, kvm-host)" 12 60 "virtos" \
        2> $TEMP_FILE

    SETUP_HOSTNAME=$(cat $TEMP_FILE)

    if [ -z "$SETUP_HOSTNAME" ]; then
        SETUP_HOSTNAME="virtos"
    fi

    $DIALOG $DIALOG_OPTS \
        --title "Domain Name" \
        --inputbox "Enter domain name (optional):\n\n(Example: lab.local)" 10 60 "local" \
        2> $TEMP_FILE

    SETUP_DOMAIN=$(cat $TEMP_FILE)
}

setup_networking() {
    $DIALOG $DIALOG_OPTS \
        --title "Network Configuration" \
        --menu "Select network configuration mode:" 12 60 2 \
        "dhcp" "Automatic (DHCP) - Recommended" \
        "static" "Static IP address" \
        2> $TEMP_FILE

    SETUP_IP_MODE=$(cat $TEMP_FILE)

    if [ "$SETUP_IP_MODE" = "static" ]; then
        # IP Address
        $DIALOG $DIALOG_OPTS \
            --title "Static IP Configuration" \
            --inputbox "Enter IP address:" 8 60 "192.168.1.100" \
            2> $TEMP_FILE
        SETUP_IP_ADDR=$(cat $TEMP_FILE)

        # Netmask
        $DIALOG $DIALOG_OPTS \
            --title "Static IP Configuration" \
            --inputbox "Enter netmask:" 8 60 "255.255.255.0" \
            2> $TEMP_FILE
        SETUP_NETMASK=$(cat $TEMP_FILE)

        # Gateway
        $DIALOG $DIALOG_OPTS \
            --title "Static IP Configuration" \
            --inputbox "Enter gateway:" 8 60 "192.168.1.1" \
            2> $TEMP_FILE
        SETUP_GATEWAY=$(cat $TEMP_FILE)

        # DNS
        $DIALOG $DIALOG_OPTS \
            --title "Static IP Configuration" \
            --inputbox "Enter DNS server:" 8 60 "8.8.8.8" \
            2> $TEMP_FILE
        SETUP_DNS=$(cat $TEMP_FILE)
    fi
}

setup_storage() {
    # Detect available disks
    DISKS=$(lsblk -dnp -o NAME,SIZE,TYPE | grep disk)

    if [ -z "$DISKS" ]; then
        $DIALOG $DIALOG_OPTS --msgbox "No additional disks found.\n\nWill use default storage location." 8 50
        return
    fi

    $DIALOG $DIALOG_OPTS \
        --title "Storage Configuration" \
        --yesno "Configure dedicated storage for VMs?\n\nDetected disks:\n$DISKS\n\nSelect 'Yes' to configure, 'No' to skip." 14 70

    if [ $? -ne 0 ]; then
        return
    fi

    # Disk selection
    DISK_LIST=""
    while IFS= read -r line; do
        DISK=$(echo $line | awk '{print $1}')
        SIZE=$(echo $line | awk '{print $2}')
        DISK_LIST="$DISK_LIST $DISK \"$SIZE\""
    done <<< "$DISKS"

    # SECURITY NOTE: eval used here for dialog's word-splitting requirements
    # Disk names come from lsblk (kernel-controlled), not user input
    eval $DIALOG $DIALOG_OPTS \
        --title "Select Storage Disk" \
        --menu "Choose disk for VM storage:" 15 70 5 \
        $DISK_LIST \
        2> $TEMP_FILE

    SETUP_STORAGE_DISK=$(cat $TEMP_FILE)

    # Filesystem selection
    $DIALOG $DIALOG_OPTS \
        --title "Filesystem Type" \
        --menu "Select filesystem for VM storage:" 15 70 4 \
        "ext4" "Standard Linux filesystem (simple, reliable)" \
        "btrfs" "Modern filesystem with snapshots (recommended)" \
        "lvm" "Logical Volume Manager (flexible)" \
        "zfs" "Enterprise filesystem (requires 4GB+ RAM)" \
        2> $TEMP_FILE

    SETUP_STORAGE_FS=$(cat $TEMP_FILE)

    # VM directory
    $DIALOG $DIALOG_OPTS \
        --title "VM Storage Location" \
        --inputbox "Enter mount point for VMs:" 8 60 "/var/lib/vms" \
        2> $TEMP_FILE

    SETUP_VM_DIR=$(cat $TEMP_FILE)

    # Warning for destructive operation
    $DIALOG $DIALOG_OPTS \
        --title "WARNING" \
        --yesno "\Z1WARNING: This will FORMAT $SETUP_STORAGE_DISK\Zn\n\nAll data on this disk will be DESTROYED!\n\nFilesystem: $SETUP_STORAGE_FS\nMount point: $SETUP_VM_DIR\n\nAre you SURE you want to continue?" 14 60

    if [ $? -ne 0 ]; then
        SETUP_STORAGE_DISK=""
        SETUP_STORAGE_FS=""
    fi
}

setup_clustering() {
    if ! command -v virtos-cluster >/dev/null 2>&1; then
        $DIALOG $DIALOG_OPTS --msgbox "Clustering feature not available\n\nReason: virtos-cluster command not found\n\nTo enable clustering:\n  1. Install virtos-cluster package:\n     tce-load -wi virtos-cluster\n\n  2. Or rebuild VirtOS with clustering:\n     ENABLE_CLUSTERING=yes ./build.sh\n\nClustering will be disabled for this setup." 16 60
        SETUP_CLUSTERING="no"
        return
    fi

    $DIALOG $DIALOG_OPTS \
        --title "Clustering" \
        --yesno "Enable multi-host clustering?\n\nThis allows:\n • Automatic discovery of other VirtOS hosts\n • Resource pooling\n • VM migration (with shared storage)\n • Coordinated management\n\nRequires: Avahi/mDNS\n\nEnable clustering?" 16 60

    if [ $? -eq 0 ]; then
        SETUP_CLUSTERING="yes"

        $DIALOG $DIALOG_OPTS \
            --title "Cluster Name" \
            --inputbox "Enter cluster name:\n\n(All hosts in the same cluster must use the same name)" 10 60 "homelab" \
            2> $TEMP_FILE

        SETUP_CLUSTER_NAME=$(cat $TEMP_FILE)

        # NFS role
        $DIALOG $DIALOG_OPTS \
            --title "Shared Storage (NFS)" \
            --menu "NFS role for this host:" 12 60 3 \
            "none" "No shared storage" \
            "server" "NFS server (share VMs to other hosts)" \
            "client" "NFS client (mount from another host)" \
            2> $TEMP_FILE

        SETUP_NFS_ROLE=$(cat $TEMP_FILE)
    else
        SETUP_CLUSTERING="no"
    fi
}

setup_services() {
    SERVICES_AVAIL=""

    # Check what's available
    command -v virsh >/dev/null && SERVICES_AVAIL="$SERVICES_AVAIL libvirt libvirt off"
    command -v docker >/dev/null && SERVICES_AVAIL="$SERVICES_AVAIL docker docker off"
    command -v avahi-daemon >/dev/null && SERVICES_AVAIL="$SERVICES_AVAIL avahi avahi off"
    command -v k3s >/dev/null && SERVICES_AVAIL="$SERVICES_AVAIL k3s k3s off"

    if [ -z "$SERVICES_AVAIL" ]; then
        $DIALOG $DIALOG_OPTS --msgbox "No optional services found." 6 40
        return
    fi

    # SECURITY NOTE: eval used here for dialog's word-splitting requirements
    # Service names come from command -v checks (system-controlled), not user input
    eval $DIALOG $DIALOG_OPTS \
        --title "Service Auto-start" \
        --checklist "Select services to start at boot:\n\n(Use SPACE to select, ENTER when done)" 16 60 6 \
        $SERVICES_AVAIL \
        2> $TEMP_FILE

    # Read selected services
    SETUP_SERVICES=($(cat $TEMP_FILE | tr -d '"'))
}

setup_admin_user() {
    $DIALOG $DIALOG_OPTS \
        --title "Admin User" \
        --yesno "Create admin user for remote access?\n\n • SSH access\n • libvirt/virsh permissions\n • sudo access\n\nRecommended for virt-manager remote management.\n\nCreate admin user?" 14 60

    if [ $? -ne 0 ]; then
        return
    fi

    $DIALOG $DIALOG_OPTS \
        --title "Admin Username" \
        --inputbox "Enter username for admin account:" 8 60 "vmadmin" \
        2> $TEMP_FILE

    SETUP_ADMIN_USER=$(cat $TEMP_FILE)

    $DIALOG $DIALOG_OPTS \
        --title "Admin Password" \
        --insecure \
        --passwordbox "Enter password for $SETUP_ADMIN_USER:" 8 60 \
        2> $TEMP_FILE

    SETUP_ADMIN_PASS=$(cat $TEMP_FILE)
}

review_configuration() {
    REVIEW="Configuration Summary\n\n"
    REVIEW="${REVIEW}Hostname: $SETUP_HOSTNAME.$SETUP_DOMAIN\n"
    REVIEW="${REVIEW}Network: $SETUP_IP_MODE"
    [ "$SETUP_IP_MODE" = "static" ] && REVIEW="${REVIEW} ($SETUP_IP_ADDR)"
    REVIEW="${REVIEW}\n"

    if [ -n "$SETUP_STORAGE_DISK" ]; then
        REVIEW="${REVIEW}Storage: $SETUP_STORAGE_FS on $SETUP_STORAGE_DISK → $SETUP_VM_DIR\n"
    else
        REVIEW="${REVIEW}Storage: Default (no dedicated disk)\n"
    fi

    REVIEW="${REVIEW}Clustering: $SETUP_CLUSTERING"
    [ "$SETUP_CLUSTERING" = "yes" ] && REVIEW="${REVIEW} ($SETUP_CLUSTER_NAME)"
    REVIEW="${REVIEW}\n"

    if [ "$SETUP_NFS_ROLE" != "none" ]; then
        REVIEW="${REVIEW}NFS: $SETUP_NFS_ROLE\n"
    fi

    if [ ${#SETUP_SERVICES[@]} -gt 0 ]; then
        REVIEW="${REVIEW}Services: ${SETUP_SERVICES[*]}\n"
    fi

    if [ -n "$SETUP_ADMIN_USER" ]; then
        REVIEW="${REVIEW}Admin user: $SETUP_ADMIN_USER\n"
    fi

    $DIALOG $DIALOG_OPTS \
        --title "Review Configuration" \
        --yesno "$REVIEW\nApply this configuration?" 20 70

    return $?
}

completion_screen() {
    INFO="VirtOS Setup Complete!\n\n"
    INFO="${INFO}Your VirtOS instance is now configured:\n\n"
    INFO="${INFO} • Hostname: $SETUP_HOSTNAME\n"

    if [ "$SETUP_IP_MODE" = "static" ]; then
        INFO="${INFO} • IP: $SETUP_IP_ADDR\n"
    else
        INFO="${INFO} • IP: $(hostname -I | awk '{print $1}')\n"
    fi

    if [ -n "$SETUP_ADMIN_USER" ]; then
        INFO="${INFO}\nRemote Access:\n"
        INFO="${INFO} ssh $SETUP_ADMIN_USER@$SETUP_HOSTNAME.local\n"
        INFO="${INFO} virt-manager -c qemu+ssh://$SETUP_ADMIN_USER@$SETUP_HOSTNAME.local/system\n"
    fi

    INFO="${INFO}\nManagement Tools:\n"
    INFO="${INFO} virtos-tui       - Text UI management console\n"
    [ "$SETUP_CLUSTERING" = "yes" ] && INFO="${INFO} virtos-cluster   - Cluster management\n"
    INFO="${INFO} virtos-create-vm - Create VMs with IaaS placement\n"

    INFO="${INFO}\nConfiguration saved to: $CONFIG_FILE\n"

    $DIALOG $DIALOG_OPTS \
        --title "Setup Complete" \
        --msgbox "$INFO" 24 76
}

#==============================================================================
# Main Setup Flow
#==============================================================================

main() {
    # Check if running as root
    if [ "$(id -u)" -ne 0 ]; then
        $DIALOG $DIALOG_OPTS --msgbox "Error: Setup wizard requires root privileges\n\nReason: System configuration requires root access to:\n  • Configure hostname and networking\n  • Format and mount storage devices\n  • Configure system services\n  • Create user accounts\n\nRe-run with root privileges:\n  sudo virtos-setup" 16 60
        exit 1
    fi

    # Check if already configured
    if [ -f "$CONFIG_FILE" ]; then
        $DIALOG $DIALOG_OPTS \
            --title "Already Configured" \
            --yesno "VirtOS appears to be already configured.\n\nConfiguration file exists: $CONFIG_FILE\n\nRun setup again?\n\n(This will overwrite existing configuration)" 12 60

        if [ $? -ne 0 ]; then
            exit 0
        fi
    fi

    # Run setup wizard
    welcome_screen

    setup_hostname
    setup_networking
    setup_storage
    setup_clustering
    setup_services
    setup_admin_user

    # Review and confirm
    if ! review_configuration; then
        $DIALOG $DIALOG_OPTS --msgbox "Setup cancelled.\n\nNo changes made." 6 40
        exit 0
    fi

    # Apply configuration
    save_config

    $DIALOG $DIALOG_OPTS --infobox "Applying configuration...\n\nPlease wait..." 6 40
    apply_config > /tmp/virtos-setup.log 2>&1

    # Show completion
    completion_screen

    # Offer to reboot
    $DIALOG $DIALOG_OPTS \
        --title "Reboot Required" \
        --yesno "Some changes require a reboot to take effect.\n\nReboot now?" 8 50

    if [ $? -eq 0 ]; then
        reboot
    fi
}

#==============================================================================
# Entry Point
#==============================================================================

main "$@"
