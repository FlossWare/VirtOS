set -e
# virtos-datacenter - Multi-datacenter management for VirtOS
# Part of Phase 11: Multi-Datacenter and Advanced Features

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.24")
SCRIPT_NAME="virtos-datacenter"
LOG_FILE="/var/log/virtos-datacenter.log"
CONFIG_FILE="/etc/virtos/datacenter.conf"
DC_DIR="/var/lib/virtos/datacenters"
REPLICATION_DIR="/var/lib/virtos/replication"

# Datacenter configuration defaults
DC_NAME=""
DC_REGION=""
DC_LATITUDE=""
DC_LONGITUDE=""
WAN_BANDWIDTH="1000"  # Mbps
REPLICATION_ENABLED="yes"
GEO_LOADBALANCING="no"
DR_ENABLED="yes"
SYNC_INTERVAL="300"  # 5 minutes

# Initialize logging
init_logging() {
    mkdir -p "$(dirname "$LOG_FILE")"
    mkdir -p "$DC_DIR"
    mkdir -p "$REPLICATION_DIR"
}

# Log message
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

# Load configuration
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
}

# Save configuration
save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" << EOF
# VirtOS Datacenter Configuration
# Generated by virtos-datacenter version $VERSION

DC_NAME="$DC_NAME"
DC_REGION="$DC_REGION"
DC_LATITUDE="$DC_LATITUDE"
DC_LONGITUDE="$DC_LONGITUDE"
WAN_BANDWIDTH="$WAN_BANDWIDTH"
REPLICATION_ENABLED="$REPLICATION_ENABLED"
GEO_LOADBALANCING="$GEO_LOADBALANCING"
DR_ENABLED="$DR_ENABLED"
SYNC_INTERVAL="$SYNC_INTERVAL"
EOF
    log "Configuration saved to $CONFIG_FILE"
}

# Initialize local datacenter
datacenter_init() {
    local name="${1:-dc1}"
    local region="${2:-us-east}"

    log "Initializing datacenter: $name (region: $region)..."

    DC_NAME="$name"
    DC_REGION="$region"

    # Create datacenter metadata file
    local dc_file="$DC_DIR/$name.json"

    cat > "$dc_file" << EOF
{
  "name": "$name",
  "region": "$region",
  "hostname": "$(hostname)",
  "ip": "$(hostname -I | awk '{print $1}')",
  "latitude": "$DC_LATITUDE",
  "longitude": "$DC_LONGITUDE",
  "wan_bandwidth": "$WAN_BANDWIDTH",
  "registered_at": "$(date -Iseconds)",
  "status": "active"
}
EOF

    save_config

    log "Datacenter $name initialized"
    log "Metadata: $dc_file"
}

# Register remote datacenter
datacenter_register() {
    local name="$1"
    local host="$2"
    local region="${3:-unknown}"

    if [ -z "$name" ] || [ -z "$host" ]; then
        log "ERROR: Datacenter name and host required"
        return 1
    fi

    log "Registering remote datacenter: $name at $host..."

    # Test connectivity
    if ! ping -c 1 -W 2 "$host" &>/dev/null; then
        log "WARNING: Cannot reach $host - registering anyway"
    fi

    # Create remote datacenter record
    local dc_file="$DC_DIR/$name.json"

    cat > "$dc_file" << EOF
{
  "name": "$name",
  "region": "$region",
  "hostname": "$host",
  "ip": "$host",
  "registered_at": "$(date -Iseconds)",
  "status": "registered",
  "remote": true
}
EOF

    log "Datacenter $name registered"

    # Setup SSH trust if possible
    if command -v ssh &>/dev/null; then
        log "Consider setting up SSH key trust: ssh-copy-id vmadmin@$host"
    fi
}

# List datacenters
datacenter_list() {
    log "Listing datacenters..."

    echo "Name            Region          Hostname              Status      Remote"
    echo "--------------- --------------- --------------------- ----------- ------"

    for dc_file in "$DC_DIR"/*.json; do
        if [ -f "$dc_file" ]; then
            local name=$(jq -r '.name' "$dc_file" 2>/dev/null || echo "unknown")
            local region=$(jq -r '.region' "$dc_file" 2>/dev/null || echo "unknown")
            local hostname=$(jq -r '.hostname' "$dc_file" 2>/dev/null || echo "unknown")
            local status=$(jq -r '.status' "$dc_file" 2>/dev/null || echo "unknown")
            local remote=$(jq -r '.remote // false' "$dc_file" 2>/dev/null || echo "false")

            printf "%-15s %-15s %-21s %-11s %-6s\n" \
                "$name" "$region" "$hostname" "$status" "$remote"
        fi
    done
}

# Remove datacenter
datacenter_remove() {
    local name="$1"

    if [ -z "$name" ]; then
        log "ERROR: Datacenter name required"
        return 1
    fi

    local dc_file="$DC_DIR/$name.json"

    if [ ! -f "$dc_file" ]; then
        log "ERROR: Datacenter not found: $name"
        return 1
    fi

    log "Removing datacenter: $name..."

    rm -f "$dc_file"

    log "Datacenter $name removed"
}

# Cross-datacenter VM placement
vm_place() {
    local vm_name="$1"
    local requirements="${2:-}"

    if [ -z "$vm_name" ]; then
        log "ERROR: VM name required"
        return 1
    fi

    log "Finding optimal datacenter for VM: $vm_name..."

    # Analyze requirements (simplified)
    local best_dc=""
    local best_score=0

    for dc_file in "$DC_DIR"/*.json; do
        if [ -f "$dc_file" ]; then
            local name=$(jq -r '.name' "$dc_file" 2>/dev/null)
            local status=$(jq -r '.status' "$dc_file" 2>/dev/null)

            if [ "$status" = "active" ]; then
                # Simple scoring: prefer local datacenter
                local score=50
                if [ "$name" = "$DC_NAME" ]; then
                    score=100
                fi

                if [ $score -gt $best_score ]; then
                    best_score=$score
                    best_dc="$name"
                fi
            fi
        fi
    done

    if [ -z "$best_dc" ]; then
        log "ERROR: No active datacenter found"
        return 1
    fi

    log "Best datacenter for $vm_name: $best_dc (score: $best_score)"
    echo "$best_dc"
}

# Setup replication
replication_setup() {
    local source_dc="$1"
    local target_dc="$2"

    if [ -z "$source_dc" ] || [ -z "$target_dc" ]; then
        log "ERROR: Source and target datacenters required"
        return 1
    fi

    log "Setting up replication: $source_dc -> $target_dc..."

    # Get target datacenter info
    local target_file="$DC_DIR/$target_dc.json"
    if [ ! -f "$target_file" ]; then
        log "ERROR: Target datacenter not found: $target_dc"
        return 1
    fi

    local target_host=$(jq -r '.hostname' "$target_file" 2>/dev/null)

    # Create replication configuration
    local repl_file="$REPLICATION_DIR/${source_dc}-to-${target_dc}.conf"

    cat > "$repl_file" << EOF
# Replication: $source_dc -> $target_dc
SOURCE_DC="$source_dc"
TARGET_DC="$target_dc"
TARGET_HOST="$target_host"
ENABLED="yes"
BANDWIDTH_LIMIT="$WAN_BANDWIDTH"
SYNC_INTERVAL="$SYNC_INTERVAL"
COMPRESSION="yes"
ENCRYPTION="yes"
EOF

    log "Replication configured: $repl_file"
    log "Target: $target_host"
}

# Start replication
replication_start() {
    local source_dc="$1"
    local target_dc="$2"

    if [ -z "$source_dc" ] || [ -z "$target_dc" ]; then
        log "ERROR: Source and target datacenters required"
        return 1
    fi

    log "Starting replication: $source_dc -> $target_dc..."

    local repl_file="$REPLICATION_DIR/${source_dc}-to-${target_dc}.conf"

    if [ ! -f "$repl_file" ]; then
        log "ERROR: Replication not configured. Run: virtos-datacenter replication-setup"
        return 1
    fi

    source "$repl_file"

    # Use rsync for WAN-optimized replication
    log "Replicating VM storage to $TARGET_HOST..."

    # Create sync script
    local sync_script="/usr/local/bin/virtos-dc-sync-${source_dc}-${target_dc}.sh"

    cat > "$sync_script" << 'SYNCEOF'
#!/bin/bash
# Auto-generated datacenter sync script

source REPL_FILE

while true; do
    echo "[$(date)] Starting sync: $SOURCE_DC -> $TARGET_DC"

    rsync -avz --compress --bwlimit=$BANDWIDTH_LIMIT \
        /var/lib/libvirt/images/ \
        vmadmin@$TARGET_HOST:/var/lib/libvirt/images/ \
        2>&1 | tee -a /var/log/virtos-replication.log

    echo "[$(date)] Sync completed. Waiting $SYNC_INTERVAL seconds..."
    sleep $SYNC_INTERVAL
done
SYNCEOF

    sed -i "s|REPL_FILE|$repl_file|" "$sync_script"
    chmod +x "$sync_script"

    # Start replication in background
    nohup "$sync_script" &>/dev/null &
    local pid=$!

    echo "$pid" > "$REPLICATION_DIR/${source_dc}-to-${target_dc}.pid"

    log "Replication started (PID: $pid)"
    log "Monitor: tail -f /var/log/virtos-replication.log"
}

# Stop replication
replication_stop() {
    local source_dc="$1"
    local target_dc="$2"

    if [ -z "$source_dc" ] || [ -z "$target_dc" ]; then
        log "ERROR: Source and target datacenters required"
        return 1
    fi

    log "Stopping replication: $source_dc -> $target_dc..."

    local pid_file="$REPLICATION_DIR/${source_dc}-to-${target_dc}.pid"

    if [ -f "$pid_file" ]; then
        local pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid"
            log "Replication stopped (PID: $pid)"
        else
            log "Replication process not running"
        fi
        rm -f "$pid_file"
    else
        log "No active replication found"
    fi
}

# Replication status
replication_status() {
    log "Replication status..."

    echo "Source DC       Target DC       Status      PID"
    echo "--------------- --------------- ----------- -------"

    for repl_file in "$REPLICATION_DIR"/*.conf; do
        if [ -f "$repl_file" ]; then
            source "$repl_file"

            local pid_file="${repl_file%.conf}.pid"
            local status="stopped"
            local pid="-"

            if [ -f "$pid_file" ]; then
                pid=$(cat "$pid_file")
                if kill -0 "$pid" 2>/dev/null; then
                    status="running"
                else
                    status="stopped"
                    pid="-"
                fi
            fi

            printf "%-15s %-15s %-11s %-7s\n" \
                "$SOURCE_DC" "$TARGET_DC" "$status" "$pid"
        fi
    done
}

# Geographic load balancing
geo_loadbalance() {
    local service="$1"
    local client_lat="${2:-0}"
    local client_lon="${3:-0}"

    if [ -z "$service" ]; then
        log "ERROR: Service name required"
        return 1
    fi

    log "Finding nearest datacenter for $service (client: $client_lat, $client_lon)..."

    # Simple distance calculation (simplified great circle)
    local best_dc=""
    local min_distance=999999

    for dc_file in "$DC_DIR"/*.json; do
        if [ -f "$dc_file" ]; then
            local name=$(jq -r '.name' "$dc_file" 2>/dev/null)
            local lat=$(jq -r '.latitude // "0"' "$dc_file" 2>/dev/null)
            local lon=$(jq -r '.longitude // "0"' "$dc_file" 2>/dev/null)
            local status=$(jq -r '.status' "$dc_file" 2>/dev/null)

            if [ "$status" = "active" ]; then
                # Simplified Euclidean distance (not accurate for large distances)
                local dlat=$(echo "$client_lat - $lat" | bc)
                local dlon=$(echo "$client_lon - $lon" | bc)
                local distance=$(echo "sqrt($dlat*$dlat + $dlon*$dlon)" | bc -l)

                if [ $(echo "$distance < $min_distance" | bc) -eq 1 ]; then
                    min_distance=$distance
                    best_dc="$name"
                fi
            fi
        fi
    done

    if [ -z "$best_dc" ]; then
        log "ERROR: No active datacenter found"
        return 1
    fi

    log "Nearest datacenter: $best_dc (distance: $min_distance)"
    echo "$best_dc"
}

# Disaster recovery failover
dr_failover() {
    local failed_dc="$1"
    local target_dc="$2"

    if [ -z "$failed_dc" ] || [ -z "$target_dc" ]; then
        log "ERROR: Failed and target datacenters required"
        return 1
    fi

    log "Initiating DR failover: $failed_dc -> $target_dc..."

    # Get target datacenter info
    local target_file="$DC_DIR/$target_dc.json"
    if [ ! -f "$target_file" ]; then
        log "ERROR: Target datacenter not found: $target_dc"
        return 1
    fi

    local target_host=$(jq -r '.hostname' "$target_file" 2>/dev/null)

    log "Target: $target_host"

    # Step 1: Mark failed datacenter as down
    local failed_file="$DC_DIR/$failed_dc.json"
    if [ -f "$failed_file" ]; then
        # Update status using jq
        local tmp_file=$(mktemp) || die "Failed to create temporary file"
        jq '.status = "failed"' "$failed_file" > "$tmp_file"
        mv "$tmp_file" "$failed_file"
        log "Marked $failed_dc as failed"
    fi

    # Step 2: Activate VMs on target datacenter
    log "Activating VMs on $target_dc..."

    if command -v ssh &>/dev/null; then
        ssh "vmadmin@$target_host" "virsh list --all --name" 2>/dev/null | while read vm; do
            if [ -n "$vm" ]; then
                log "Starting VM: $vm on $target_dc"
                ssh "vmadmin@$target_host" "virsh start $vm" 2>/dev/null || true
            fi
        done
    fi

    log "DR failover completed"
    log "Review VM states on $target_dc"
}

# WAN optimization status
wan_status() {
    log "WAN optimization status..."

    echo "=== WAN Configuration ==="
    echo "Bandwidth limit: $WAN_BANDWIDTH Mbps"
    echo "Compression: enabled"
    echo "Encryption: enabled"
    echo ""

    echo "=== Active Connections ==="
    for repl_file in "$REPLICATION_DIR"/*.conf; do
        if [ -f "$repl_file" ]; then
            source "$repl_file"
            echo "  $SOURCE_DC -> $TARGET_DC ($TARGET_HOST)"
        fi
    done
}

# Datacenter wizard
datacenter_wizard() {
    log "Starting VirtOS Datacenter Setup Wizard..."

    echo "=== VirtOS Multi-Datacenter Setup Wizard ==="
    echo ""

    # Local datacenter info
    echo "1. Local Datacenter Configuration"
    read -p "   Datacenter name [dc1]: " dc_name
    DC_NAME="${dc_name:-dc1}"

    read -p "   Region (e.g., us-east, eu-west) [us-east]: " dc_region
    DC_REGION="${dc_region:-us-east}"

    read -p "   Latitude (optional): " dc_lat
    DC_LATITUDE="$dc_lat"

    read -p "   Longitude (optional): " dc_lon
    DC_LONGITUDE="$dc_lon"

    # WAN configuration
    echo ""
    echo "2. WAN Configuration"
    read -p "   WAN bandwidth limit (Mbps) [1000]: " wan_bw
    WAN_BANDWIDTH="${wan_bw:-1000}"

    # Replication
    echo ""
    echo "3. Replication"
    read -p "   Enable datacenter replication? (y/n) [y]: " repl_choice
    REPLICATION_ENABLED="${repl_choice:-y}"

    if [ "$REPLICATION_ENABLED" = "y" ]; then
        read -p "   Replication sync interval (seconds) [300]: " sync_int
        SYNC_INTERVAL="${sync_int:-300}"
    fi

    # Geo load balancing
    echo ""
    echo "4. Geographic Load Balancing"
    read -p "   Enable geo load balancing? (y/n) [n]: " geo_choice
    GEO_LOADBALANCING="${geo_choice:-n}"

    # DR
    echo ""
    echo "5. Disaster Recovery"
    read -p "   Enable DR failover? (y/n) [y]: " dr_choice
    DR_ENABLED="${dr_choice:-y}"

    # Initialize
    echo ""
    log "Initializing datacenter..."
    datacenter_init "$DC_NAME" "$DC_REGION"

    save_config

    echo ""
    log "Datacenter wizard completed!"
    echo ""
    echo "Next steps:"
    echo "  - Register remote datacenters: virtos-datacenter datacenter-register"
    echo "  - Setup replication: virtos-datacenter replication-setup"
    echo "  - View status: virtos-datacenter datacenter-list"
}

# Show usage
usage() {
    cat << EOF
VirtOS Multi-Datacenter Management - Version $VERSION

Usage: $SCRIPT_NAME <command> [options]

Commands:
  datacenter-init <name> [region]        Initialize local datacenter
  datacenter-register <name> <host> [region]  Register remote datacenter
  datacenter-list                        List all datacenters
  datacenter-remove <name>               Remove datacenter

  vm-place <vm-name> [requirements]      Find optimal datacenter for VM

  replication-setup <source> <target>    Configure replication
  replication-start <source> <target>    Start replication
  replication-stop <source> <target>     Stop replication
  replication-status                     Show replication status

  geo-loadbalance <service> [lat] [lon]  Find nearest datacenter
  dr-failover <failed-dc> <target-dc>    Failover to backup datacenter

  wan-status                             Show WAN optimization status
  wizard                                 Run interactive setup wizard

  version                                Show version
  help                                   Show this help

Examples:
  # Setup wizard (recommended for first-time setup)
  $SCRIPT_NAME wizard

  # Initialize local datacenter
  $SCRIPT_NAME datacenter-init dc1 us-east

  # Register remote datacenter
  $SCRIPT_NAME datacenter-register dc2 192.168.2.100 us-west

  # Setup replication
  $SCRIPT_NAME replication-setup dc1 dc2
  $SCRIPT_NAME replication-start dc1 dc2

  # Find optimal datacenter for VM
  $SCRIPT_NAME vm-place production-db

  # Geographic load balancing
  $SCRIPT_NAME geo-loadbalance web-app 40.7 -74.0

  # Disaster recovery failover
  $SCRIPT_NAME dr-failover dc1 dc2

EXIT CODES:
    0    Success
    1    General error
    2    Invalid arguments
    3    Datacenter not found
    4    Replication failed
    5    Failover failed

EOF
}

# Main
main() {
    # Handle help/version first (before init to avoid permission issues in tests)
    case "${1:-}" in
        version|--version|-v)
            echo "$SCRIPT_NAME version $VERSION"
            exit 0
            ;;
        help|--help|-h|"")
            usage
            exit 0
            ;;
    esac

    # Now init for actual commands
    init_logging
    load_config

    # Install jq if needed
    if ! command -v jq &> /dev/null; then
        log "Installing jq..."
        tce-load -wi jq
    fi

    case "${1}" in
        datacenter-init)
            datacenter_init "$2" "$3"
            ;;
        datacenter-register)
            datacenter_register "$2" "$3" "$4"
            ;;
        datacenter-list)
            datacenter_list
            ;;
        datacenter-remove)
            datacenter_remove "$2"
            ;;
        vm-place)
            vm_place "$2" "$3"
            ;;
        replication-setup)
            replication_setup "$2" "$3"
            ;;
        replication-start)
            replication_start "$2" "$3"
            ;;
        replication-stop)
            replication_stop "$2" "$3"
            ;;
        replication-status)
            replication_status
            ;;
        geo-loadbalance)
            geo_loadbalance "$2" "$3" "$4"
            ;;
        dr-failover)
            dr_failover "$2" "$3"
            ;;
        wan-status)
            wan_status
            ;;
        wizard)
            datacenter_wizard
            ;;        *)
            echo "Unknown command: $1"
            echo "Run '$SCRIPT_NAME help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
