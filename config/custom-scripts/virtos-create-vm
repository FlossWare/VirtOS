set -e
# VirtOS - Automated VM Creation with IaaS Placement

# Load common library - try multiple paths for dev/production compatibility
VIRTOS_COMMON=""
for lib_path in \
    "${VIRTOS_LIB:-}" \
    "$(dirname "$0")/lib/virtos-common.sh" \
    "/usr/local/lib/virtos-common.sh" \
    "$(git rev-parse --show-toplevel 2>/dev/null)/config/custom-scripts/lib/virtos-common.sh"; do
    [ -n "$lib_path" ] && [ -f "$lib_path" ] && VIRTOS_COMMON="$lib_path" && break
done

if [ -n "$VIRTOS_COMMON" ]; then
    . "$VIRTOS_COMMON"
else
    # Fallback color definitions if common lib not available
    if [ -t 1 ]; then
        RED='\033[0;31m'
        GREEN='\033[0;32m'
        YELLOW='\033[1;33m'
        BLUE='\033[0;34m'
        NC='\033[0m'
    else
        RED='' GREEN='' YELLOW='' BLUE='' NC=''
    fi
fi

VERSION=$(get_version 2>/dev/null || echo "0.89")

usage() {
    cat << EOF
VirtOS Automated VM Creation v${VERSION}

Usage: virtos-create-vm [options]

Required Options:
  --name <name>          VM name
  --cpu <count>          Number of vCPUs
  --ram <MB>             RAM in MB
  --disk <size>          Disk size (e.g., 20G, 500M)

Optional:
  --os <template>        OS template / cloud image (see Cloud Images below)
  --iso <path>           ISO file to boot from (e.g., VirtOS ISO)
  --ssh-key <path>       SSH public key to install (default: ~/.ssh/id_rsa.pub)
  --network <type>       Network type (bridged, nat, isolated) [default: bridged]
  --prefer <host>        Prefer this host (soft constraint)
  --avoid <host>         Avoid this host
  --require <host>       Must use this host (skip scheduler)
  --anti-affinity <vm>   Don't place on same host as <vm>
  --affinity <vm>        Prefer same host as <vm>
  --policy <policy>      Scheduler policy (balanced, packed, spread) [default: balanced]
  --priority <level>     Priority (low, normal, high) [default: normal]
  --auto-start           Start VM after creation
  --dry-run              Show placement decision without creating
  --verbose              Show detailed scheduling information

Cloud Images (--os):
  ubuntu-24.04           Ubuntu 24.04 LTS (Noble Numbat) cloud image
  ubuntu-22.04           Ubuntu 22.04 LTS (Jammy Jellyfish) cloud image
  ubuntu-20.04           Ubuntu 20.04 LTS (Focal Fossa) cloud image
  debian-12              Debian 12 (Bookworm) cloud image
  debian-11              Debian 11 (Bullseye) cloud image
  fedora-40              Fedora 40 cloud image
  centos-stream-9        CentOS Stream 9 cloud image
  virtos                 VirtOS (requires --iso, creates blank disk)
  minimal                Built-in minimal profile (blank disk)
  performance            Built-in performance profile (blank disk)
  secure                 Built-in secure profile (blank disk)

  When a cloud image OS is specified, the base image is automatically
  downloaded (if not cached) and used as a copy-on-write backing file.
  This means VMs boot with a full OS already installed. Combine with
  --ssh-key for immediate SSH access.

Examples:
  # Simple VM (auto-placed)
  virtos-create-vm --name web-1 --cpu 2 --ram 4096 --disk 20G

  # With cloud image (downloads Ubuntu, ready to SSH)
  virtos-create-vm --name app --cpu 4 --ram 8192 --disk 50G --os ubuntu-22.04

  # Debian cloud image with SSH key
  virtos-create-vm --name db --cpu 2 --ram 4096 --disk 30G \\
    --os debian-12 --ssh-key ~/.ssh/id_rsa.pub --auto-start

  # High availability (spread across hosts)
  virtos-create-vm --name db-primary --cpu 8 --ram 16384 --disk 200G \\
    --policy spread --priority high

  # Anti-affinity with another VM
  virtos-create-vm --name db-replica --cpu 8 --ram 16384 --disk 200G \\
    --anti-affinity db-primary

  # Force specific host
  virtos-create-vm --name test --cpu 1 --ram 2048 --disk 10G \\
    --require virtos-2

EXIT CODES:
    0    Success
    1    General error
    2    Invalid arguments
    3    VM already exists
    4    Insufficient resources
    5    Disk creation failed

EOF
}

# Parse arguments
NAME=""
CPU=""
RAM=""
DISK=""
OS_TEMPLATE=""
BOOT_ISO=""
SSH_KEY="$HOME/.ssh/id_rsa.pub"
NETWORK="bridged"
PREFER=""
AVOID=""
REQUIRE=""
ANTI_AFFINITY=""
AFFINITY=""
POLICY="balanced"
PRIORITY="normal"
AUTO_START="no"
DRY_RUN="no"
VERBOSE="no"

while [ $# -gt 0 ]; do
    case "$1" in
        --name) NAME="$2"; shift 2 ;;
        --cpu) CPU="$2"; shift 2 ;;
        --ram) RAM="$2"; shift 2 ;;
        --disk) DISK="$2"; shift 2 ;;
        --os) OS_TEMPLATE="$2"; shift 2 ;;
        --iso) BOOT_ISO="$2"; shift 2 ;;
        --ssh-key) SSH_KEY="$2"; shift 2 ;;
        --network) NETWORK="$2"; shift 2 ;;
        --prefer) PREFER="$2"; shift 2 ;;
        --avoid) AVOID="$2"; shift 2 ;;
        --require) REQUIRE="$2"; shift 2 ;;
        --anti-affinity) ANTI_AFFINITY="$2"; shift 2 ;;
        --affinity) AFFINITY="$2"; shift 2 ;;
        --policy) POLICY="$2"; shift 2 ;;
        --priority) PRIORITY="$2"; shift 2 ;;
        --auto-start) AUTO_START="yes"; shift ;;
        --dry-run) DRY_RUN="yes"; shift ;;
        --verbose) VERBOSE="yes"; shift ;;
        --help|-h) usage; exit 0 ;;
        --version|-v|version) echo "virtos-create-vm version $VERSION"; exit 0 ;;
        *) echo "Unknown option: $1"; usage; exit 1 ;;
    esac
done

# Validate required arguments
if [ -z "$NAME" ] || [ -z "$CPU" ] || [ -z "$RAM" ] || [ -z "$DISK" ]; then
    echo "${RED}Error: Missing required arguments for VM creation${NC}" >&2
    echo "" >&2
    echo "Required arguments:" >&2
    [ -z "$NAME" ] && echo "  --name <name>     VM name (missing)" >&2 || echo "  --name <name>     VM name: $NAME" >&2
    [ -z "$CPU" ] && echo "  --cpu <count>     Number of vCPUs (missing)" >&2 || echo "  --cpu <count>     Number of vCPUs: $CPU" >&2
    [ -z "$RAM" ] && echo "  --ram <MB>        RAM in MB (missing)" >&2 || echo "  --ram <MB>        RAM in MB: $RAM" >&2
    [ -z "$DISK" ] && echo "  --disk <size>     Disk size (missing)" >&2 || echo "  --disk <size>     Disk size: $DISK" >&2
    echo "" >&2
    echo "Example:" >&2
    echo "  virtos-create-vm --name web-1 --cpu 2 --ram 4096 --disk 20G" >&2
    echo "" >&2
    echo "See 'virtos-create-vm --help' for full usage" >&2
    exit 1
fi

# Validate VM name format (use validation from virtos-common.sh if available)
if command -v validate_vm_name >/dev/null 2>&1; then
    if ! validate_vm_name "$NAME"; then
        echo "${RED}Error: Invalid VM name: $NAME${NC}" >&2
        echo "VM names must contain only letters, numbers, hyphens, and underscores" >&2
        exit 1
    fi
fi

# Validate CPU count is a positive number
if command -v validate_number >/dev/null 2>&1; then
    if ! validate_number "$CPU"; then
        echo "${RED}Error: CPU count must be a positive number: $CPU${NC}" >&2
        exit 1
    fi
else
    # Fallback validation if function not available
    case "$CPU" in
        ''|*[!0-9]*)
            echo "${RED}Error: CPU count must be a positive number: $CPU${NC}" >&2
            exit 1
            ;;
    esac
fi

# Validate CPU is greater than zero
if [ "$CPU" -le 0 ]; then
    echo "${RED}Error: CPU count must be greater than 0: $CPU${NC}" >&2
    exit 1
fi

# Validate RAM is a positive number
if command -v validate_number >/dev/null 2>&1; then
    if ! validate_number "$RAM"; then
        echo "${RED}Error: RAM must be a positive number (in MB): $RAM${NC}" >&2
        exit 1
    fi
else
    # Fallback validation
    case "$RAM" in
        ''|*[!0-9]*)
            echo "${RED}Error: RAM must be a positive number (in MB): $RAM${NC}" >&2
            exit 1
            ;;
    esac
fi

# Validate RAM is greater than zero
if [ "$RAM" -le 0 ]; then
    echo "${RED}Error: RAM must be greater than 0 MB: $RAM${NC}" >&2
    exit 1
fi

# Validate disk size format
if command -v validate_disk_size >/dev/null 2>&1; then
    if ! validate_disk_size "$DISK"; then
        echo "${RED}Error: Invalid disk size format: $DISK${NC}" >&2
        echo "Valid formats: 10G, 500M, 1T" >&2
        exit 1
    fi
else
    # Fallback validation
    case "$DISK" in
        *[0-9][GMTgmt])
            # Valid format
            ;;
        *)
            echo "${RED}Error: Invalid disk size format: $DISK${NC}" >&2
            echo "Valid formats: 10G, 500M, 1T" >&2
            exit 1
            ;;
    esac
fi

# Validate disk size is greater than zero
DISK_NUM=$(echo "$DISK" | sed 's/[^0-9]*//g')
if [ -n "$DISK_NUM" ] && [ "$DISK_NUM" -le 0 ]; then
    echo "${RED}Error: Disk size must be greater than 0: $DISK${NC}" >&2
    exit 1
fi

# Validate network mode
if [ -n "$NETWORK" ]; then
    if command -v validate_network_mode >/dev/null 2>&1; then
        if ! validate_network_mode "$NETWORK"; then
            echo "${RED}Error: Invalid network mode: $NETWORK${NC}" >&2
            echo "Valid modes: bridged, nat, isolated" >&2
            exit 1
        fi
    else
        # Fallback validation
        case "$NETWORK" in
            bridged|nat|isolated)
                # Valid
                ;;
            *)
                echo "${RED}Error: Invalid network mode: $NETWORK${NC}" >&2
                echo "Valid modes: bridged, nat, isolated" >&2
                exit 1
                ;;
        esac
    fi
fi

# Validate policy
case "$POLICY" in
    balanced|packed|spread)
        # Valid
        ;;
    *)
        echo "${RED}Error: Invalid policy: $POLICY${NC}" >&2
        echo "Valid policies: balanced, packed, spread" >&2
        exit 1
        ;;
esac

# Validate priority
case "$PRIORITY" in
    low|normal|high)
        # Valid
        ;;
    *)
        echo "${RED}Error: Invalid priority: $PRIORITY${NC}" >&2
        echo "Valid priorities: low, normal, high" >&2
        exit 1
        ;;
esac

# Validate host names if specified (avoid command injection)
for host_var in "$PREFER" "$AVOID" "$REQUIRE"; do
    if [ -n "$host_var" ]; then
        if command -v validate_hostname >/dev/null 2>&1; then
            if ! validate_hostname "$host_var"; then
                echo "${RED}Error: Invalid hostname: $host_var${NC}" >&2
                exit 1
            fi
        else
            # Fallback: basic hostname validation
            case "$host_var" in
                *[!a-zA-Z0-9.-]*)
                    echo "${RED}Error: Invalid hostname: $host_var${NC}" >&2
                    exit 1
                    ;;
            esac
        fi
    fi
done

# Validate VM names for affinity/anti-affinity (prevent command injection)
for vm_var in "$AFFINITY" "$ANTI_AFFINITY"; do
    if [ -n "$vm_var" ]; then
        if command -v validate_vm_name >/dev/null 2>&1; then
            if ! validate_vm_name "$vm_var"; then
                echo "${RED}Error: Invalid VM name for affinity: $vm_var${NC}" >&2
                exit 1
            fi
        fi
    fi
done

echo "${BLUE}VirtOS IaaS - Automated VM Placement${NC}"
echo "=========================================="
echo ""
echo "Request:"
echo "  Name:     $NAME"
echo "  CPU:      $CPU vCPUs"
echo "  RAM:      $RAM MB"
echo "  Disk:     $DISK"
echo "  Policy:   $POLICY"
echo "  Priority: $PRIORITY"
[ -n "$OS_TEMPLATE" ] && echo "  OS:       $OS_TEMPLATE"
[ -n "$PREFER" ] && echo "  Prefer:   $PREFER"
[ -n "$AVOID" ] && echo "  Avoid:    $AVOID"
[ -n "$REQUIRE" ] && echo "  Require:  $REQUIRE"
[ -n "$ANTI_AFFINITY" ] && echo "  Anti-affinity: $ANTI_AFFINITY"
[ -n "$AFFINITY" ] && echo "  Affinity: $AFFINITY"
echo ""

# If --require specified, skip scheduler
if [ -n "$REQUIRE" ]; then
    echo "${YELLOW}Required host specified: $REQUIRE${NC}"
    echo "Skipping scheduler, using: $REQUIRE"
    SELECTED_HOST="$REQUIRE"
else
    # Run scheduler
    echo "Analyzing cluster..."

    # Use virtos-schedule command
    SCHED_ARGS="--vm $NAME --cpu $CPU --ram $RAM --policy $POLICY"
    [ -n "$PREFER" ] && SCHED_ARGS="$SCHED_ARGS --prefer $PREFER"
    [ -n "$AVOID" ] && SCHED_ARGS="$SCHED_ARGS --avoid $AVOID"
    [ -n "$ANTI_AFFINITY" ] && SCHED_ARGS="$SCHED_ARGS --anti-affinity $ANTI_AFFINITY"
    [ -n "$AFFINITY" ] && SCHED_ARGS="$SCHED_ARGS --affinity $AFFINITY"
    [ "$VERBOSE" = "yes" ] && SCHED_ARGS="$SCHED_ARGS --verbose"

    # Get cluster members
    if [ ! -f /var/run/virtos/cluster-members ]; then
        echo "${RED}Error: Cluster information not available${NC}" >&2
        echo "" >&2
        echo "Reason: Cluster member cache not found" >&2
        echo "  File: /var/run/virtos/cluster-members" >&2
        echo "" >&2
        echo "To resolve:" >&2
        echo "  1. Refresh cluster discovery:" >&2
        echo "     virtos-cluster refresh" >&2
        echo "" >&2
        echo "  2. If clustering is not configured, initialize it:" >&2
        echo "     virtos-cluster init" >&2
        echo "" >&2
        echo "  3. For single-host deployment, use --require localhost:" >&2
        echo "     virtos-create-vm --name $NAME --cpu $CPU --ram $RAM --disk $DISK --require localhost" >&2
        exit 1
    fi

    # Implement scoring algorithm for VM placement
    BEST_SCORE=-1
    SELECTED_HOST=""
    SELECTION_REASON=""

    [ "$VERBOSE" = "yes" ] && echo "Evaluating hosts..."

    while IFS= read -r line; do
        HOST=$(echo "$line" | awk '{print $1}')
        [ -z "$HOST" ] && continue

        # Skip avoided hosts
        if [ -n "$AVOID" ]; then
            echo "$AVOID" | grep -q "$HOST" && continue
        fi

        # Get host resources via virsh or SSH
        if [ "$HOST" = "localhost" ] || [ "$HOST" = "$(hostname)" ]; then
            # Local host - use virsh directly
            TOTAL_MEM=$(free -m | awk '/^Mem:/{print $2}')
            USED_MEM=$(free -m | awk '/^Mem:/{print $3}')
            TOTAL_CPU=$(nproc)
            # Get CPU load average (1 min)
            CPU_LOAD=$(awk '{print int($1 * 100)}' /proc/loadavg)
        else
            # Remote host - use SSH
            TOTAL_MEM=$(ssh -o ConnectTimeout=2 "$HOST" 'free -m | awk "/^Mem:/{print \$2}"' 2>/dev/null || echo "0")
            USED_MEM=$(ssh -o ConnectTimeout=2 "$HOST" 'free -m | awk "/^Mem:/{print \$3}"' 2>/dev/null || echo "0")
            TOTAL_CPU=$(ssh -o ConnectTimeout=2 "$HOST" 'nproc' 2>/dev/null || echo "1")
            CPU_LOAD=$(ssh -o ConnectTimeout=2 "$HOST" 'awk "{print int(\$1 * 100)}" /proc/loadavg' 2>/dev/null || echo "100")
        fi

        # Skip if we couldn't get stats
        [ "$TOTAL_MEM" = "0" ] && continue

        # Calculate available resources
        AVAIL_MEM=$((TOTAL_MEM - USED_MEM))
        AVAIL_CPU_PCT=$((100 - CPU_LOAD / TOTAL_CPU))

        # Check if host has enough resources
        if [ "$AVAIL_MEM" -lt "$RAM" ]; then
            [ "$VERBOSE" = "yes" ] && echo "  $HOST: Insufficient memory ($AVAIL_MEM MB < $RAM MB)"
            continue
        fi

        # Calculate score based on policy
        case "$POLICY" in
            balanced)
                # Balanced: prefer hosts with ~50% utilization
                MEM_UTIL=$((USED_MEM * 100 / TOTAL_MEM))
                MEM_SCORE=$((100 - (MEM_UTIL - 50) * (MEM_UTIL - 50) / 25))  # Peak at 50%
                CPU_SCORE=$AVAIL_CPU_PCT
                SCORE=$(((MEM_SCORE + CPU_SCORE) / 2))
                REASON="balanced load (CPU: ${AVAIL_CPU_PCT}%, MEM: ${AVAIL_MEM}MB)"
                ;;
            pack)
                # Pack: prefer most utilized hosts (bin packing)
                MEM_UTIL=$((USED_MEM * 100 / TOTAL_MEM))
                SCORE=$MEM_UTIL
                REASON="pack strategy (MEM util: ${MEM_UTIL}%)"
                ;;
            spread)
                # Spread: prefer least utilized hosts
                MEM_UTIL=$((USED_MEM * 100 / TOTAL_MEM))
                SCORE=$((100 - MEM_UTIL))
                REASON="spread strategy (MEM avail: ${AVAIL_MEM}MB)"
                ;;
            *)
                # Default: maximize available resources
                MEM_SCORE=$((AVAIL_MEM * 100 / TOTAL_MEM))
                CPU_SCORE=$AVAIL_CPU_PCT
                SCORE=$(((MEM_SCORE + CPU_SCORE) / 2))
                REASON="max available resources"
                ;;
        esac

        # Apply preference bonus
        if [ -n "$PREFER" ]; then
            echo "$PREFER" | grep -q "$HOST" && SCORE=$((SCORE + 20))
        fi

        # Apply affinity bonus
        if [ -n "$AFFINITY" ]; then
            # Check if affinity VM is on this host
            if virsh -c "qemu+ssh://$HOST/system" list --all 2>/dev/null | grep -q "$AFFINITY"; then
                SCORE=$((SCORE + 30))
                REASON="$REASON + affinity with $AFFINITY"
            fi
        fi

        # Apply anti-affinity penalty
        if [ -n "$ANTI_AFFINITY" ]; then
            # Check if anti-affinity VM is on this host
            if virsh -c "qemu+ssh://$HOST/system" list --all 2>/dev/null | grep -q "$ANTI_AFFINITY"; then
                SCORE=$((SCORE - 50))
                [ "$SCORE" -lt 0 ] && SCORE=0
                REASON="$REASON - anti-affinity penalty"
            fi
        fi

        [ "$VERBOSE" = "yes" ] && echo "  $HOST: score=$SCORE ($REASON)"

        # Track best host
        if [ "$SCORE" -gt "$BEST_SCORE" ]; then
            BEST_SCORE=$SCORE
            SELECTED_HOST=$HOST
            SELECTION_REASON=$REASON
        fi
    done < /var/run/virtos/cluster-members

    if [ -z "$SELECTED_HOST" ]; then
        echo "${RED}Error: No suitable host found for VM placement${NC}" >&2
        echo "" >&2
        echo "VM requirements:" >&2
        echo "  CPU:    $CPU vCPUs" >&2
        echo "  RAM:    $RAM MB" >&2
        echo "  Policy: $POLICY" >&2
        echo "" >&2
        echo "Possible reasons:" >&2
        echo "  • All hosts avoided or excluded by affinity constraints" >&2
        echo "  • Insufficient resources (CPU/RAM) on all available hosts" >&2
        echo "  • Unable to contact cluster members (network issues)" >&2
        echo "  • Anti-affinity rules prevent placement" >&2
        echo "" >&2
        echo "To resolve:" >&2
        echo "  1. Check cluster status:" >&2
        echo "     virtos-cluster resources" >&2
        echo "" >&2
        echo "  2. Reduce resource requirements or try different policy:" >&2
        echo "     virtos-create-vm --name $NAME --cpu $((CPU/2)) --ram $((RAM/2)) --disk $DISK --policy spread" >&2
        echo "" >&2
        echo "  3. Force placement on specific host:" >&2
        echo "     virtos-create-vm --name $NAME --cpu $CPU --ram $RAM --disk $DISK --require <hostname>" >&2
        exit 1
    fi

    echo "${GREEN}Selected host: $SELECTED_HOST${NC}"
    echo "  Score:  $BEST_SCORE/100"
    echo "  Reason: $SELECTION_REASON"
fi

echo ""

# Dry run mode - stop here
if [ "$DRY_RUN" = "yes" ]; then
    echo "${YELLOW}Dry run mode - VM not created${NC}"
    echo ""
    echo "Would create VM '$NAME' on $SELECTED_HOST"
    exit 0
fi

# Helper function to generate network interface XML
generate_network_interface() {
    local network_mode="$1"

    case "$network_mode" in
        bridged)
            # Bridge mode - connect to physical bridge
            cat <<EOF
    <interface type='bridge'>
      <source bridge='br0'/>
      <model type='virtio'/>
    </interface>
EOF
            ;;
        nat)
            # NAT mode - use default network
            cat <<EOF
    <interface type='network'>
      <source network='default'/>
      <model type='virtio'/>
    </interface>
EOF
            ;;
        isolated)
            # Isolated mode - use isolated network
            cat <<EOF
    <interface type='network'>
      <source network='isolated'/>
      <model type='virtio'/>
    </interface>
EOF
            ;;
        *)
            # Default to NAT mode
            cat <<EOF
    <interface type='network'>
      <source network='default'/>
      <model type='virtio'/>
    </interface>
EOF
            ;;
    esac
}

# Cloud image support
CLOUD_IMAGE_DIR="${CLOUD_IMAGE_DIR:-/var/lib/virtos/images}"

# Get the download URL for a supported cloud image OS
get_cloud_image_url() {
    local os="$1"
    case "$os" in
        ubuntu-24.04)
            echo "https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
            ;;
        ubuntu-22.04)
            echo "https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img"
            ;;
        ubuntu-20.04)
            echo "https://cloud-images.ubuntu.com/focal/current/focal-server-cloudimg-amd64.img"
            ;;
        debian-12)
            echo "https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-generic-amd64.qcow2"
            ;;
        debian-11)
            echo "https://cloud.debian.org/images/cloud/bullseye/latest/debian-11-generic-amd64.qcow2"
            ;;
        fedora-40)
            echo "https://download.fedoraproject.org/pub/fedora/linux/releases/40/Cloud/x86_64/images/Fedora-Cloud-Base-Generic.x86_64-40-1.14.qcow2"
            ;;
        centos-stream-9)
            echo "https://cloud.centos.org/centos/9-stream/x86_64/images/CentOS-Stream-GenericCloud-9-latest.x86_64.qcow2"
            ;;
        *)
            echo ""
            ;;
    esac
}

# Check whether an OS template is a cloud image type
is_cloud_image_os() {
    local os="$1"
    local url
    url=$(get_cloud_image_url "$os")
    [ -n "$url" ]
}

# Download a cloud image if not already cached
download_cloud_image() {
    local os="$1"
    local image_url
    image_url=$(get_cloud_image_url "$os")

    if [ -z "$image_url" ]; then
        echo "${RED}Error: No cloud image URL for OS: $os${NC}" >&2
        return 1
    fi

    local base_image="$CLOUD_IMAGE_DIR/base-${os}.qcow2"

    # Return cached image if it exists
    if [ -f "$base_image" ]; then
        echo "$base_image"
        return 0
    fi

    # Create image cache directory
    mkdir -p "$CLOUD_IMAGE_DIR"

    echo "  Downloading cloud image for $os..."
    echo "  URL: $image_url"

    # Download to a temporary file first so partial downloads do not leave
    # a corrupt cached image behind
    local tmp_image="${base_image}.download"

    if command -v wget >/dev/null 2>&1; then
        if ! wget -q --show-progress -O "$tmp_image" "$image_url" 2>&1; then
            rm -f "$tmp_image"
            echo "${RED}Error: Failed to download cloud image${NC}" >&2
            echo "  URL: $image_url" >&2
            echo "  Ensure you have network connectivity and the URL is valid" >&2
            return 1
        fi
    elif command -v curl >/dev/null 2>&1; then
        if ! curl -fL --progress-bar -o "$tmp_image" "$image_url" 2>&1; then
            rm -f "$tmp_image"
            echo "${RED}Error: Failed to download cloud image${NC}" >&2
            echo "  URL: $image_url" >&2
            echo "  Ensure you have network connectivity and the URL is valid" >&2
            return 1
        fi
    else
        echo "${RED}Error: Neither wget nor curl found. Cannot download cloud image.${NC}" >&2
        echo "  Install wget or curl, then retry." >&2
        return 1
    fi

    # Verify the download produced a valid qcow2 (or raw) image
    if ! qemu-img info "$tmp_image" >/dev/null 2>&1; then
        rm -f "$tmp_image"
        echo "${RED}Error: Downloaded file is not a valid disk image${NC}" >&2
        return 1
    fi

    # Convert to qcow2 if the source is raw (some Ubuntu images are raw .img)
    local src_format
    src_format=$(qemu-img info --output=json "$tmp_image" 2>/dev/null | grep '"format"' | head -1 | sed 's/.*: "//;s/".*//')
    if [ "$src_format" = "raw" ]; then
        echo "  Converting raw image to qcow2..."
        if ! qemu-img convert -f raw -O qcow2 "$tmp_image" "$base_image"; then
            rm -f "$tmp_image" "$base_image"
            echo "${RED}Error: Failed to convert image to qcow2${NC}" >&2
            return 1
        fi
        rm -f "$tmp_image"
    else
        mv "$tmp_image" "$base_image"
    fi

    echo "  Cloud image cached: $base_image"
    echo "$base_image"
}

# Create a VM disk as a copy-on-write overlay on top of a base cloud image
create_disk_from_cloud_image() {
    local base_image="$1"
    local vm_disk="$2"
    local size="$3"

    if [ ! -f "$base_image" ]; then
        echo "${RED}Error: Base image not found: $base_image${NC}" >&2
        return 1
    fi

    # Determine the format of the base image (usually qcow2)
    local base_format
    base_format=$(qemu-img info --output=json "$base_image" 2>/dev/null | grep '"format"' | head -1 | sed 's/.*: "//;s/".*//')
    base_format="${base_format:-qcow2}"

    # Create a copy-on-write overlay disk backed by the base image
    if ! qemu-img create -f qcow2 -F "$base_format" -b "$base_image" "$vm_disk" "$size"; then
        echo "${RED}Error: Failed to create disk from cloud image${NC}" >&2
        return 1
    fi

    echo "  Created CoW disk: $vm_disk (backed by $base_image)"
}

# Create the VM
echo "Creating VM on $SELECTED_HOST..."

# Generate VM XML using templates or built-in profiles
VM_DIR="/var/lib/virtos/vms/$NAME"
mkdir -p "$VM_DIR"

# Check if we should use virtos-template for cloning
if [ -n "$OS_TEMPLATE" ] && command -v virtos-template >/dev/null 2>&1; then
    TEMPLATE_DIR="${TEMPLATE_DIR:-/var/lib/virtos/templates}"

    if [ -d "$TEMPLATE_DIR/$OS_TEMPLATE" ]; then
        echo "Using template: $OS_TEMPLATE"
        virtos-template clone "$OS_TEMPLATE" "$NAME"

        # Adjust resources if needed
        virsh setvcpus "$NAME" "$CPU" --config --maximum
        virsh setvcpus "$NAME" "$CPU" --config
        virsh setmaxmem "$NAME" "$RAM" --config
        virsh setmem "$NAME" "$RAM" --config

        echo "${GREEN}VM created from template: $OS_TEMPLATE${NC}"
        exit 0
    else
        echo "${YELLOW}Warning: Template '$OS_TEMPLATE' not found, using built-in profile${NC}"
    fi
fi

# Use built-in VM profiles if OS template specified
case "${OS_TEMPLATE:-default}" in
    minimal)
        # Minimal VM profile - console only, no graphics
        cat > "$VM_DIR/$NAME.xml" << EOF
<domain type='kvm'>
  <name>$NAME</name>
  <memory unit='MiB'>$RAM</memory>
  <vcpu>$CPU</vcpu>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='cdrom'/>
    <boot dev='hd'/>
  </os>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='$VM_DIR/$NAME.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
EOF
        # Add CDROM if ISO specified
        if [ -n "$BOOT_ISO" ]; then
            cat >> "$VM_DIR/$NAME.xml" << EOF
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='$BOOT_ISO'/>
      <target dev='hdc' bus='ide'/>
      <readonly/>
    </disk>
EOF
        fi
        cat >> "$VM_DIR/$NAME.xml" <<EOF
$(generate_network_interface "$NETWORK")
    <serial type='pty'>
      <target port='0'/>
    </serial>
    <console type='pty'>
      <target type='serial' port='0'/>
    </console>
  </devices>
</domain>
EOF
        ;;

    performance)
        # Performance-optimized VM profile
        cat > "$VM_DIR/$NAME.xml" << EOF
<domain type='kvm'>
  <name>$NAME</name>
  <memory unit='MiB'>$RAM</memory>
  <vcpu placement='static'>$CPU</vcpu>
  <cpu mode='host-passthrough' check='none'/>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='cdrom'/>
    <boot dev='hd'/>
  </os>
  <features>
    <acpi/>
    <apic/>
  </features>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' cache='none' io='native'/>
      <source file='$VM_DIR/$NAME.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
EOF
        # Add CDROM if ISO specified
        if [ -n "$BOOT_ISO" ]; then
            cat >> "$VM_DIR/$NAME.xml" << EOF
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='$BOOT_ISO'/>
      <target dev='hdc' bus='ide'/>
      <readonly/>
    </disk>
EOF
        fi
        # Network interface with performance optimizations
        cat >> "$VM_DIR/$NAME.xml" <<EOF
    <interface type='$([ "$NETWORK" = "bridged" ] && echo "bridge" || echo "network")'>
      <source $([ "$NETWORK" = "bridged" ] && echo "bridge='br0'" || echo "network='default'")/>
      <model type='virtio'/>
      <driver name='vhost' queues='$CPU'/>
    </interface>
    <graphics type='vnc' port='-1'/>
    <serial type='pty'>
      <target port='0'/>
    </serial>
    <console type='pty'>
      <target type='serial' port='0'/>
    </console>
  </devices>
</domain>
EOF
        ;;

    secure)
        # Security-hardened VM profile
        cat > "$VM_DIR/$NAME.xml" << EOF
<domain type='kvm'>
  <name>$NAME</name>
  <memory unit='MiB'>$RAM</memory>
  <vcpu>$CPU</vcpu>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='cdrom'/>
    <boot dev='hd'/>
  </os>
  <features>
    <acpi/>
    <smm state='on'>
      <tseg unit='MiB'>16</tseg>
    </smm>
  </features>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2' discard='unmap'/>
      <source file='$VM_DIR/$NAME.qcow2'/>
      <target dev='vda' bus='virtio'/>
      <encryption format='luks'>
        <secret type='passphrase'/>
      </encryption>
    </disk>
EOF
        # Add CDROM if ISO specified
        if [ -n "$BOOT_ISO" ]; then
            cat >> "$VM_DIR/$NAME.xml" << EOF
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='$BOOT_ISO'/>
      <target dev='hdc' bus='ide'/>
      <readonly/>
    </disk>
EOF
        fi
        # Network interface with security filter
        cat >> "$VM_DIR/$NAME.xml" <<EOF
    <interface type='$([ "$NETWORK" = "bridged" ] && echo "bridge" || echo "network")'>
      <source $([ "$NETWORK" = "bridged" ] && echo "bridge='br0'" || echo "network='default'")/>
      <model type='virtio'/>
      <filterref filter='clean-traffic'/>
    </interface>
    <graphics type='vnc' port='-1'>
      <listen type='address' address='127.0.0.1'/>
    </graphics>
    <rng model='virtio'>
      <backend model='random'>/dev/urandom</backend>
    </rng>
    <serial type='pty'>
      <target port='0'/>
    </serial>
    <console type='pty'>
      <target type='serial' port='0'/>
    </console>
  </devices>
</domain>
EOF
        ;;

    default|*)
        # Standard VM profile - balanced configuration
        cat > "$VM_DIR/$NAME.xml" << EOF
<domain type='kvm'>
  <name>$NAME</name>
  <memory unit='MiB'>$RAM</memory>
  <vcpu>$CPU</vcpu>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='cdrom'/>
    <boot dev='hd'/>
  </os>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='$VM_DIR/$NAME.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
EOF
        # Add CDROM if ISO specified
        if [ -n "$BOOT_ISO" ]; then
            cat >> "$VM_DIR/$NAME.xml" << EOF
    <disk type='file' device='cdrom'>
      <driver name='qemu' type='raw'/>
      <source file='$BOOT_ISO'/>
      <target dev='hdc' bus='ide'/>
      <readonly/>
    </disk>
EOF
        fi
        cat >> "$VM_DIR/$NAME.xml" <<EOF
$(generate_network_interface "$NETWORK")
    <graphics type='vnc' port='-1'/>
    <serial type='pty'>
      <target port='0'/>
    </serial>
    <console type='pty'>
      <target type='serial' port='0'/>
    </console>
  </devices>
</domain>
EOF
        ;;
esac

# Create disk - use cloud image if applicable, otherwise create blank
echo "Creating disk..."
if [ -n "$OS_TEMPLATE" ] && is_cloud_image_os "$OS_TEMPLATE"; then
    echo "  Using cloud image for OS: $OS_TEMPLATE"
    BASE_IMAGE=$(download_cloud_image "$OS_TEMPLATE") || exit 5
    # The last line of download_cloud_image output is the path
    BASE_IMAGE=$(echo "$BASE_IMAGE" | tail -1)
    create_disk_from_cloud_image "$BASE_IMAGE" "$VM_DIR/$NAME.qcow2" "$DISK" || exit 5
    echo "${GREEN}  Disk created from $OS_TEMPLATE cloud image${NC}"
else
    qemu-img create -f qcow2 "$VM_DIR/$NAME.qcow2" "$DISK"
    if [ -z "$BOOT_ISO" ] && [ -z "$OS_TEMPLATE" ]; then
        echo "${YELLOW}  Warning: Creating blank disk with no OS and no --iso specified${NC}" >&2
        echo "${YELLOW}  The VM will have no bootable media. Consider using --os or --iso.${NC}" >&2
    fi
fi

# Generate cloud-init ISO with SSH key if specified
if [ -n "$SSH_KEY" ] && [ -f "$SSH_KEY" ]; then
    echo "Generating cloud-init ISO with SSH key..."

    # Check if virtos-cloud-init is available
    if command -v virtos-cloud-init >/dev/null 2>&1; then
        # Use virtos-cloud-init to generate configuration
        virtos-cloud-init create "$NAME" \
            --hostname "$NAME" \
            --user tc \
            --ssh-key "$SSH_KEY"

        # Generate the ISO
        virtos-cloud-init generate "$NAME"

        CLOUD_INIT_ISO="/var/lib/virtos/cloud-init/${NAME}-cloud-init.iso"

        # Add cloud-init ISO as second CDROM if it was generated successfully
        if [ -f "$CLOUD_INIT_ISO" ]; then
            echo "  Cloud-init ISO generated: $CLOUD_INIT_ISO"

            # Modify VM XML to include cloud-init ISO as second CDROM
            # This will be inserted before the closing </devices> tag
            sed -i "/<\/devices>/i\\    <disk type='file' device='cdrom'>\\n      <driver name='qemu' type='raw'/>\\n      <source file='$CLOUD_INIT_ISO'/>\\n      <target dev='hdd' bus='ide'/>\\n      <readonly/>\\n    </disk>" "$VM_DIR/$NAME.xml"

            echo "  Cloud-init ISO attached as second CDROM"
        else
            echo "${YELLOW}Warning: Cloud-init ISO generation failed${NC}" >&2
        fi
    else
        echo "${YELLOW}Warning: virtos-cloud-init not found, SSH key will not be injected${NC}" >&2
        echo "  Install virtos-cloud-init or manually configure SSH access" >&2
    fi
elif [ -n "$SSH_KEY" ] && [ ! -f "$SSH_KEY" ]; then
    echo "${YELLOW}Warning: SSH key file not found: $SSH_KEY${NC}" >&2
fi

# Define VM on selected host
echo "Defining VM on $SELECTED_HOST..."

if [ "$SELECTED_HOST" = "$(hostname)" ] || [ "$SELECTED_HOST" = "localhost" ]; then
    # Local host
    virsh define "$VM_DIR/$NAME.xml"
else
    # Remote host
    virsh -c "qemu+ssh://root@$SELECTED_HOST.local/system" define "$VM_DIR/$NAME.xml"
fi

echo ""
echo "${GREEN}VM '$NAME' created successfully on $SELECTED_HOST${NC}"
echo ""

# Auto-start if requested
if [ "$AUTO_START" = "yes" ]; then
    echo "Starting VM..."
    if [ "$SELECTED_HOST" = "$(hostname)" ] || [ "$SELECTED_HOST" = "localhost" ]; then
        virsh start "$NAME"
    else
        virsh -c "qemu+ssh://root@$SELECTED_HOST.local/system" start "$NAME"
    fi
    echo "${GREEN}VM started${NC}"
fi

# Show connection info
echo "Connect to VM:"
if [ "$SELECTED_HOST" = "$(hostname)" ] || [ "$SELECTED_HOST" = "localhost" ]; then
    echo "  virsh console $NAME"
else
    echo "  virsh -c qemu+ssh://root@$SELECTED_HOST.local/system console $NAME"
fi
echo ""
echo "Manage via virt-manager:"
echo "  virt-manager -c qemu+ssh://root@$SELECTED_HOST.local/system"
echo ""
