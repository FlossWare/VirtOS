                        virtos-ha failover "$VM_NAME" "$DEST_HOST" 2>&1 | \
                            $DIALOG $DIALOG_OPTS --title "Failover Progress" --programbox 20 76
                        $DIALOG $DIALOG_OPTS --msgbox "Failover operation completed" 6 50
                    fi
                fi
            fi
            ha_menu
            ;;
        6)
            virtos-ha start-daemon 2>&1 | \
                $DIALOG $DIALOG_OPTS --title "Starting HA Daemon" --programbox 15 76
            $DIALOG $DIALOG_OPTS --msgbox "HA daemon started" 6 40
