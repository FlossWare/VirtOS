iaas_vm_create_menu() {
    if ! command -v virtos-create-vm >/dev/null 2>&1; then
        $DIALOG $DIALOG_OPTS --msgbox "virtos-create-vm not installed" 6 40
        main_menu
        return
    fi

    $DIALOG $DIALOG_OPTS \
        --title "IaaS VM Creation Wizard" \
        --msgbox "Create a VM with automatic placement across the cluster.\n\nThe system will analyze resources and select the optimal host." 10 70

    # Get VM name
    $DIALOG $DIALOG_OPTS \
        --title "VM Name" \
        --inputbox "Enter VM name:" 10 60 \
        2> $TEMP_FILE
    VM_NAME=$(cat $TEMP_FILE)

    if [ -z "$VM_NAME" ]; then
        main_menu
        return
    fi

    # Get CPU count
    $DIALOG $DIALOG_OPTS \
        --title "CPU Cores" \
        --inputbox "Enter number of CPU cores:" 10 60 "2" \
        2> $TEMP_FILE
    CPU_COUNT=$(cat $TEMP_FILE)

    # Get RAM in MB
    $DIALOG $DIALOG_OPTS \
        --title "Memory (RAM)" \
        --inputbox "Enter RAM in MB:" 10 60 "4096" \
        2> $TEMP_FILE
    RAM_MB=$(cat $TEMP_FILE)

    # Get disk size
    $DIALOG $DIALOG_OPTS \
        --title "Disk Size" \
        --inputbox "Enter disk size (e.g., 20G, 50G, 100G):" 10 60 "20G" \
        2> $TEMP_FILE
    DISK_SIZE=$(cat $TEMP_FILE)

    # Select scheduling policy
    $DIALOG $DIALOG_OPTS \
        --title "Scheduling Policy" \
        --menu "Select VM placement policy:" 15 70 4 \
        1 "Balanced (default - even distribution)" \
        2 "Packed (maximize host utilization)" \
        3 "Spread (minimize VMs per host)" \
        2> $TEMP_FILE
    POLICY_CHOICE=$(cat $TEMP_FILE)

    case $POLICY_CHOICE in
        2) POLICY="packed" ;;
        3) POLICY="spread" ;;
        *) POLICY="balanced" ;;
    esac

    # Select priority
    $DIALOG $DIALOG_OPTS \
        --title "VM Priority" \
        --menu "Select VM priority:" 12 60 3 \
        1 "Normal" \
        2 "High" \
        3 "Low" \
        2> $TEMP_FILE
    PRIORITY_CHOICE=$(cat $TEMP_FILE)

    case $PRIORITY_CHOICE in
        2) PRIORITY="high" ;;
        3) PRIORITY="low" ;;
        *) PRIORITY="normal" ;;
    esac

    # Optional: OS template
    $DIALOG $DIALOG_OPTS \
        --title "OS Template" \
        --inputbox "Enter OS template (optional, press Enter to skip):\n(e.g., ubuntu-22.04, debian-12)" 12 70 \
        2> $TEMP_FILE
    OS_TEMPLATE=$(cat $TEMP_FILE)

    # Dry run first
    $DIALOG $DIALOG_OPTS \
        --title "Preview Placement" \
        --yesno "Run a dry-run to see where the VM would be placed?\n\n(Recommended before creating)" 10 70

    if [ $? -eq 0 ]; then
        if [ -n "$OS_TEMPLATE" ]; then
            virtos-create-vm --name "$VM_NAME" --cpu "$CPU_COUNT" --ram "$RAM_MB" --disk "$DISK_SIZE" --policy "$POLICY" --priority "$PRIORITY" --os "$OS_TEMPLATE" --dry-run 2>&1 | \
                $DIALOG $DIALOG_OPTS --title "Placement Preview" --programbox 20 100
        else
            virtos-create-vm --name "$VM_NAME" --cpu "$CPU_COUNT" --ram "$RAM_MB" --disk "$DISK_SIZE" --policy "$POLICY" --priority "$PRIORITY" --dry-run 2>&1 | \
                $DIALOG $DIALOG_OPTS --title "Placement Preview" --programbox 20 100
        fi

        $DIALOG $DIALOG_OPTS \
            --title "Create VM" \
            --yesno "Proceed with VM creation?" 8 50

        if [ $? -ne 0 ]; then
            main_menu
            return
        fi
    fi

    # Create VM
    $DIALOG $DIALOG_OPTS \
        --title "Creating VM" \
        --infobox "Creating VM '$VM_NAME' on optimal host...\n\nPlease wait..." 8 60

    if [ -n "$OS_TEMPLATE" ]; then
        virtos-create-vm --name "$VM_NAME" --cpu "$CPU_COUNT" --ram "$RAM_MB" --disk "$DISK_SIZE" --policy "$POLICY" --priority "$PRIORITY" --os "$OS_TEMPLATE" > /tmp/iaas-result.txt 2>&1
    else
        virtos-create-vm --name "$VM_NAME" --cpu "$CPU_COUNT" --ram "$RAM_MB" --disk "$DISK_SIZE" --policy "$POLICY" --priority "$PRIORITY" > /tmp/iaas-result.txt 2>&1
    fi

    # Show result
    RESULT=$(cat /tmp/iaas-result.txt)
    rm -f /tmp/iaas-result.txt

    $DIALOG $DIALOG_OPTS \
        --title "VM Creation Result" \
        --msgbox "$RESULT\n\nVM '$VM_NAME' has been created and placed on the optimal host." 15 80

    main_menu
}

snapshots_menu() {
    if ! command -v virtos-snapshot >/dev/null 2>&1; then
        $DIALOG $DIALOG_OPTS --msgbox "virtos-snapshot not installed" 6 40
        main_menu
        return
    fi

    $DIALOG $DIALOG_OPTS \
        --title "VM Snapshots" \
        --menu "Select option:" 18 76 8 \
        1 "List Snapshots for VM" \
        2 "Create Snapshot" \
        3 "Revert to Snapshot" \
        4 "Delete Snapshot" \
        5 "Schedule Automatic Snapshots" \
        6 "Cleanup Old Snapshots" \
        0 "Back" \
        2> $TEMP_FILE

    CHOICE=$(cat $TEMP_FILE)

    case $CHOICE in
        1)
            # Get VM name
            $DIALOG $DIALOG_OPTS \
                --title "List Snapshots" \
                --inputbox "Enter VM name:" 10 60 \
                2> $TEMP_FILE
            VM_NAME=$(cat $TEMP_FILE)

            if [ -n "$VM_NAME" ]; then
                $DIALOG $DIALOG_OPTS \
                    --title "Snapshots for $VM_NAME" \
                    --msgbox "$(virtos-snapshot list "$VM_NAME" 2>&1)" 25 100
            fi
            snapshots_menu
            ;;
        2)
            # Get VM name
            $DIALOG $DIALOG_OPTS \
                --title "Create Snapshot" \
                --inputbox "Enter VM name:" 10 60 \
                2> $TEMP_FILE
            VM_NAME=$(cat $TEMP_FILE)

            if [ -n "$VM_NAME" ]; then
                # Get description
                $DIALOG $DIALOG_OPTS \
                    --title "Snapshot Description" \
                    --inputbox "Enter description (optional):" 10 60 "Manual snapshot" \
                    2> $TEMP_FILE
                DESCRIPTION=$(cat $TEMP_FILE)

                # Ask for snapshot type
                $DIALOG $DIALOG_OPTS \
                    --title "Snapshot Type" \
                    --menu "Select snapshot type:" 12 60 2 \
                    1 "Disk-only (faster, no RAM state)" \
                    2 "Full (includes RAM state)" \
                    2> $TEMP_FILE
                TYPE_CHOICE=$(cat $TEMP_FILE)

                if [ "$TYPE_CHOICE" = "2" ]; then
                    virtos-snapshot create "$VM_NAME" "$DESCRIPTION" --memory 2>&1 | \
                        $DIALOG $DIALOG_OPTS --title "Creating Snapshot" --programbox 15 76
                else
                    virtos-snapshot create "$VM_NAME" "$DESCRIPTION" --disk-only 2>&1 | \
                        $DIALOG $DIALOG_OPTS --title "Creating Snapshot" --programbox 15 76
                fi

                $DIALOG $DIALOG_OPTS --msgbox "Snapshot created" 6 40
            fi
            snapshots_menu
            ;;
        3)
            # Get VM name
            $DIALOG $DIALOG_OPTS \
                --title "Revert Snapshot" \
                --inputbox "Enter VM name:" 10 60 \
                2> $TEMP_FILE
            VM_NAME=$(cat $TEMP_FILE)

            if [ -n "$VM_NAME" ]; then
                # Show available snapshots
                SNAPSHOTS=$(virtos-snapshot list "$VM_NAME" 2>&1)

                # Get snapshot name
                $DIALOG $DIALOG_OPTS \
                    --title "Select Snapshot" \
                    --inputbox "Enter snapshot name:\n\n$SNAPSHOTS" 25 100 \
                    2> $TEMP_FILE
                SNAPSHOT_NAME=$(cat $TEMP_FILE)

                if [ -n "$SNAPSHOT_NAME" ]; then
                    $DIALOG $DIALOG_OPTS \
                        --title "Confirm Revert" \
                        --yesno "Revert VM '$VM_NAME' to snapshot '$SNAPSHOT_NAME'?\n\nCurrent state will be lost!" 10 70

                    if [ $? -eq 0 ]; then
                        virtos-snapshot revert "$VM_NAME" "$SNAPSHOT_NAME" 2>&1 | \
                            $DIALOG $DIALOG_OPTS --title "Reverting" --programbox 15 76
                        $DIALOG $DIALOG_OPTS --msgbox "VM reverted to snapshot" 6 40
                    fi
                fi
            fi
            snapshots_menu
            ;;
        4)
            # Get VM name
            $DIALOG $DIALOG_OPTS \
                --title "Delete Snapshot" \
                --inputbox "Enter VM name:" 10 60 \
                2> $TEMP_FILE
            VM_NAME=$(cat $TEMP_FILE)

            if [ -n "$VM_NAME" ]; then
                # Show available snapshots
                SNAPSHOTS=$(virtos-snapshot list "$VM_NAME" 2>&1)

                # Get snapshot name
                $DIALOG $DIALOG_OPTS \
                    --title "Select Snapshot" \
                    --inputbox "Enter snapshot name to delete:\n\n$SNAPSHOTS" 25 100 \
                    2> $TEMP_FILE
                SNAPSHOT_NAME=$(cat $TEMP_FILE)

                if [ -n "$SNAPSHOT_NAME" ]; then
                    $DIALOG $DIALOG_OPTS \
                        --title "Confirm Delete" \
                        --yesno "Delete snapshot '$SNAPSHOT_NAME'?\n\nThis cannot be undone!" 10 60

                    if [ $? -eq 0 ]; then
                        virtos-snapshot delete "$VM_NAME" "$SNAPSHOT_NAME" 2>&1 | \
                            $DIALOG $DIALOG_OPTS --title "Deleting Snapshot" --programbox 15 76
                        $DIALOG $DIALOG_OPTS --msgbox "Snapshot deleted" 6 40
                    fi
                fi
            fi
            snapshots_menu
            ;;
        5)
            # Get VM name
            $DIALOG $DIALOG_OPTS \
                --title "Schedule Snapshots" \
                --inputbox "Enter VM name:" 10 60 \
                2> $TEMP_FILE
            VM_NAME=$(cat $TEMP_FILE)

            if [ -n "$VM_NAME" ]; then
                # Select schedule type
                $DIALOG $DIALOG_OPTS \
                    --title "Snapshot Schedule" \
                    --menu "Select schedule frequency:" 12 60 2 \
                    1 "Hourly" \
                    2 "Daily" \
                    2> $TEMP_FILE
                SCHED_CHOICE=$(cat $TEMP_FILE)

                case $SCHED_CHOICE in
                    1)
                        # Get retention count
                        $DIALOG $DIALOG_OPTS \
                            --title "Retention Policy" \
                            --inputbox "Keep last N snapshots:" 10 60 "7" \
                            2> $TEMP_FILE
                        KEEP_COUNT=$(cat $TEMP_FILE)

                        virtos-snapshot schedule "$VM_NAME" --hourly --keep "$KEEP_COUNT" 2>&1 | \
                            $DIALOG $DIALOG_OPTS --title "Schedule Result" --programbox 15 76
                        ;;
                    2)
                        # Get time
                        $DIALOG $DIALOG_OPTS \
                            --title "Daily Snapshot Time" \
                            --inputbox "Enter time (HH:MM, e.g., 02:00):" 10 60 "02:00" \
                            2> $TEMP_FILE
                        SNAPSHOT_TIME=$(cat $TEMP_FILE)

                        # Get retention count
