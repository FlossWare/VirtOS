jplatform_menu() {
    # Check if JPlatform is installed
    if ! command -v jplatform >/dev/null 2>&1; then
        $DIALOG $DIALOG_OPTS \
            --title "JPlatform Not Installed" \
            --yesno "JPlatform is not installed. Would you like to install it now?" 8 60

        if [ $? -eq 0 ]; then
            clear
            echo "Installing JPlatform..."
            virtos-jplatform-install
            read -p "Press Enter to continue..."
        fi
        main_menu
        return
    fi

    # Get JPlatform status
    local jplatform_status=$(jplatform status 2>&1 || echo "Unable to get status")

    $DIALOG $DIALOG_OPTS \
        --title "JPlatform Workload Management" \
        --menu "Unified orchestration for VMs, containers, Java apps, and native binaries\n\nSelect action:" 22 76 12 \
        1 "List All Workloads" \
        2 "Deploy Workload (from YAML)" \
        3 "Start Workload" \
        4 "Stop Workload" \
        5 "Restart Workload" \
        6 "View Workload Status" \
        7 "View Workload Metrics" \
        8 "View Workload Logs" \
        9 "Undeploy Workload" \
        10 "Deploy Example VM" \
        11 "Deploy Example Container" \
        12 "JPlatform Info" \
        0 "Back" \
        2> $TEMP_FILE

    CHOICE=$(cat $TEMP_FILE)

    case $CHOICE in
        1)
            # List all workloads
            $DIALOG $DIALOG_OPTS \
                --title "JPlatform Workloads" \
                --msgbox "$(jplatform status 2>&1)" 25 100
            jplatform_menu
            ;;
        2)
            # Deploy from YAML
            $DIALOG $DIALOG_OPTS \
                --title "Deploy Workload" \
                --inputbox "Enter path to YAML descriptor:" 8 76 2> $TEMP_FILE
            YAML_PATH=$(cat $TEMP_FILE)

            if [ -n "$YAML_PATH" ] && [ -f "$YAML_PATH" ]; then
                clear
                echo "Deploying workload from $YAML_PATH..."
                jplatform deploy "$YAML_PATH"
                echo ""
                read -p "Press Enter to continue..."
            elif [ -n "$YAML_PATH" ]; then
                $DIALOG $DIALOG_OPTS --msgbox "File not found: $YAML_PATH" 6 50
            fi
            jplatform_menu
            ;;
        3)
            # Start workload
            $DIALOG $DIALOG_OPTS \
                --title "Start Workload" \
                --inputbox "Enter workload ID:" 8 50 2> $TEMP_FILE
            WORKLOAD_ID=$(cat $TEMP_FILE)

            if [ -n "$WORKLOAD_ID" ]; then
                clear
                echo "Starting $WORKLOAD_ID..."
                jplatform start "$WORKLOAD_ID"
                echo ""
                read -p "Press Enter to continue..."
            fi
            jplatform_menu
            ;;
        4)
            # Stop workload
            $DIALOG $DIALOG_OPTS \
                --title "Stop Workload" \
                --inputbox "Enter workload ID:" 8 50 2> $TEMP_FILE
            WORKLOAD_ID=$(cat $TEMP_FILE)

            if [ -n "$WORKLOAD_ID" ]; then
                clear
                echo "Stopping $WORKLOAD_ID..."
                jplatform stop "$WORKLOAD_ID"
                echo ""
                read -p "Press Enter to continue..."
            fi
            jplatform_menu
            ;;
        5)
            # Restart workload
            $DIALOG $DIALOG_OPTS \
                --title "Restart Workload" \
                --inputbox "Enter workload ID:" 8 50 2> $TEMP_FILE
            WORKLOAD_ID=$(cat $TEMP_FILE)

            if [ -n "$WORKLOAD_ID" ]; then
                clear
                echo "Restarting $WORKLOAD_ID..."
                jplatform restart "$WORKLOAD_ID"
                echo ""
                read -p "Press Enter to continue..."
            fi
            jplatform_menu
            ;;
        6)
            # View status
            $DIALOG $DIALOG_OPTS \
                --title "Workload Status" \
                --inputbox "Enter workload ID:" 8 50 2> $TEMP_FILE
            WORKLOAD_ID=$(cat $TEMP_FILE)

            if [ -n "$WORKLOAD_ID" ]; then
                $DIALOG $DIALOG_OPTS \
                    --title "Status: $WORKLOAD_ID" \
                    --msgbox "$(jplatform status "$WORKLOAD_ID" 2>&1)" 25 100
            fi
            jplatform_menu
            ;;
        7)
            # View metrics
            $DIALOG $DIALOG_OPTS \
                --title "Workload Metrics" \
                --inputbox "Enter workload ID:" 8 50 2> $TEMP_FILE
            WORKLOAD_ID=$(cat $TEMP_FILE)

            if [ -n "$WORKLOAD_ID" ]; then
                $DIALOG $DIALOG_OPTS \
                    --title "Metrics: $WORKLOAD_ID" \
                    --msgbox "$(jplatform metrics "$WORKLOAD_ID" 2>&1)" 25 100
            fi
            jplatform_menu
            ;;
        8)
            # View logs
            $DIALOG $DIALOG_OPTS \
                --title "Workload Logs" \
                --inputbox "Enter workload ID:" 8 50 2> $TEMP_FILE
            WORKLOAD_ID=$(cat $TEMP_FILE)

            if [ -n "$WORKLOAD_ID" ]; then
                clear
                echo "=== Logs for $WORKLOAD_ID ==="
                jplatform logs "$WORKLOAD_ID"
                echo ""
                read -p "Press Enter to continue..."
            fi
            jplatform_menu
            ;;
        9)
            # Undeploy
            $DIALOG $DIALOG_OPTS \
                --title "Undeploy Workload" \
                --inputbox "Enter workload ID:" 8 50 2> $TEMP_FILE
            WORKLOAD_ID=$(cat $TEMP_FILE)

            if [ -n "$WORKLOAD_ID" ]; then
                $DIALOG $DIALOG_OPTS \
                    --title "Confirm" \
                    --yesno "Undeploy $WORKLOAD_ID? This will remove it permanently." 8 60

                if [ $? -eq 0 ]; then
                    clear
                    echo "Undeploying $WORKLOAD_ID..."
                    jplatform undeploy "$WORKLOAD_ID"
                    echo ""
                    read -p "Press Enter to continue..."
                fi
            fi
            jplatform_menu
            ;;
        10)
            # Deploy example VM
            EXAMPLE_VM="/tmp/example-vm-$$.yaml"
            cat > "$EXAMPLE_VM" << 'EOF'
applicationId: example-vm
name: Example Virtual Machine
properties:
  vm.vcpu: "2"
  vm.memory: "4096"
  vm.disk: "/var/lib/jplatform/vms/example-vm.qcow2"
  vm.network: "bridge"
resources:
  cpu: 2
  memory: 4096
EOF

            $DIALOG $DIALOG_OPTS \
                --title "Example VM" \
                --yesno "Deploy example VM?\n\nID: example-vm\nCPU: 2 vCPUs\nRAM: 4096 MB\nDisk: /var/lib/jplatform/vms/example-vm.qcow2\n\nNote: You must create the disk image first:\n  qemu-img create -f qcow2 /var/lib/jplatform/vms/example-vm.qcow2 20G" 16 76

            if [ $? -eq 0 ]; then
                clear
                echo "Deploying example VM..."
                jplatform deploy "$EXAMPLE_VM"
                echo ""
                echo "To start: jplatform start example-vm"
                echo ""
                read -p "Press Enter to continue..."
            fi
            rm -f "$EXAMPLE_VM"
            jplatform_menu
            ;;
        11)
            # Deploy example container
            EXAMPLE_CONTAINER="/tmp/example-container-$$.yaml"
            cat > "$EXAMPLE_CONTAINER" << 'EOF'
applicationId: nginx-web
name: NGINX Web Server
properties:
  container.image: "nginx:alpine"
  container.runtime: "docker"
  container.ports: "8080:80"
EOF

            $DIALOG $DIALOG_OPTS \
                --title "Example Container" \
                --yesno "Deploy example NGINX container?\n\nID: nginx-web\nImage: nginx:alpine\nPort: 8080 -> 80" 10 60

            if [ $? -eq 0 ]; then
                clear
                echo "Deploying NGINX container..."
                jplatform deploy "$EXAMPLE_CONTAINER"
                echo ""
                echo "To start: jplatform start nginx-web"
                echo "Access: http://localhost:8080"
                echo ""
                read -p "Press Enter to continue..."
            fi
            rm -f "$EXAMPLE_CONTAINER"
            jplatform_menu
            ;;
        12)
            # JPlatform info
            $DIALOG $DIALOG_OPTS \
                --title "JPlatform Info" \
                --msgbox "$(virtos-jplatform-info 2>&1)" 25 76
            jplatform_menu
            ;;
        0) main_menu ;;
        *) jplatform_menu ;;
    esac
}

