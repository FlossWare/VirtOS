backup_restore_menu() {
    if ! command -v virtos-backup >/dev/null 2>&1; then
        $DIALOG $DIALOG_OPTS --msgbox "virtos-backup not installed" 6 40
        main_menu
        return
    fi

    $DIALOG $DIALOG_OPTS \
        --title "VM Backups & Restore" \
        --menu "Select option:" 18 76 8 \
        1 "List All Backups" \
        2 "Backup a VM" \
        3 "Restore a VM" \
        4 "Schedule Automatic Backups" \
        5 "Cleanup Old Backups" \
        6 "View Backup Statistics" \
        0 "Back" \
        2> $TEMP_FILE

    CHOICE=$(cat $TEMP_FILE)

    case $CHOICE in
        1)
            $DIALOG $DIALOG_OPTS \
                --title "Available Backups" \
                --msgbox "$(virtos-backup list 2>&1)" 25 100
            backup_restore_menu
            ;;
        2)
            # Get VM name
            $DIALOG $DIALOG_OPTS \
                --title "Backup VM" \
                --inputbox "Enter VM name to backup:" 10 60 \
                2> $TEMP_FILE
            VM_NAME=$(cat $TEMP_FILE)

            if [ -n "$VM_NAME" ]; then
                # Ask for remote destination (optional)
                $DIALOG $DIALOG_OPTS \
                    --title "Backup Destination" \
                    --yesno "Backup to remote location?\n\nNo = Local backup\nYes = Specify remote" 10 50

                if [ $? -eq 0 ]; then
                    $DIALOG $DIALOG_OPTS \
                        --title "Remote Destination" \
                        --inputbox "Enter remote destination:\n(e.g., scp://user@host:/path or s3://bucket/path)" 12 76 \
                        2> $TEMP_FILE
                    REMOTE=$(cat $TEMP_FILE)

                    if [ -n "$REMOTE" ]; then
                        virtos-backup backup "$VM_NAME" --remote "$REMOTE" 2>&1 | \
                            $DIALOG $DIALOG_OPTS --title "Backup Progress" --programbox 20 76
                    else
                        $DIALOG $DIALOG_OPTS --msgbox "Remote destination required" 6 40
                    fi
                else
                    virtos-backup backup "$VM_NAME" 2>&1 | \
                        $DIALOG $DIALOG_OPTS --title "Backup Progress" --programbox 20 76
                fi

                $DIALOG $DIALOG_OPTS --msgbox "Backup operation completed\n\nCheck logs for status" 8 50
            fi
            backup_restore_menu
            ;;
        3)
            # Get VM name
            $DIALOG $DIALOG_OPTS \
                --title "Restore VM" \
                --inputbox "Enter VM name to restore:" 10 60 \
                2> $TEMP_FILE
            VM_NAME=$(cat $TEMP_FILE)

            if [ -n "$VM_NAME" ]; then
                # Get backup date
                $DIALOG $DIALOG_OPTS \
                    --title "Restore Date" \
                    --inputbox "Enter backup date (YYYY-MM-DD):" 10 60 \
                    2> $TEMP_FILE
                BACKUP_DATE=$(cat $TEMP_FILE)

                if [ -n "$BACKUP_DATE" ]; then
                    $DIALOG $DIALOG_OPTS \
                        --title "Confirm Restore" \
                        --yesno "Restore VM '$VM_NAME' from backup '$BACKUP_DATE'?\n\nThis will overwrite the current VM!" 10 60

                    if [ $? -eq 0 ]; then
                        virtos-backup restore "$VM_NAME" "$BACKUP_DATE" 2>&1 | \
                            $DIALOG $DIALOG_OPTS --title "Restore Progress" --programbox 20 76
                        $DIALOG $DIALOG_OPTS --msgbox "Restore operation completed\n\nCheck logs for status" 8 50
                    fi
                fi
            fi
            backup_restore_menu
            ;;
        4)
            # Get VM name
            $DIALOG $DIALOG_OPTS \
                --title "Schedule Backups" \
                --inputbox "Enter VM name:" 10 60 \
                2> $TEMP_FILE
            VM_NAME=$(cat $TEMP_FILE)

            if [ -n "$VM_NAME" ]; then
                # Select schedule type
                $DIALOG $DIALOG_OPTS \
                    --title "Backup Schedule" \
                    --menu "Select schedule frequency:" 12 60 4 \
                    1 "Hourly" \
                    2 "Daily" \
                    3 "Weekly" \
                    2> $TEMP_FILE
                SCHED_CHOICE=$(cat $TEMP_FILE)

                case $SCHED_CHOICE in
                    1)
                        virtos-backup schedule "$VM_NAME" --hourly 2>&1 | \
                            $DIALOG $DIALOG_OPTS --title "Schedule Result" --programbox 15 76
                        ;;
                    2)
                        $DIALOG $DIALOG_OPTS \
                            --title "Daily Backup Time" \
                            --inputbox "Enter time (HH:MM, e.g., 02:00):" 10 60 "02:00" \
                            2> $TEMP_FILE
                        BACKUP_TIME=$(cat $TEMP_FILE)

                        if [ -n "$BACKUP_TIME" ]; then
                            virtos-backup schedule "$VM_NAME" --daily "$BACKUP_TIME" 2>&1 | \
                                $DIALOG $DIALOG_OPTS --title "Schedule Result" --programbox 15 76
                        fi
                        ;;
                    3)
                        $DIALOG $DIALOG_OPTS \
                            --title "Weekly Backup Time" \
                            --inputbox "Enter time (HH:MM, e.g., 03:00):" 10 60 "03:00" \
                            2> $TEMP_FILE
                        BACKUP_TIME=$(cat $TEMP_FILE)

                        if [ -n "$BACKUP_TIME" ]; then
                            virtos-backup schedule "$VM_NAME" --weekly "$BACKUP_TIME" 2>&1 | \
                                $DIALOG $DIALOG_OPTS --title "Schedule Result" --programbox 15 76
                        fi
                        ;;
                esac

                $DIALOG $DIALOG_OPTS --msgbox "Backup schedule configured" 6 40
            fi
            backup_restore_menu
            ;;
        5)
            $DIALOG $DIALOG_OPTS \
                --title "Cleanup Backups" \
                --yesno "Remove old backups according to retention policy?\n\nThis cannot be undone!" 10 60

            if [ $? -eq 0 ]; then
                virtos-backup cleanup 2>&1 | \
                    $DIALOG $DIALOG_OPTS --title "Cleanup Progress" --programbox 20 76
                $DIALOG $DIALOG_OPTS --msgbox "Cleanup completed" 6 40
            fi
            backup_restore_menu
            ;;
        6)
            STATS="Backup Statistics:\n\n"
            STATS="${STATS}$(virtos-backup list 2>&1 | head -20)\n"
            $DIALOG $DIALOG_OPTS \
                --title "Backup Statistics" \
                --msgbox "$STATS" 25 100
            backup_restore_menu
            ;;
        0) main_menu ;;
        *) backup_restore_menu ;;
    esac
}

