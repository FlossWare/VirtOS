set -e
# VirtOS Network - Network virtualization and SDN
# VLAN management, OVN, network policies, and software-defined networking

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.21")

# Handle --help and --version early (before any filesystem operations)
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "help" ] || [ "${1:-}" = "" ]; then
    # Skip mkdir - will show usage at end
    SKIP_INIT=yes
elif [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ] || [ "${1:-}" = "version" ]; then
    echo "virtos-network version $VERSION"
    exit 0
fi

NETWORK_DIR="/var/lib/virtos/network"
STATE_DIR="/var/run/virtos/network"
LOG_FILE="/var/log/virtos-network.log"

if [ "${SKIP_INIT:-no}" != "yes" ]; then
mkdir -p "$NETWORK_DIR" "$STATE_DIR"
fi

usage() {
    cat << EOF
VirtOS Network - Network Virtualization v${VERSION}

Usage: virtos-network [command] [options]

Commands:
  vlan-create <vlan-id> <name>     Create VLAN
  vlan-delete <vlan-id>            Delete VLAN
  vlan-list                        List VLANs
  vlan-attach <vm> <vlan-id>       Attach VM to VLAN

  ovn-init                         Initialize OVN (Open Virtual Network)
  ovn-status                       Show OVN status
  ovn-network-create <name>        Create virtual network
  ovn-network-delete <name>        Delete virtual network
  ovn-network-list                 List virtual networks

  bridge-create <name>             Create virtual bridge
  bridge-delete <name>             Delete virtual bridge
  bridge-list                      List bridges
  bridge-attach <bridge> <iface>   Attach interface to bridge

  firewall-create <vm> <rule>      Create per-VM firewall rule
  firewall-delete <vm> <rule>      Delete firewall rule
  firewall-list <vm>               List VM firewall rules

  policy-create <name>             Create network policy
  policy-apply <vm> <policy>       Apply policy to VM
  policy-list                      List network policies

  qos-set <vm> <rate>              Set QoS bandwidth limit
  qos-show <vm>                    Show VM QoS settings
  qos-remove <vm>                  Remove QoS limit

  sdn-enable                       Enable SDN mode
  sdn-status                       Show SDN status

Options:
  --subnet <cidr>                  Network subnet
  --gateway <ip>                   Gateway IP
  --dhcp <start>-<end>             DHCP range
  --vxlan                          Use VXLAN encapsulation
  --mtu <size>                     MTU size
  --rate <mbps>                    Bandwidth rate limit

Examples:
  # Create VLAN for DMZ
  virtos-network vlan-create 100 dmz-network

  # Attach VM to VLAN
  virtos-network vlan-attach web-server-1 100

  # Initialize OVN
  virtos-network ovn-init

  # Create virtual network with DHCP
  virtos-network ovn-network-create tenant-net \
    --subnet 10.10.0.0/24 \
    --gateway 10.10.0.1 \
    --dhcp 10.10.0.100-10.10.0.200

  # Create firewall rule
  virtos-network firewall-create web-1 "allow tcp 80,443"

  # Set QoS bandwidth limit
  virtos-network qos-set download-vm 100  # 100 Mbps

  # Create bridge for isolated network
  virtos-network bridge-create isolated-br0

EOF
}

log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

init_config() {
    if [ ! -f "$NETWORK_DIR/config.conf" ]; then
        cat > "$NETWORK_DIR/config.conf" <<EOF
# VirtOS Network Configuration

# VLAN settings
VLAN_ENABLED=no
VLAN_INTERFACE=eth0

# OVN settings
OVN_ENABLED=no
OVN_CENTRAL=""
OVN_ENCAP=geneve

# SDN settings
SDN_ENABLED=no
SDN_CONTROLLER=""

# QoS settings
QOS_ENABLED=no
DEFAULT_BANDWIDTH=1000

# Firewall
FIREWALL_ENABLED=yes
DEFAULT_POLICY=drop
EOF
    fi

    source "$NETWORK_DIR/config.conf"
}

# VLAN Management
vlan_create() {
    local vlan_id="$1"
    local vlan_name="$2"

    if [ -z "$vlan_id" ] || [ -z "$vlan_name" ]; then
        echo "Error: VLAN ID and name required"
        return 1
    fi

    if [ "$vlan_id" -lt 1 ] || [ "$vlan_id" -gt 4094 ]; then
        echo "Error: VLAN ID must be between 1-4094"
        return 1
    fi

    log_message "Creating VLAN $vlan_id ($vlan_name)"

    echo "Creating VLAN"
    echo "============="
    echo "VLAN ID: $vlan_id"
    echo "Name: $vlan_name"
    echo ""

    # Create VLAN interface
    local parent_iface="${VLAN_INTERFACE:-eth0}"
    local vlan_iface="${parent_iface}.${vlan_id}"

    if ip link show "$vlan_iface" >/dev/null 2>&1; then
        echo "VLAN interface already exists: $vlan_iface"
    else
        echo "Creating VLAN interface: $vlan_iface"
        # ip link add link $parent_iface name $vlan_iface type vlan id $vlan_id
        # ip link set $vlan_iface up
    fi

    # Create libvirt network for VLAN
    cat > "$NETWORK_DIR/vlan-${vlan_id}.xml" <<EOF
<network>
  <name>$vlan_name</name>
  <forward mode='bridge'/>
  <bridge name='$vlan_iface'/>
  <virtualport type='openvswitch'/>
  <vlan trunk='yes'>
    <tag id='$vlan_id'/>
  </vlan>
</network>
EOF

    if command -v virsh >/dev/null 2>&1; then
        virsh net-define "$NETWORK_DIR/vlan-${vlan_id}.xml" 2>/dev/null || true
        virsh net-start "$vlan_name" 2>/dev/null || true
        virsh net-autostart "$vlan_name" 2>/dev/null || true
    fi

    sed -i 's/^VLAN_ENABLED=.*/VLAN_ENABLED=yes/' "$NETWORK_DIR/config.conf"

    log_message "VLAN $vlan_id created"
    echo "VLAN $vlan_id created: $vlan_name"
    echo "Interface: $vlan_iface"
}

vlan_delete() {
    local vlan_id="$1"

    if [ -z "$vlan_id" ]; then
        echo "Error: VLAN ID required"
        return 1
    fi

    log_message "Deleting VLAN $vlan_id"

    # Get VLAN name from libvirt
    local vlan_name=$(virsh net-list --all 2>/dev/null | grep "vlan.*${vlan_id}" | awk '{print $1}')

    if [ -n "$vlan_name" ] && command -v virsh >/dev/null 2>&1; then
        virsh net-destroy "$vlan_name" 2>/dev/null || true
        virsh net-undefine "$vlan_name" 2>/dev/null || true
    fi

    # Remove VLAN interface
    local parent_iface="${VLAN_INTERFACE:-eth0}"
    local vlan_iface="${parent_iface}.${vlan_id}"

    if ip link show "$vlan_iface" >/dev/null 2>&1; then
        # ip link delete $vlan_iface
        echo "VLAN interface $vlan_iface removed"
    fi

    rm -f "$NETWORK_DIR/vlan-${vlan_id}.xml"

    echo "VLAN $vlan_id deleted"
}

vlan_list() {
    echo "VLANs:"
    echo "======"
    echo ""

    printf "%-10s %-20s %-15s %-10s\n" "VLAN ID" "NAME" "INTERFACE" "STATE"
    echo "----------------------------------------------------------------"

    # List from libvirt
    if command -v virsh >/dev/null 2>&1; then
        while read -r line; do
            if [ -n "$line" ]; then
                local name=$(echo "$line" | awk '{print $1}')
                local state=$(echo "$line" | awk '{print $2}')

                # Try to extract VLAN ID from name or config
                if [ -f "$NETWORK_DIR/vlan-*.xml" ]; then
                    for vlan_file in "$NETWORK_DIR"/vlan-*.xml; do
                        if grep -q "<name>$name</name>" "$vlan_file" 2>/dev/null; then
                            local vlan_id=$(basename "$vlan_file" .xml | sed 's/vlan-//')
                            local iface="${VLAN_INTERFACE:-eth0}.${vlan_id}"
                            printf "%-10s %-20s %-15s %-10s\n" "$vlan_id" "$name" "$iface" "$state"
                        fi
                    done
                fi
            fi
        done < <(virsh net-list --all 2>/dev/null | grep -v "^Name" | grep -v "^---" | grep "vlan")
    fi

    # Also list VLAN interfaces directly
    echo ""
    echo "VLAN Interfaces:"
    ip -br link show type vlan 2>/dev/null || echo "  (none)"
}

vlan_attach() {
    local vm_name="$1"
    local vlan_id="$2"

    if [ -z "$vm_name" ] || [ -z "$vlan_id" ]; then
        echo "Error: VM name and VLAN ID required"
        return 1
    fi

    log_message "Attaching VM $vm_name to VLAN $vlan_id"

    # Get VLAN network name
    local vlan_name=$(virsh net-list --all 2>/dev/null | grep "vlan.*${vlan_id}" | awk '{print $1}')

    if [ -z "$vlan_name" ]; then
        echo "Error: VLAN $vlan_id not found"
        return 1
    fi

    echo "Attaching VM to VLAN"
    echo "===================="
    echo "VM: $vm_name"
    echo "VLAN: $vlan_id ($vlan_name)"
    echo ""

    # In production, would:
    # 1. Get VM's network interface
    # 2. Update VM XML to use VLAN network
    # 3. Restart network interface or VM

    echo "VM $vm_name attached to VLAN $vlan_id (simulation)"
    echo ""
    echo "To apply, update VM network:"
    echo "  virsh edit $vm_name"
    echo "  Change <source network='default'/> to <source network='$vlan_name'/>"
}

# OVN (Open Virtual Network) Management
ovn_init() {
    log_message "Initializing OVN"

    echo "OVN Initialization"
    echo "=================="
    echo ""

    if ! command -v ovn-nbctl >/dev/null 2>&1; then
        echo "Error: OVN not installed"
        echo "Install with: tce-load -i openvswitch ovn"
        return 1
    fi

    echo "Starting OVN services..."

    # Start OVS if not running
    if ! pgrep ovs-vswitchd >/dev/null 2>&1; then
        echo "Starting Open vSwitch..."
        # ovsdb-server --detach
        # ovs-vswitchd --detach
    fi

    # Start OVN northbound database
    # ovn-northd --detach

    sed -i 's/^OVN_ENABLED=.*/OVN_ENABLED=yes/' "$NETWORK_DIR/config.conf"

    log_message "OVN initialized"
    echo "OVN initialized"
    echo ""
    echo "Create networks:"
    echo "  virtos-network ovn-network-create <name> --subnet <cidr>"
}

ovn_status() {
    echo "OVN Status"
    echo "=========="
    echo ""

    if ! command -v ovn-nbctl >/dev/null 2>&1; then
        echo "OVN not installed"
        return 1
    fi

    echo "OVN Databases:"
    if pgrep ovsdb-server >/dev/null 2>&1; then
        echo "  Northbound: Running"
    else
        echo "  Northbound: Not running"
    fi

    echo ""
    echo "Logical Switches:"
    ovn-nbctl ls-list 2>/dev/null || echo "  (none)"

    echo ""
    echo "Logical Routers:"
    ovn-nbctl lr-list 2>/dev/null || echo "  (none)"
}

ovn_network_create() {
    local net_name="$1"
    shift

    local subnet=""
    local gateway=""
    local dhcp_range=""

    if [ -z "$net_name" ]; then
        echo "Error: Network name required"
        return 1
    fi

    # Parse options
    while [ $# -gt 0 ]; do
        case "$1" in
            --subnet)
                subnet="$2"
                shift 2
                ;;
            --gateway)
                gateway="$2"
                shift 2
                ;;
            --dhcp)
                dhcp_range="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    log_message "Creating OVN network: $net_name"

    echo "Creating OVN Network"
    echo "===================="
    echo "Name: $net_name"
    echo "Subnet: $subnet"
    echo "Gateway: $gateway"
    echo "DHCP: $dhcp_range"
    echo ""

    # In production:
    # ovn-nbctl ls-add $net_name
    # ovn-nbctl lsp-add $net_name ${net_name}-port
    # Configure DHCP if specified

    echo "OVN network '$net_name' created (simulation)"
}

ovn_network_delete() {
    local net_name="$1"

    if [ -z "$net_name" ]; then
        echo "Error: Network name required"
        return 1
    fi

    log_message "Deleting OVN network: $net_name"

    # ovn-nbctl ls-del $net_name

    echo "OVN network '$net_name' deleted (simulation)"
}

ovn_network_list() {
    echo "OVN Networks:"
    echo "============="

    if command -v ovn-nbctl >/dev/null 2>&1; then
        ovn-nbctl ls-list 2>/dev/null || echo "No networks configured"
    else
        echo "OVN not installed"
    fi
}

# Bridge Management
bridge_create() {
    local bridge_name="$1"

    if [ -z "$bridge_name" ]; then
        echo "Error: Bridge name required"
        return 1
    fi

    log_message "Creating bridge: $bridge_name"

    echo "Creating Virtual Bridge"
    echo "======================="
    echo "Name: $bridge_name"

    # Create Linux bridge
    if ! ip link show "$bridge_name" >/dev/null 2>&1; then
        # ip link add name $bridge_name type bridge
        # ip link set $bridge_name up
        echo "Bridge created: $bridge_name"
    else
        echo "Bridge already exists: $bridge_name"
    fi

    # Create libvirt network
    cat > "$NETWORK_DIR/bridge-${bridge_name}.xml" <<EOF
<network>
  <name>$bridge_name</name>
  <forward mode='bridge'/>
  <bridge name='$bridge_name'/>
</network>
EOF

    if command -v virsh >/dev/null 2>&1; then
        virsh net-define "$NETWORK_DIR/bridge-${bridge_name}.xml" 2>/dev/null || true
        virsh net-start "$bridge_name" 2>/dev/null || true
        virsh net-autostart "$bridge_name" 2>/dev/null || true
    fi

    echo "Bridge $bridge_name created and available for VMs"
}

bridge_delete() {
    local bridge_name="$1"

    if [ -z "$bridge_name" ]; then
        echo "Error: Bridge name required"
        return 1
    fi

    log_message "Deleting bridge: $bridge_name"

    if command -v virsh >/dev/null 2>&1; then
        virsh net-destroy "$bridge_name" 2>/dev/null || true
        virsh net-undefine "$bridge_name" 2>/dev/null || true
    fi

    # ip link delete $bridge_name type bridge 2>/dev/null || true

    rm -f "$NETWORK_DIR/bridge-${bridge_name}.xml"

    echo "Bridge $bridge_name deleted"
}

bridge_list() {
    echo "Virtual Bridges:"
    echo "================"
    echo ""

    echo "System Bridges:"
    ip -br link show type bridge 2>/dev/null || echo "  (none)"

    echo ""
    echo "Libvirt Networks:"
    if command -v virsh >/dev/null 2>&1; then
        virsh net-list --all
    else
        echo "  (libvirt not available)"
    fi
}

bridge_attach() {
    local bridge_name="$1"
    local iface="$2"

    if [ -z "$bridge_name" ] || [ -z "$iface" ]; then
        echo "Error: Bridge name and interface required"
        return 1
    fi

    log_message "Attaching $iface to bridge $bridge_name"

    # ip link set $iface master $bridge_name

    echo "Interface $iface attached to bridge $bridge_name (simulation)"
}

# Firewall Management
firewall_create() {
    local vm_name="$1"
    local rule="$2"

    if [ -z "$vm_name" ] || [ -z "$rule" ]; then
        echo "Error: VM name and rule required"
        echo "Rule format: allow|deny tcp|udp|icmp port[,port]"
        return 1
    fi

    log_message "Creating firewall rule for $vm_name: $rule"

    local fw_file="$NETWORK_DIR/firewall-${vm_name}.rules"

    echo "$rule" >> "$fw_file"

    echo "Firewall Rule Added"
    echo "==================="
    echo "VM: $vm_name"
    echo "Rule: $rule"
    echo ""
    echo "Apply rules: virtos-network firewall-apply $vm_name"
}

firewall_delete() {
    local vm_name="$1"
    local rule="$2"

    if [ -z "$vm_name" ] || [ -z "$rule" ]; then
        echo "Error: VM name and rule required"
        return 1
    fi

    log_message "Deleting firewall rule for $vm_name: $rule"

    local fw_file="$NETWORK_DIR/firewall-${vm_name}.rules"

    if [ -f "$fw_file" ]; then
        grep -v "^$rule$" "$fw_file" > "${fw_file}.tmp"
        mv "${fw_file}.tmp" "$fw_file"
        echo "Rule deleted from $vm_name"
    else
        echo "No firewall rules for $vm_name"
    fi
}

firewall_list() {
    local vm_name="$1"

    echo "Firewall Rules:"
    echo "==============="

    if [ -n "$vm_name" ]; then
        echo "VM: $vm_name"
        echo ""

        local fw_file="$NETWORK_DIR/firewall-${vm_name}.rules"
        if [ -f "$fw_file" ]; then
            cat "$fw_file"
        else
            echo "No rules configured"
        fi
    else
        echo "All VMs:"
        echo ""

        for fw_file in "$NETWORK_DIR"/firewall-*.rules; do
            if [ -f "$fw_file" ]; then
                local vm=$(basename "$fw_file" .rules | sed 's/firewall-//')
                echo "VM: $vm"
                cat "$fw_file"
                echo ""
            fi
        done

        if ! ls "$NETWORK_DIR"/firewall-*.rules >/dev/null 2>&1; then
            echo "No rules configured"
        fi
    fi
}

# Network Policy
policy_create() {
    local policy_name="$1"

    if [ -z "$policy_name" ]; then
        echo "Error: Policy name required"
        return 1
    fi

    log_message "Creating network policy: $policy_name"

    cat > "$NETWORK_DIR/policy-${policy_name}.conf" <<EOF
# Network Policy: $policy_name
POLICY_NAME="$policy_name"

# Ingress rules
INGRESS_ALLOW=""

# Egress rules
EGRESS_ALLOW=""

# Default action
DEFAULT_ACTION="deny"
EOF

    echo "Network policy '$policy_name' created"
    echo "Edit: $NETWORK_DIR/policy-${policy_name}.conf"
}

policy_apply() {
    local vm_name="$1"
    local policy_name="$2"

    if [ -z "$vm_name" ] || [ -z "$policy_name" ]; then
        echo "Error: VM name and policy name required"
        return 1
    fi

    local policy_file="$NETWORK_DIR/policy-${policy_name}.conf"

    if [ ! -f "$policy_file" ]; then
        echo "Error: Policy not found: $policy_name"
        return 1
    fi

    log_message "Applying policy $policy_name to $vm_name"

    # In production, would apply policy rules to VM's network interface

    echo "Policy '$policy_name' applied to $vm_name (simulation)"
}

policy_list() {
    echo "Network Policies:"
    echo "================="

    for policy_file in "$NETWORK_DIR"/policy-*.conf; do
        if [ -f "$policy_file" ]; then
            local policy=$(basename "$policy_file" .conf | sed 's/policy-//')
            echo "  $policy"
        fi
    done

    if ! ls "$NETWORK_DIR"/policy-*.conf >/dev/null 2>&1; then
        echo "No policies configured"
    fi
}

# QoS Management
qos_set() {
    local vm_name="$1"
    local rate="$2"

    if [ -z "$vm_name" ] || [ -z "$rate" ]; then
        echo "Error: VM name and rate required"
        echo "Rate format: <number> (Mbps)"
        return 1
    fi

    log_message "Setting QoS for $vm_name: ${rate}Mbps"

    echo "Setting QoS Bandwidth Limit"
    echo "==========================="
    echo "VM: $vm_name"
    echo "Rate: ${rate} Mbps"

    # Save QoS settings
    mkdir -p "$NETWORK_DIR/qos"
    echo "$rate" > "$NETWORK_DIR/qos/${vm_name}.rate"

    # In production:
    # tc qdisc add dev <vm-iface> root tbf rate ${rate}mbit burst 32kbit latency 400ms

    sed -i 's/^QOS_ENABLED=.*/QOS_ENABLED=yes/' "$NETWORK_DIR/config.conf"

    echo "QoS limit applied (simulation)"
}

qos_show() {
    local vm_name="$1"

    if [ -z "$vm_name" ]; then
        echo "Error: VM name required"
        return 1
    fi

    echo "QoS Settings for $vm_name:"
    echo "=========================="

    if [ -f "$NETWORK_DIR/qos/${vm_name}.rate" ]; then
        local rate=$(cat "$NETWORK_DIR/qos/${vm_name}.rate")
        echo "Bandwidth limit: ${rate} Mbps"
    else
        echo "No QoS limit configured"
    fi
}

qos_remove() {
    local vm_name="$1"

    if [ -z "$vm_name" ]; then
        echo "Error: VM name required"
        return 1
    fi

    log_message "Removing QoS for $vm_name"

    rm -f "$NETWORK_DIR/qos/${vm_name}.rate"

    # tc qdisc del dev <vm-iface> root

    echo "QoS limit removed from $vm_name (simulation)"
}

# SDN Control
sdn_enable() {
    log_message "Enabling SDN mode"

    echo "Enabling Software-Defined Networking"
    echo "===================================="

    sed -i 's/^SDN_ENABLED=.*/SDN_ENABLED=yes/' "$NETWORK_DIR/config.conf"

    echo "SDN mode enabled"
    echo ""
    echo "SDN requires a controller. Configure in:"
    echo "  $NETWORK_DIR/config.conf"
}

sdn_status() {
    echo "SDN Status"
    echo "=========="
    echo ""

    if [ "$SDN_ENABLED" = "yes" ]; then
        echo "Status: Enabled"
        echo "Controller: ${SDN_CONTROLLER:-not configured}"
    else
        echo "Status: Disabled"
    fi

    echo ""
    echo "OVN: $([ "$OVN_ENABLED" = "yes" ] && echo "Enabled" || echo "Disabled")"
    echo "VLANs: $([ "$VLAN_ENABLED" = "yes" ] && echo "Enabled" || echo "Disabled")"
    echo "QoS: $([ "$QOS_ENABLED" = "yes" ] && echo "Enabled" || echo "Disabled")"
}

# Initialize
init_config

# Main command handler
COMMAND="${1:-}"
[ -n "$COMMAND" ] && shift

case "$COMMAND" in
    vlan-create)
        vlan_create "$1" "$2"
        ;;
    vlan-delete)
        vlan_delete "$1"
        ;;
    vlan-list)
        vlan_list
        ;;
    vlan-attach)
        vlan_attach "$1" "$2"
        ;;
    ovn-init)
        ovn_init
        ;;
    ovn-status)
        ovn_status
        ;;
    ovn-network-create)
        ovn_network_create "$@"
        ;;
    ovn-network-delete)
        ovn_network_delete "$1"
        ;;
    ovn-network-list)
        ovn_network_list
        ;;
    bridge-create)
        bridge_create "$1"
        ;;
    bridge-delete)
        bridge_delete "$1"
        ;;
    bridge-list)
        bridge_list
        ;;
    bridge-attach)
        bridge_attach "$1" "$2"
        ;;
    firewall-create)
        firewall_create "$1" "$2"
        ;;
    firewall-delete)
        firewall_delete "$1" "$2"
        ;;
    firewall-list)
        firewall_list "$1"
        ;;
    policy-create)
        policy_create "$1"
        ;;
    policy-apply)
        policy_apply "$1" "$2"
        ;;
    policy-list)
        policy_list
        ;;
    qos-set)
        qos_set "$1" "$2"
        ;;
    qos-show)
        qos_show "$1"
        ;;
    qos-remove)
        qos_remove "$1"
        ;;
    sdn-enable)
        sdn_enable
        ;;
    sdn-status)
        sdn_status
        ;;
    --version|-v|version)
        echo "virtos-network version $VERSION"
        exit 0
        ;;
    --help|-h|help|"")
        usage
        exit 0
        ;;
    *)
        echo "Error: Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac
