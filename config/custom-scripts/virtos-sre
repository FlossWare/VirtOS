# On-call rotation
setup_oncall_rotation() {
    local team="$1"
    local rotation_type="$2"  # weekly, daily

    log_message "Setting up on-call rotation for $team..."

    cat > "$SRE_CONFIG_DIR/oncall-$team.yaml" <<EOF
apiVersion: v1
kind: OnCallRotation
metadata:
  team: $team
  type: $rotation_type
  created: $(date -Iseconds)

spec:
  rotation_type: $rotation_type

  members:
    - name: "engineer1"
      email: "engineer1@example.com"
      phone: "+1-555-0001"
    - name: "engineer2"
      email: "engineer2@example.com"
      phone: "+1-555-0002"
    - name: "engineer3"
      email: "engineer3@example.com"
      phone: "+1-555-0003"

  schedule:
    start_date: "$(date +%Y-%m-%d)"
    handoff_time: "09:00"
    timezone: "UTC"

  escalation:
    - level: 1
      timeout: 5m
      target: primary
    - level: 2
      timeout: 10m
      target: secondary
    - level: 3
      timeout: 15m
      target: manager

  notifications:
    - type: email
      enabled: true
    - type: sms
      enabled: true
    - type: slack
      channel: "#oncall-$team"
EOF

    log_message "On-call rotation configured: $SRE_CONFIG_DIR/oncall-$team.yaml"
}

# Who is on-call
whos_oncall() {
    local team="$1"

    log_message "Checking who is on-call for $team..."

    local oncall_file="$SRE_CONFIG_DIR/oncall-$team.yaml"

    if [ ! -f "$oncall_file" ]; then
        log_message "ERROR: On-call rotation not found for: $team"
        return 1
    fi

    # Simplified implementation - in real system would calculate based on schedule
    echo "=== On-Call Status: $team ==="
    echo
    echo "Primary: engineer1 <engineer1@example.com>"
    echo "Secondary: engineer2 <engineer2@example.com>"
    echo
    echo "Current rotation: $(date +%Y-%m-%d)"
    echo "Next handoff: Tomorrow at 09:00 UTC"
}

