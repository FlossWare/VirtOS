  virtos-sre whos-oncall sre-team
  virtos-sre error-budget-report
  virtos-sre wizard

Version: $VERSION
EOF
}

# Main command dispatcher
case "$1" in
    define-slo)
        define_slo "$2" "$3" "$4" "$5"
        ;;
    calculate-slo)
        calculate_slo_status "$2"
        ;;
    create-incident)
        create_incident "$2" "$3" "$4"
        ;;
    update-incident)
        update_incident "$2" "$3" "$4"
        ;;
    close-incident)
        close_incident "$2" "$3"
        ;;
    create-postmortem)
        create_postmortem "$2"
        ;;
    setup-oncall)
        setup_oncall_rotation "$2" "$3"
        ;;
    whos-oncall)
        whos_oncall "$2"
        ;;
    create-runbook)
        create_runbook "$2" "$3"
        ;;
    error-budget-report)
        error_budget_report
        ;;
    status)
        sre_status
        ;;
    wizard)
        sre_wizard
        ;;
    version|--version|-v)
        echo "virtos-sre version $VERSION"
        ;;
    *)
        usage
        ;;
esac
