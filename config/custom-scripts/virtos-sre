# Error budget report
error_budget_report() {
    log_message "Generating error budget report..."

    local report_file="$SRE_CONFIG_DIR/error-budget-report-$(date +%Y%m%d).txt"

    cat > "$report_file" <<EOF
=== Error Budget Report ===
Generated: $(date)

Services and SLO Status:
EOF

    # List all SLOs
    for slo in "$SLO_DIR"/*.yaml; do
        if [ -f "$slo" ]; then
            local name=$(basename "$slo" .yaml)
            local status_file="$SLO_DIR/$name.status"

            if [ -f "$status_file" ]; then
                local budget=$(grep "error_budget_percent" "$status_file" | cut -d: -f2 | tr -d ' ,')
                local meeting=$(grep "meeting_slo" "$status_file" | cut -d: -f2 | tr -d ' ,')

                echo "  - $name: ${budget}% budget remaining ($([ "$meeting" = "true" ] && echo "✓" || echo "✗"))" >> "$report_file"
            fi
        fi
    done

    cat >> "$report_file" <<EOF

Incidents This Month: $(ls -1 "$INCIDENT_DIR"/INC-$(date +%Y%m)*.yaml 2>/dev/null | wc -l)

P1 Incidents: $(grep -l "severity: P1" "$INCIDENT_DIR"/INC-*.yaml 2>/dev/null | wc -l)
P2 Incidents: $(grep -l "severity: P2" "$INCIDENT_DIR"/INC-*.yaml 2>/dev/null | wc -l)

Total Error Budget Consumed: TBD minutes

Recommendations:
- Review incidents consuming most error budget
- Consider adjusting SLOs if consistently violated
- Implement automated remediation where possible
EOF

    log_message "Error budget report generated: $report_file"
    cat "$report_file"
}

# SRE status
sre_status() {
    echo "=== VirtOS SRE Status ==="
    echo

    echo "SLOs Defined: $(ls -1 "$SLO_DIR"/*.yaml 2>/dev/null | wc -l)"
    for slo in "$SLO_DIR"/*.yaml; do
        if [ -f "$slo" ]; then
            local name=$(basename "$slo" .yaml)
            echo "  - $name"
        fi
    done

    echo
    echo "Active Incidents: $(grep -l "status: investigating" "$INCIDENT_DIR"/*.yaml 2>/dev/null | wc -l)"
    echo "Resolved Incidents: $(grep -l "status: resolved" "$INCIDENT_DIR"/*.yaml 2>/dev/null | wc -l)"

    echo
    echo "Postmortems: $(ls -1 "$POSTMORTEM_DIR"/*.md 2>/dev/null | wc -l)"

    echo
    echo "On-Call Rotations: $(ls -1 "$SRE_CONFIG_DIR"/oncall-*.yaml 2>/dev/null | wc -l)"

    echo
    echo "Configuration: $SRE_CONFIG_DIR"
    echo "Logs: $SRE_LOG"
}

# Interactive wizard
sre_wizard() {
    dialog --title "VirtOS SRE Setup" \
        --msgbox "This wizard will help you set up SRE practices.\n\nDefine SLOs, manage incidents, and track error budgets." 12 60

    # Choose action
    local choice=$(dialog --title "Choose Action" \
        --menu "Select SRE action:" 16 60 5 \
        1 "Define SLO" \
        2 "Create Incident" \
        3 "Create Postmortem" \
        4 "Setup On-Call Rotation" \
        5 "Create Runbook" \
        2>&1 >/dev/tty)

    case "$choice" in
        1)
            local name=$(dialog --inputbox "SLO name:" 10 60 2>&1 >/dev/tty)
            local service=$(dialog --inputbox "Service name:" 10 60 2>&1 >/dev/tty)
            local target=$(dialog --inputbox "Target (%):" 10 60 "99.9" 2>&1 >/dev/tty)
            local window=$(dialog --inputbox "Window (days):" 10 60 "30" 2>&1 >/dev/tty)

            define_slo "$name" "$service" "$target" "$window"
            ;;

        2)
            local severity=$(dialog --menu "Severity:" 12 60 4 \
                P1 "Critical - Service down" \
                P2 "High - Major degradation" \
                P3 "Medium - Minor issue" \
                P4 "Low - Cosmetic" \
                2>&1 >/dev/tty)

            local title=$(dialog --inputbox "Incident title:" 10 60 2>&1 >/dev/tty)
            local desc=$(dialog --inputbox "Description:" 10 60 2>&1 >/dev/tty)

            create_incident "$severity" "$title" "$desc"
            ;;

        3)
            local incident_id=$(dialog --inputbox "Incident ID:" 10 60 "INC-20260522-120000" 2>&1 >/dev/tty)
            create_postmortem "$incident_id"
            ;;

        4)
            local team=$(dialog --inputbox "Team name:" 10 60 "sre-team" 2>&1 >/dev/tty)
            local rotation=$(dialog --menu "Rotation type:" 10 60 2 \
                weekly "Weekly rotation" \
                daily "Daily rotation" \
                2>&1 >/dev/tty)

            setup_oncall_rotation "$team" "$rotation"
            ;;

        5)
            local name=$(dialog --inputbox "Runbook name:" 10 60 2>&1 >/dev/tty)
            local service=$(dialog --inputbox "Service:" 10 60 2>&1 >/dev/tty)

            create_runbook "$name" "$service"
            ;;
    esac

    dialog --title "Setup Complete" \
        --msgbox "SRE setup complete!\n\nRun 'virtos-sre status' to review." 10 50
}

# Show usage
usage() {
    cat <<EOF
VirtOS Site Reliability Engineering Tools

Usage: virtos-sre <command> [options]

SLO Commands:
  define-slo <name> <service> <target%> <window_days>  Define Service Level Objective
  calculate-slo <name>                                  Calculate SLO status
  error-budget-report                                   Generate error budget report

Incident Commands:
  create-incident <severity> <title> <description>  Create incident (P1/P2/P3/P4)
  update-incident <id> <type> <text>                Update incident (timeline/status/resolution)
  close-incident <id> <resolution>                  Close incident
  create-postmortem <incident_id>                   Create postmortem template

On-Call Commands:
  setup-oncall <team> <rotation_type>               Setup on-call rotation (weekly/daily)
  whos-oncall <team>                                Check current on-call engineer

Runbook Commands:
  create-runbook <name> <service>                   Create runbook template

Status Commands:
  status                                            Show SRE status
  wizard                                            Interactive setup wizard

Examples:
  virtos-sre define-slo api-availability api-service 99.9 30
  virtos-sre calculate-slo api-availability
  virtos-sre create-incident P1 "API service down" "500 errors on all endpoints"
  virtos-sre create-postmortem INC-20260522-120000
