#!/bin/bash
set -e

# VirtOS Migrate - Live VM migration with and without shared storage
# Enhanced migration capabilities including block migration

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.17")

usage() {
    cat << EOF
VirtOS Migrate - Live VM Migration v${VERSION}

Usage: virtos-migrate [options] <vm-name> <destination-host>

Migration Types:
  --live                        Live migration (default)
  --offline                     Offline migration (shutdown, copy, start)
  --block                       Block migration (no shared storage required)

Options:
  --shared-storage              Use shared storage migration (faster)
  --bandwidth <mbps>            Limit migration bandwidth
  --compressed                  Use compression during migration
  --auto-converge               Auto-converge for busy VMs
  --persistent                  Make migration persistent
  --undefine-source             Remove VM from source after migration
  --verbose                     Verbose output

Examples:
  # Live migration with shared storage
  virtos-migrate --live --shared-storage web-1 virtos-2

  # Block migration (no shared storage)
  virtos-migrate --block web-1 virtos-2

  # Offline migration
  virtos-migrate --offline db-server virtos-3

  # Live migration with bandwidth limit
  virtos-migrate --live --bandwidth 100 app-1 virtos-2

  # Compressed migration
  virtos-migrate --block --compressed large-vm virtos-3

EOF
}

log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

check_requirements() {
    local vm_name="$1"
    local dest_host="$2"

    # Check if VM exists
    if ! virsh list --all | grep -q " $vm_name "; then
        echo "Error: VM '$vm_name' not found"
        return 1
    fi

    # Check if VM is running (for live migration)
    if [ "$MIGRATION_TYPE" = "live" ] || [ "$MIGRATION_TYPE" = "block" ]; then
        local state=$(virsh domstate "$vm_name")
        if [ "$state" != "running" ]; then
            echo "Error: VM must be running for live migration"
            echo "Current state: $state"
            echo "Use --offline for offline migration"
            return 1
        fi
    fi

    # Check destination host reachability
    if ! ping -c 1 -W 2 "$dest_host" >/dev/null 2>&1; then
        echo "Error: Destination host '$dest_host' unreachable"
        return 1
    fi

    # Check SSH connectivity
    if ! ssh -o ConnectTimeout=5 "root@$dest_host" "echo test" >/dev/null 2>&1; then
        echo "Error: SSH connection to root@$dest_host failed"
        echo "Ensure SSH key-based authentication is configured"
        return 1
    fi

    # Check destination has libvirt
    if ! ssh "root@$dest_host" "command -v virsh" >/dev/null 2>&1; then
        echo "Error: libvirt not available on destination host"
        return 1
    fi

    return 0
}

migrate_live_shared() {
    local vm_name="$1"
    local dest_host="$2"

    log_message "Starting live migration of $vm_name to $dest_host (shared storage)..."

    local migrate_opts="--live --persistent --verbose"

    if [ "$UNDEFINE_SOURCE" = "yes" ]; then
        migrate_opts="$migrate_opts --undefinesource"
    fi

    if [ -n "$BANDWIDTH" ]; then
        migrate_opts="$migrate_opts --bandwidth $BANDWIDTH"
    fi

    if [ "$COMPRESSED" = "yes" ]; then
        migrate_opts="$migrate_opts --compressed"
    fi

    if [ "$AUTO_CONVERGE" = "yes" ]; then
        migrate_opts="$migrate_opts --auto-converge"
    fi

    # Perform migration
    if virsh migrate $migrate_opts "$vm_name" "qemu+ssh://root@$dest_host/system"; then
        log_message "Migration completed successfully"
        echo "VM $vm_name successfully migrated to $dest_host"
        return 0
    else
        log_message "Migration failed"
        echo "Migration failed"
        return 1
    fi
}

migrate_block() {
    local vm_name="$1"
    local dest_host="$2"

    log_message "Starting block migration of $vm_name to $dest_host (copying disks)..."

    local migrate_opts="--live --copy-storage-all --persistent --verbose"

    if [ "$UNDEFINE_SOURCE" = "yes" ]; then
        migrate_opts="$migrate_opts --undefinesource"
    fi

    if [ -n "$BANDWIDTH" ]; then
        migrate_opts="$migrate_opts --bandwidth $BANDWIDTH"
    fi

    if [ "$COMPRESSED" = "yes" ]; then
        migrate_opts="$migrate_opts --compressed"
    fi

    echo "Note: Block migration copies all VM disks to destination"
    echo "This may take significant time depending on disk size and network speed"
    echo ""

    # Perform block migration
    if virsh migrate $migrate_opts "$vm_name" "qemu+ssh://root@$dest_host/system"; then
        log_message "Block migration completed successfully"
        echo "VM $vm_name successfully migrated to $dest_host (with disks)"
        return 0
    else
        log_message "Block migration failed"
        echo "Block migration failed"
        return 1
    fi
}

migrate_offline() {
    local vm_name="$1"
    local dest_host="$2"

    log_message "Starting offline migration of $vm_name to $dest_host..."

    # Shutdown VM if running
    local state=$(virsh domstate "$vm_name")
    if [ "$state" = "running" ]; then
        echo "Shutting down VM..."
        virsh shutdown "$vm_name"

        # Wait for shutdown (max 60 seconds)
        local timeout=60
        local elapsed=0
        while [ $elapsed -lt $timeout ]; do
            state=$(virsh domstate "$vm_name")
            if [ "$state" = "shut off" ]; then
                break
            fi
            sleep 2
            elapsed=$((elapsed + 2))
        done

        # Force destroy if still running
        state=$(virsh domstate "$vm_name")
        if [ "$state" != "shut off" ]; then
            echo "Forcing VM shutdown..."
            virsh destroy "$vm_name"
        fi
    fi

    # Get VM XML
    echo "Exporting VM configuration..."
    local vm_xml=$(mktemp --suffix=".xml") || die "Failed to create temporary file"
    trap "rm -f '$vm_xml'" EXIT
    virsh dumpxml "$vm_name" > "$vm_xml"

    # Get disk paths
    echo "Copying VM disks..."
    local disks=$(virsh domblklist "$vm_name" | grep -v '^-' | awk 'NR>1 {print $2}')

    for disk in $disks; do
        if [ -f "$disk" ]; then
            local disk_name=$(basename "$disk")
            local dest_dir="/var/lib/vms/${vm_name}"

            echo "  Copying: $disk_name"

            # Create directory on destination
            ssh "root@$dest_host" "mkdir -p $dest_dir"

            # Copy disk
            if ! scp "$disk" "root@$dest_host:$dest_dir/$disk_name"; then
                echo "Error: Failed to copy $disk"
                return 1
            fi

            # Update XML path
            sed -i "s|$disk|$dest_dir/$disk_name|g" "$vm_xml"
        fi
    done

    # Copy XML to destination
    echo "Copying VM configuration..."
    local remote_xml=$(ssh "root@$dest_host" "mktemp --suffix=.xml") || die "Failed to create remote temp file"
    scp "$vm_xml" "root@$dest_host:$remote_xml"

    # Define VM on destination
    echo "Defining VM on destination..."
    if ssh "root@$dest_host" "virsh define '$remote_xml' && rm -f '$remote_xml'"; then
        # Undefine on source if requested
        if [ "$UNDEFINE_SOURCE" = "yes" ]; then
            virsh undefine "$vm_name"
            echo "VM removed from source host"
        fi

        # Start VM on destination
        echo "Starting VM on destination..."
        ssh "root@$dest_host" "virsh start $vm_name"

        log_message "Offline migration completed successfully"
        echo "VM $vm_name successfully migrated to $dest_host"

        # Cleanup (local temp file - remote already cleaned by trap)
        rm -f "$vm_xml"

        return 0
    else
        log_message "Offline migration failed"
        echo "Migration failed"
        rm -f "$vm_xml"
        return 1
    fi
}

# Default options
MIGRATION_TYPE="live"
SHARED_STORAGE="no"
UNDEFINE_SOURCE="no"
COMPRESSED="no"
AUTO_CONVERGE="no"
BANDWIDTH=""
VERBOSE="no"

# Parse options
while [ $# -gt 0 ]; do
    case "$1" in
        --live)
            MIGRATION_TYPE="live"
            shift
            ;;
        --offline)
            MIGRATION_TYPE="offline"
            shift
            ;;
        --block)
            MIGRATION_TYPE="block"
            shift
            ;;
        --shared-storage)
            SHARED_STORAGE="yes"
            shift
            ;;
        --bandwidth)
            BANDWIDTH="$2"
            shift 2
            ;;
        --compressed)
            COMPRESSED="yes"
            shift
            ;;
        --auto-converge)
            AUTO_CONVERGE="yes"
            shift
            ;;
        --persistent)
            PERSISTENT="yes"
            shift
            ;;
        --undefine-source)
            UNDEFINE_SOURCE="yes"
            shift
            ;;
        --verbose)
            VERBOSE="yes"
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version)
            echo "virtos-migrate version $VERSION"
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

# Get VM name and destination
VM_NAME="$1"
DEST_HOST="$2"

if [ -z "$VM_NAME" ] || [ -z "$DEST_HOST" ]; then
    echo "Error: VM name and destination host required"
    echo ""
    usage
    exit 1
fi

# Security: Validate inputs before using in commands
if ! validate_vm_name "$VM_NAME"; then
    echo "Error: Invalid VM name '$VM_NAME'"
    echo "VM names must contain only alphanumeric characters, dashes, and underscores (max 64 chars)"
    exit 1
fi

if ! validate_hostname "$DEST_HOST"; then
    echo "Error: Invalid destination hostname '$DEST_HOST'"
    echo "Hostnames must contain only alphanumeric characters, dots, and dashes"
    exit 1
fi

# Check requirements
if ! check_requirements "$VM_NAME" "$DEST_HOST"; then
    exit 1
fi

# Perform migration
case "$MIGRATION_TYPE" in
    live)
        if [ "$SHARED_STORAGE" = "yes" ]; then
            migrate_live_shared "$VM_NAME" "$DEST_HOST"
        else
            echo "Error: Live migration requires --shared-storage or use --block"
            echo "Tip: Use --block for live migration without shared storage"
            exit 1
        fi
        ;;
    block)
        migrate_block "$VM_NAME" "$DEST_HOST"
        ;;
    offline)
        migrate_offline "$VM_NAME" "$DEST_HOST"
        ;;
esac
