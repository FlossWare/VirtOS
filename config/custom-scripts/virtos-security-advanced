# Advanced security wizard
security_adv_wizard() {
    log "Starting Advanced Security Setup Wizard..."

    echo "=== Advanced Security Setup Wizard ==="
    echo ""

    # MAC
    echo "1. Mandatory Access Control"
    echo "   Choose system:"
    echo "   1) AppArmor (recommended for Debian/Ubuntu)"
    echo "   2) SELinux (recommended for RHEL/Fedora)"
    read -p "   Selection [1]: " mac_choice
    case "${mac_choice:-1}" in
        1) SELINUX_APPARMOR="apparmor" ;;
        2) SELINUX_APPARMOR="selinux" ;;
    esac

    # Features
    echo ""
    echo "2. Security Features"
    read -p "   Enable IDS/IPS? (y/n) [y]: " ids_choice
    IDS_IPS="${ids_choice:-y}"

    read -p "   Enable vulnerability scanning? (y/n) [y]: " vuln_choice
    VULNERABILITY_SCANNING="${vuln_choice:-y}"

    read -p "   Enable compliance frameworks? (y/n) [y]: " comp_choice
    COMPLIANCE_FRAMEWORKS="${comp_choice:-y}"

    read -p "   Enable penetration testing? (y/n) [y]: " pen_choice
    PENETRATION_TESTING="${pen_choice:-y}"

    read -p "   Enable threat intelligence? (y/n) [y]: " threat_choice
    THREAT_INTELLIGENCE="${threat_choice:-y}"

    # Initialize
    echo ""
    log "Initializing advanced security..."
    security_adv_init

    if [ "$IDS_IPS" = "y" ]; then
        setup_ids ids
    fi

    echo ""
    log "Advanced security wizard completed!"
    echo ""
    echo "Next steps:"
    echo "  - Run audit: virtos-security-advanced security-audit"
    echo "  - Scan vulnerabilities: virtos-security-advanced vuln-scan localhost"
    echo "  - Check compliance: virtos-security-advanced compliance-check pci-dss"
    echo "  - Run pentest: virtos-security-advanced pentest-run localhost"
}

# Show usage
usage() {
    cat << EOF
VirtOS Advanced Security - Version $VERSION

Usage: $SCRIPT_NAME <command> [options]

Commands:
  security-adv-init                      Initialize advanced security

  enable-mac [selinux|apparmor]          Enable mandatory access control
  setup-ids [ids|ips]                    Setup intrusion detection/prevention

  vuln-scan <target> [type]              Run vulnerability scan
  compliance-check [framework]           Check compliance
                                         Frameworks: pci-dss, hipaa, iso27001, nist

  pentest-run <target> [intensity]       Run penetration test
                                         Intensity: light, normal, aggressive

  threat-intel [update|query|block]      Threat intelligence operations

  security-audit                         Comprehensive security audit
  security-adv-status                    Show advanced security status
  wizard                                 Run interactive setup wizard

  version                                Show version
  help                                   Show this help

Examples:
  # Setup wizard
  $SCRIPT_NAME wizard

  # Enable MAC
  $SCRIPT_NAME enable-mac apparmor
  $SCRIPT_NAME enable-mac selinux

  # IDS/IPS
  $SCRIPT_NAME setup-ids ids            # Detection only
  $SCRIPT_NAME setup-ids ips            # Prevention mode

  # Vulnerability scanning
  $SCRIPT_NAME vuln-scan localhost full
  $SCRIPT_NAME vuln-scan 192.168.1.100 quick

  # Compliance checks
  $SCRIPT_NAME compliance-check pci-dss
  $SCRIPT_NAME compliance-check hipaa
  $SCRIPT_NAME compliance-check iso27001
  $SCRIPT_NAME compliance-check nist

  # Penetration testing
  $SCRIPT_NAME pentest-run localhost normal
  $SCRIPT_NAME pentest-run 192.168.1.0/24 aggressive

  # Threat intelligence
  $SCRIPT_NAME threat-intel update
  $SCRIPT_NAME threat-intel query
  $SCRIPT_NAME threat-intel block

  # Security audit
  $SCRIPT_NAME security-audit

  # Status
  $SCRIPT_NAME security-adv-status

EXIT CODES:
    0    Success
    1    General error
    2    Invalid arguments
    3    Security component not available
    4    Scan/test failed
    5    Compliance check failed

EOF
}

# Main
main() {
    # Handle help/version first (before init to avoid permission issues in tests)
    case "${1:-}" in
        version|--version|-v)
            echo "$SCRIPT_NAME version $VERSION"
            exit 0
            ;;
        help|--help|-h|"")
            usage
            exit 0
            ;;
    esac

    # Now init for actual commands
    init_logging
    load_config

    case "${1}" in
        security-adv-init)
            security_adv_init
            ;;
        enable-mac)
            enable_mac "$2"
            ;;
        setup-ids)
            setup_ids "$2"
            ;;
        vuln-scan)
            vuln_scan "$2" "$3"
            ;;
        compliance-check)
            compliance_check "$2"
            ;;
        pentest-run)
            pentest_run "$2" "$3"
            ;;
        threat-intel)
            threat_intel "$2"
            ;;
        security-audit)
            security_audit
            ;;
        security-adv-status)
            security_adv_status
            ;;
        wizard)
            security_adv_wizard
            ;;        *)
            echo "Unknown command: $1"
            echo "Run '$SCRIPT_NAME help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
