set -e
# virtos-mesh - Service mesh integration for VirtOS
# Part of Phase 10: Metrics, Telemetry, and Advanced Features

# Load common library
if [ -f /usr/local/lib/virtos-common.sh ]; then
    . /usr/local/lib/virtos-common.sh
fi

VERSION=$(get_version 2>/dev/null || echo "0.89")
SCRIPT_NAME="virtos-mesh"
LOG_FILE="/var/log/virtos-mesh.log"
CONFIG_FILE="/etc/virtos/mesh.conf"
MESH_DIR="/var/lib/virtos/mesh"

# Service mesh configuration defaults
MESH_TYPE="istio"  # istio, linkerd, consul
MESH_ENABLED="no"
ISTIO_VERSION="1.20.0"
LINKERD_VERSION="2.14.0"
CONSUL_VERSION="1.17.0"
MESH_NAMESPACE="virtos-mesh"
MTLS_ENABLED="yes"
OBSERVABILITY_ENABLED="yes"
TRACING_ENABLED="yes"
TRAFFIC_MANAGEMENT="yes"

# Initialize logging
init_logging() {
    mkdir -p "$(dirname "$LOG_FILE")"
    mkdir -p "$MESH_DIR"
}

# Log message
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | tee -a "$LOG_FILE"
}

# Load configuration
load_config() {
    if [ -f "$CONFIG_FILE" ]; then
        source "$CONFIG_FILE"
    fi
}

# Save configuration
save_config() {
    mkdir -p "$(dirname "$CONFIG_FILE")"
    cat > "$CONFIG_FILE" << EOF
# VirtOS Service Mesh Configuration
# Generated by virtos-mesh version $VERSION

MESH_TYPE="$MESH_TYPE"
MESH_ENABLED="$MESH_ENABLED"
ISTIO_VERSION="$ISTIO_VERSION"
LINKERD_VERSION="$LINKERD_VERSION"
CONSUL_VERSION="$CONSUL_VERSION"
MESH_NAMESPACE="$MESH_NAMESPACE"
MTLS_ENABLED="$MTLS_ENABLED"
OBSERVABILITY_ENABLED="$OBSERVABILITY_ENABLED"
TRACING_ENABLED="$TRACING_ENABLED"
TRAFFIC_MANAGEMENT="$TRAFFIC_MANAGEMENT"
EOF
    log "Configuration saved to $CONFIG_FILE"
}

# Check prerequisites
check_prerequisites() {
    log "Checking prerequisites..."

    # Check for kubectl
    if ! command -v kubectl &> /dev/null; then
        log "ERROR: kubectl not found. Install Kubernetes first."
        log "Run: virtos-kubernetes init"
        return 1
    fi

    # Check for K3s/Kubernetes
    if ! kubectl cluster-info &> /dev/null; then
        log "ERROR: Kubernetes cluster not accessible"
        return 1
    fi

    # Check for Helm
    if ! command -v helm &> /dev/null; then
        log "Installing Helm..."
        # SECURITY: Download and review before executing
        local helm_install=$(mktemp) || die "Failed to create temporary file"
        if curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 -o "$helm_install"; then
            log "Downloaded Helm install script to $helm_install"
            log "WARNING: Review the script before execution in production"
            if ! bash "$helm_install"; then
                rm -f "$helm_install"
                log "ERROR: Failed to install Helm"
                return 1
            fi
            rm -f "$helm_install"
        else
            log "ERROR: Failed to download Helm install script"
            return 1
        fi
    fi

    log "Prerequisites check passed"
    return 0
}

# Install Istio
istio_install() {
    log "Installing Istio $ISTIO_VERSION..."

    if ! check_prerequisites; then
        return 1
    fi

    # Download Istio
    local istio_dir="$MESH_DIR/istio-$ISTIO_VERSION"

    if [ ! -d "$istio_dir" ]; then
        log "Downloading Istio..."
        cd "$MESH_DIR" || return 1
        # SECURITY: Download and review before executing
        local istio_install=$(mktemp) || die "Failed to create temporary file"
        if curl -L https://istio.io/downloadIstio -o "$istio_install"; then
            log "Downloaded Istio install script to $istio_install"
            log "WARNING: Review the script before execution in production"
            if ! ISTIO_VERSION=$ISTIO_VERSION sh "$istio_install"; then
                rm -f "$istio_install"
                log "ERROR: Failed to download Istio"
                return 1
            fi
            rm -f "$istio_install"
        else
            log "ERROR: Failed to download Istio install script"
            return 1
        fi
    fi

    # Add istioctl to PATH
    export PATH="$istio_dir/bin:$PATH"

    # Install Istio
    log "Installing Istio control plane..."
    if ! istioctl install --set profile=default -y; then
        log "ERROR: Failed to install Istio"
        return 1
    fi

    # Enable sidecar injection
    kubectl label namespace default istio-injection=enabled --overwrite

    # Install Istio addons (observability)
    if [ "$OBSERVABILITY_ENABLED" = "yes" ]; then
        log "Installing Istio observability addons..."
        kubectl apply -f "$istio_dir/samples/addons/prometheus.yaml"
        kubectl apply -f "$istio_dir/samples/addons/grafana.yaml"
        kubectl apply -f "$istio_dir/samples/addons/kiali.yaml"
        if [ "$TRACING_ENABLED" = "yes" ]; then
            kubectl apply -f "$istio_dir/samples/addons/jaeger.yaml"
        fi
    fi

    MESH_TYPE="istio"
    MESH_ENABLED="yes"
    save_config

    log "Istio installed successfully"
    log "Kiali dashboard: kubectl port-forward -n istio-system svc/kiali 20001:20001"
}

# Install Linkerd
linkerd_install() {
    log "Installing Linkerd $LINKERD_VERSION..."

    if ! check_prerequisites; then
        return 1
    fi

    # Download Linkerd CLI
    log "Downloading Linkerd CLI..."
    # SECURITY: Download and review before executing
    local linkerd_install=$(mktemp) || die "Failed to create temporary file"
    if curl -fsL https://run.linkerd.io/install -o "$linkerd_install"; then
        log "Downloaded Linkerd install script to $linkerd_install"
        log "WARNING: Review the script before execution in production"
        if ! sh "$linkerd_install"; then
            rm -f "$linkerd_install"
            log "ERROR: Failed to install Linkerd"
            return 1
        fi
        rm -f "$linkerd_install"
    else
        log "ERROR: Failed to download Linkerd install script"
        return 1
    fi

    export PATH="$HOME/.linkerd2/bin:$PATH"

    # Pre-check
    log "Running pre-installation checks..."
    linkerd check --pre

    # Install Linkerd control plane
    log "Installing Linkerd control plane..."
    linkerd install --crds | kubectl apply -f -
    if ! linkerd install | kubectl apply -f -; then
        log "ERROR: Failed to install Linkerd"
        return 1
    fi

    # Wait for Linkerd to be ready
    log "Waiting for Linkerd to be ready..."
    linkerd check

    # Install Linkerd viz extension (observability)
    if [ "$OBSERVABILITY_ENABLED" = "yes" ]; then
        log "Installing Linkerd viz extension..."
        linkerd viz install | kubectl apply -f -
        linkerd viz check
    fi

    MESH_TYPE="linkerd"
    MESH_ENABLED="yes"
    save_config

    log "Linkerd installed successfully"
    log "Dashboard: linkerd viz dashboard"
}

# Install Consul Connect
consul_install() {
    log "Installing Consul Connect $CONSUL_VERSION..."

    if ! check_prerequisites; then
        return 1
    fi

    # Add Consul Helm repo
    helm repo add hashicorp https://helm.releases.hashicorp.com
    helm repo update

    # Install Consul
    log "Installing Consul via Helm..."
    if ! helm install consul hashicorp/consul \
        --set global.name=consul \
        --set connectInject.enabled=true \
        --set ui.enabled=true \
        --create-namespace \
        --namespace "$MESH_NAMESPACE"; then
        log "ERROR: Failed to install Consul"
        return 1
    fi

    # Wait for Consul to be ready
    log "Waiting for Consul to be ready..."
    kubectl wait --for=condition=ready pod -l app=consul -n "$MESH_NAMESPACE" --timeout=300s

    MESH_TYPE="consul"
    MESH_ENABLED="yes"
    save_config

    log "Consul Connect installed successfully"
    log "UI: kubectl port-forward -n $MESH_NAMESPACE svc/consul-ui 8500:80"
}

# Inject sidecar into deployment
inject_sidecar() {
    local deployment="$1"
    local namespace="${2:-default}"

    if [ -z "$deployment" ]; then
        log "ERROR: Deployment name required"
        return 1
    fi

    log "Injecting sidecar into deployment: $deployment (namespace: $namespace)..."

    case "$MESH_TYPE" in
        istio)
            # Restart pods to inject Istio sidecar
            kubectl rollout restart deployment "$deployment" -n "$namespace"
            kubectl rollout status deployment "$deployment" -n "$namespace"
            ;;
        linkerd)
            # Inject Linkerd proxy
            kubectl get deployment "$deployment" -n "$namespace" -o yaml | \
                linkerd inject - | \
                kubectl apply -f -
            kubectl rollout status deployment "$deployment" -n "$namespace"
            ;;
        consul)
            # Annotate deployment for Consul injection
            kubectl patch deployment "$deployment" -n "$namespace" -p '{
                "spec": {
                    "template": {
                        "metadata": {
                            "annotations": {
                                "consul.hashicorp.com/connect-inject": "true"
                            }
                        }
                    }
                }
            }'
            kubectl rollout status deployment "$deployment" -n "$namespace"
            ;;
        *)
            log "ERROR: Unknown mesh type: $MESH_TYPE"
            return 1
            ;;
    esac

    log "Sidecar injection completed"
}

# Enable mTLS
mtls_enable() {
    log "Enabling mutual TLS..."

    case "$MESH_TYPE" in
        istio)
            cat <<EOF | kubectl apply -f -
apiVersion: security.istio.io/v1beta1
kind: PeerAuthentication
metadata:
  name: default
  namespace: istio-system
spec:
  mtls:
    mode: STRICT
EOF
            ;;
        linkerd)
            log "mTLS is enabled by default in Linkerd"
            ;;
        consul)
            # mTLS is enabled via Consul config
            log "mTLS configured via Consul settings"
            ;;
    esac

    MTLS_ENABLED="yes"
    save_config

    log "mTLS enabled"
}

# Create virtual service (traffic management)
virtual_service_create() {
    local name="$1"
    local host="$2"
    local service="$3"
    local port="${4:-80}"

    if [ -z "$name" ] || [ -z "$host" ] || [ -z "$service" ]; then
        log "ERROR: Name, host, and service required"
        return 1
    fi

    log "Creating virtual service: $name..."

    case "$MESH_TYPE" in
        istio)
            cat <<EOF | kubectl apply -f -
apiVersion: networking.istio.io/v1beta1
kind: VirtualService
metadata:
  name: $name
spec:
  hosts:
  - $host
  http:
  - route:
    - destination:
        host: $service
        port:
          number: $port
EOF
            ;;
        linkerd)
            log "Traffic splitting in Linkerd uses SMI TrafficSplit"
            cat <<EOF | kubectl apply -f -
apiVersion: split.smi-spec.io/v1alpha1
kind: TrafficSplit
metadata:
  name: $name
spec:
  service: $service
  backends:
  - service: $service
    weight: 100
EOF
            ;;
        consul)
            log "Traffic management in Consul uses service-router config entries"
            ;;
    esac

    log "Virtual service created"
}

# Create destination rule (traffic policy)
destination_rule_create() {
    local name="$1"
    local host="$2"

    if [ -z "$name" ] || [ -z "$host" ]; then
        log "ERROR: Name and host required"
        return 1
    fi

    log "Creating destination rule: $name..."

    case "$MESH_TYPE" in
        istio)
            cat <<EOF | kubectl apply -f -
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: $name
spec:
  host: $host
  trafficPolicy:
    loadBalancer:
      simple: ROUND_ROBIN
    connectionPool:
      tcp:
        maxConnections: 100
      http:
        http1MaxPendingRequests: 50
        http2MaxRequests: 100
    outlierDetection:
      consecutiveErrors: 5
      interval: 30s
      baseEjectionTime: 30s
EOF
            ;;
        linkerd)
            log "Traffic policy in Linkerd uses ServiceProfile"
            ;;
        consul)
            log "Traffic policy in Consul uses service-defaults config entries"
            ;;
    esac

    log "Destination rule created"
}

# Traffic split (canary deployment)
traffic_split() {
    local service="$1"
    local version_a="${2:-v1}"
    local version_b="${3:-v2}"
    local weight_b="${4:-10}"  # Percentage for version B

    if [ -z "$service" ]; then
        log "ERROR: Service name required"
        return 1
    fi

    local weight_a=$((100 - weight_b))

    log "Creating traffic split: $service ($version_a: $weight_a%, $version_b: $weight_b%)..."

    case "$MESH_TYPE" in
        istio)
            cat <<EOF | kubectl apply -f -
apiVersion: networking.istio.io/v1beta1
kind: VirtualService
metadata:
  name: $service-split
spec:
  hosts:
  - $service
  http:
  - match:
    - uri:
        prefix: "/"
    route:
    - destination:
        host: $service
        subset: $version_a
      weight: $weight_a
    - destination:
        host: $service
        subset: $version_b
      weight: $weight_b
---
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: $service-split
spec:
  host: $service
  subsets:
  - name: $version_a
    labels:
      version: $version_a
  - name: $version_b
    labels:
      version: $version_b
EOF
            ;;
        linkerd)
            cat <<EOF | kubectl apply -f -
apiVersion: split.smi-spec.io/v1alpha1
kind: TrafficSplit
metadata:
  name: $service-split
spec:
  service: $service
  backends:
  - service: $service-$version_a
    weight: $weight_a
  - service: $service-$version_b
    weight: $weight_b
EOF
            ;;
        consul)
            log "Traffic splitting in Consul uses service-splitter config entries"
            ;;
    esac

    log "Traffic split created"
}

# Fault injection (chaos testing)
fault_inject() {
    local service="$1"
    local fault_type="${2:-delay}"  # delay, abort
    local percentage="${3:-10}"

    if [ -z "$service" ]; then
        log "ERROR: Service name required"
        return 1
    fi

    log "Injecting $fault_type fault into $service ($percentage%)..."

    case "$MESH_TYPE" in
        istio)
            local fault_spec=""
            if [ "$fault_type" = "delay" ]; then
                fault_spec="delay:\n      percentage:\n        value: $percentage\n      fixedDelay: 5s"
            else
                fault_spec="abort:\n      percentage:\n        value: $percentage\n      httpStatus: 500"
            fi

            cat <<EOF | kubectl apply -f -
apiVersion: networking.istio.io/v1beta1
kind: VirtualService
metadata:
  name: $service-fault
spec:
  hosts:
  - $service
  http:
  - fault:
      $fault_spec
    route:
    - destination:
        host: $service
EOF
            ;;
        linkerd)
            log "Fault injection in Linkerd requires external tools like Chaos Mesh"
            ;;
        consul)
            log "Fault injection in Consul requires additional tooling"
            ;;
    esac

    log "Fault injection configured"
}

# Circuit breaker
circuit_breaker() {
    local service="$1"
    local max_connections="${2:-100}"
    local max_requests="${3:-100}"

    if [ -z "$service" ]; then
        log "ERROR: Service name required"
        return 1
    fi

    log "Configuring circuit breaker for $service..."

    case "$MESH_TYPE" in
        istio)
            cat <<EOF | kubectl apply -f -
apiVersion: networking.istio.io/v1beta1
kind: DestinationRule
metadata:
  name: $service-circuit-breaker
spec:
  host: $service
  trafficPolicy:
    connectionPool:
      tcp:
        maxConnections: $max_connections
      http:
        http1MaxPendingRequests: 50
        http2MaxRequests: $max_requests
    outlierDetection:
      consecutiveErrors: 5
      interval: 30s
      baseEjectionTime: 30s
      maxEjectionPercent: 50
EOF
            ;;
        linkerd)
            log "Circuit breaking in Linkerd uses retry budgets and timeouts"
            ;;
        consul)
            log "Circuit breaking in Consul uses service-defaults config entries"
            ;;
    esac

    log "Circuit breaker configured"
}

# Mesh status
mesh_status() {
    log "=== Service Mesh Status ==="
    echo ""

    echo "Mesh Type: $MESH_TYPE"
    echo "Status: $MESH_ENABLED"
    echo ""

    case "$MESH_TYPE" in
        istio)
            echo "Istio Version: $ISTIO_VERSION"
            echo ""
            echo "Control Plane:"
            kubectl get pods -n istio-system
            echo ""
            echo "Gateways:"
            kubectl get gateway --all-namespaces
            echo ""
            echo "Virtual Services:"
            kubectl get virtualservice --all-namespaces
            ;;
        linkerd)
            echo "Linkerd Version: $LINKERD_VERSION"
            echo ""
            linkerd check || true
            ;;
        consul)
            echo "Consul Version: $CONSUL_VERSION"
            echo ""
            kubectl get pods -n "$MESH_NAMESPACE"
            ;;
    esac
}

# Dashboard
mesh_dashboard() {
    log "Opening mesh dashboard..."

    case "$MESH_TYPE" in
        istio)
            log "Starting Kiali dashboard..."
            kubectl port-forward -n istio-system svc/kiali 20001:20001 &
            log "Kiali available at: http://localhost:20001"
            ;;
        linkerd)
            log "Starting Linkerd dashboard..."
            linkerd viz dashboard &
            ;;
        consul)
            log "Starting Consul UI..."
            kubectl port-forward -n "$MESH_NAMESPACE" svc/consul-ui 8500:80 &
            log "Consul UI available at: http://localhost:8500"
            ;;
    esac
}

# Mesh wizard
mesh_wizard() {
    log "Starting VirtOS Service Mesh Setup Wizard..."

    echo "=== VirtOS Service Mesh Setup Wizard ==="
    echo ""

    # Choose mesh
    echo "1. Service Mesh Selection"
    echo "   Choose service mesh:"
    echo "   1) Istio (feature-rich, production-grade)"
    echo "   2) Linkerd (lightweight, simple)"
    echo "   3) Consul Connect (multi-platform)"
    read -p "   Selection [1]: " mesh_choice

    case "${mesh_choice:-1}" in
        1)
            MESH_TYPE="istio"
            istio_install
            ;;
        2)
            MESH_TYPE="linkerd"
            linkerd_install
            ;;
        3)
            MESH_TYPE="consul"
            consul_install
            ;;
    esac

    # mTLS
    echo ""
    echo "2. Security Configuration"
    read -p "   Enable mutual TLS? (y/n) [y]: " mtls_choice
    if [ "${mtls_choice:-y}" = "y" ]; then
        mtls_enable
    fi

    # Observability
    echo ""
    echo "3. Observability"
    read -p "   Enable observability (metrics, traces)? (y/n) [y]: " obs_choice
    OBSERVABILITY_ENABLED="${obs_choice:-y}"

    if [ "$OBSERVABILITY_ENABLED" = "y" ]; then
        read -p "   Enable distributed tracing? (y/n) [y]: " trace_choice
        TRACING_ENABLED="${trace_choice:-y}"
    fi

    save_config

    echo ""
    log "Service mesh wizard completed!"
    echo ""
    echo "Next steps:"
    echo "  - Check status: virtos-mesh status"
    echo "  - Inject sidecars: virtos-mesh inject-sidecar <deployment>"
    echo "  - View dashboard: virtos-mesh dashboard"
}

# Show usage
usage() {
    cat << EOF
VirtOS Service Mesh Integration - Version $VERSION

Usage: $SCRIPT_NAME <command> [options]

Commands:
  istio-install                          Install Istio service mesh
  linkerd-install                        Install Linkerd service mesh
  consul-install                         Install Consul Connect

  inject-sidecar <deployment> [ns]       Inject sidecar proxy into deployment
  mtls-enable                            Enable mutual TLS

  virtual-service-create <name> <host> <svc> [port]  Create virtual service
  destination-rule-create <name> <host>  Create destination rule
  traffic-split <svc> [v1] [v2] [weight] Configure traffic splitting
  fault-inject <svc> [type] [pct]        Inject faults (delay/abort)
  circuit-breaker <svc> [conn] [req]     Configure circuit breaker

  status                                 Show mesh status
  dashboard                              Open mesh dashboard
  wizard                                 Run interactive setup wizard

  version                                Show version
  help                                   Show this help

Examples:
  # Setup wizard (recommended for first-time setup)
  $SCRIPT_NAME wizard

  # Install Istio
  $SCRIPT_NAME istio-install

  # Inject sidecar
  $SCRIPT_NAME inject-sidecar my-app default

  # Traffic management
  $SCRIPT_NAME traffic-split my-service v1 v2 10
  $SCRIPT_NAME circuit-breaker my-service 100 100

  # Check status
  $SCRIPT_NAME status
  $SCRIPT_NAME dashboard

EXIT CODES:
    0    Success
    1    General error
    2    Invalid arguments
    3    Service mesh not installed
    4    Configuration failed
    5    Injection failed

EOF
}

# Main
main() {
    # Handle help/version first (before init to avoid permission issues in tests)
    case "${1:-}" in
        version|--version|-v)
            echo "$SCRIPT_NAME version $VERSION"
            exit 0
            ;;
        help|--help|-h|"")
            usage
            exit 0
            ;;
    esac

    # Now init for actual commands
    init_logging
    load_config

    case "${1}" in
        istio-install)
            istio_install
            ;;
        linkerd-install)
            linkerd_install
            ;;
        consul-install)
            consul_install
            ;;
        inject-sidecar)
            inject_sidecar "$2" "$3"
            ;;
        mtls-enable)
            mtls_enable
            ;;
        virtual-service-create)
            virtual_service_create "$2" "$3" "$4" "$5"
            ;;
        destination-rule-create)
            destination_rule_create "$2" "$3"
            ;;
        traffic-split)
            traffic_split "$2" "$3" "$4" "$5"
            ;;
        fault-inject)
            fault_inject "$2" "$3" "$4"
            ;;
        circuit-breaker)
            circuit_breaker "$2" "$3" "$4"
            ;;
        status)
            mesh_status
            ;;
        dashboard)
            mesh_dashboard
            ;;
        wizard)
            mesh_wizard
            ;;        *)
            echo "Unknown command: $1"
            echo "Run '$SCRIPT_NAME help' for usage"
            exit 1
            ;;
    esac
}

main "$@"
