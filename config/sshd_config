# VirtOS SSH Server Configuration
# Minimal secure configuration for Tiny Core Linux

Port 22
AddressFamily any
ListenAddress 0.0.0.0

# Host keys
HostKey /usr/local/etc/ssh/ssh_host_rsa_key
HostKey /usr/local/etc/ssh/ssh_host_ecdsa_key
HostKey /usr/local/etc/ssh/ssh_host_ed25519_key

# Authentication
PermitRootLogin yes
PubkeyAuthentication yes
PasswordAuthentication yes
PermitEmptyPasswords no
ChallengeResponseAuthentication no
UsePAM no

# SSH access via group membership
# Users must be members of ssh-users group to login
# This allows cloud-init and other tools to create users dynamically
# without needing to update sshd_config each time
AllowGroups ssh-users

# Logging
SyslogFacility AUTH
LogLevel INFO

# Session settings
X11Forwarding no
PrintMotd yes
PrintLastLog yes
TCPKeepAlive yes
AcceptEnv LANG LC_*

# Subsystem
Subsystem sftp /usr/local/lib/openssh/sftp-server
