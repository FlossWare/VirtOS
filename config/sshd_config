# VirtOS SSH Server Configuration
# Minimal configuration for Tiny Core Linux

Port 22
ListenAddress 0.0.0.0

# Host keys
HostKey /usr/local/etc/ssh/ssh_host_rsa_key
HostKey /usr/local/etc/ssh/ssh_host_ecdsa_key
HostKey /usr/local/etc/ssh/ssh_host_ed25519_key

# Authentication - VERY permissive for testing
PermitRootLogin yes
PubkeyAuthentication yes
PasswordAuthentication yes
PermitEmptyPasswords yes
UsePAM no
StrictModes no

# Allow all users (no restrictions)
# AllowGroups removed - was blocking access

# Logging
SyslogFacility AUTH
LogLevel DEBUG3

# Session settings
X11Forwarding no
PrintMotd yes
TCPKeepAlive yes

# Subsystem
Subsystem sftp /usr/local/lib/openssh/sftp-server
