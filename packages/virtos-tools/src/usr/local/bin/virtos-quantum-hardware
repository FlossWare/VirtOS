    local backend="${1:-ibmq_manila}"

    log "Getting backend information: $backend..."

    cat > "$QUANTUM_HW_DIR/backend_info.py" << 'PYEOF'
#!/usr/bin/env python3
import sys

backend = sys.argv[1] if len(sys.argv) > 1 else "ibmq_manila"

print(f"Backend Information: {backend}")
