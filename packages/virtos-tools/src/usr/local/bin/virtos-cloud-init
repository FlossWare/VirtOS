#!/bin/bash
set -e

# VirtOS Cloud-Init - Cloud-init integration for VMs
# Configure VMs with cloud-init on first boot

VERSION="1"
CLOUD_INIT_DIR="/var/lib/virtos/cloud-init"

mkdir -p "$CLOUD_INIT_DIR"

usage() {
    cat << EOF
VirtOS Cloud-Init Integration v${VERSION}

Usage: virtos-cloud-init [command] [options]

Commands:
  create <vm-name>                 Create cloud-init configuration
  attach <vm-name> <iso-path>      Attach cloud-init ISO to VM
  generate <vm-name>               Generate cloud-init ISO
  template-list                    List available templates
  template-show <template>         Show template contents

Configuration Options:
  --hostname <name>                Set hostname
  --user <username>                Set default user
  --password <password>            Set user password
  --ssh-key <key-file>             Add SSH public key
  --packages <pkg1,pkg2>           Install packages
  --run <script-file>              Run custom script
  --network <dhcp|static>          Network configuration
  --ip <address>                   Static IP address
  --gateway <address>              Default gateway
  --dns <server>                   DNS server

Examples:
  # Create cloud-init with SSH key
  virtos-cloud-init create ubuntu-vm \\
    --hostname web-server \\
    --user admin \\
    --ssh-key ~/.ssh/id_rsa.pub

  # Create with static IP
  virtos-cloud-init create db-vm \\
    --hostname database \\
    --network static \\
    --ip 192.168.1.100/24 \\
    --gateway 192.168.1.1 \\
    --dns 8.8.8.8

  # Install packages on first boot
  virtos-cloud-init create app-vm \\
    --hostname app-server \\
    --packages nginx,git,python3 \\
    --run /path/to/setup.sh

  # Generate ISO and attach to VM
  virtos-cloud-init generate web-vm
  virtos-cloud-init attach web-vm /var/lib/virtos/cloud-init/web-vm.iso

EOF
}

log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

create_cloud_init() {
    local vm_name="$1"
    local config_dir="$CLOUD_INIT_DIR/$vm_name"

    mkdir -p "$config_dir"

    log_message "Creating cloud-init configuration for $vm_name"

    # Parse options
    local hostname="$vm_name"
    local username="ubuntu"
    local password=""
    local ssh_keys=()
    local packages=()
    local run_script=""
    local network_type="dhcp"
    local static_ip=""
    local gateway=""
    local dns_server="8.8.8.8"

    shift  # Skip vm_name

    while [ $# -gt 0 ]; do
        case "$1" in
            --hostname)
                hostname="$2"
                shift 2
                ;;
            --user)
                username="$2"
                shift 2
                ;;
            --password)
                password="$2"
                shift 2
                ;;
            --ssh-key)
                if [ -f "$2" ]; then
                    ssh_keys+=("$(cat "$2")")
                else
                    echo "Warning: SSH key file not found: $2"
                fi
                shift 2
                ;;
            --packages)
                IFS=',' read -ra packages <<< "$2"
                shift 2
                ;;
            --run)
                run_script="$2"
                shift 2
                ;;
            --network)
                network_type="$2"
                shift 2
                ;;
            --ip)
                static_ip="$2"
                shift 2
                ;;
            --gateway)
                gateway="$2"
                shift 2
                ;;
            --dns)
                dns_server="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    # Create meta-data
    cat > "$config_dir/meta-data" <<EOF
instance-id: $vm_name-$(date +%s)
local-hostname: $hostname
EOF

    # Create user-data
    cat > "$config_dir/user-data" <<'EOF'
#cloud-config
EOF

    # Add hostname
    cat >> "$config_dir/user-data" <<EOF
hostname: $hostname
fqdn: ${hostname}.local
manage_etc_hosts: true

EOF

    # Add users
    cat >> "$config_dir/user-data" <<EOF
users:
  - name: $username
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups: users, admin
    shell: /bin/bash
EOF

    # Add password if provided
    if [ -n "$password" ]; then
        # Hash password (simple method, should use mkpasswd in production)
        cat >> "$config_dir/user-data" <<EOF
    passwd: $(openssl passwd -1 "$password")
    lock_passwd: false
EOF
    fi

    # Add SSH keys
    if [ ${#ssh_keys[@]} -gt 0 ]; then
        cat >> "$config_dir/user-data" <<EOF
    ssh_authorized_keys:
EOF
        for key in "${ssh_keys[@]}"; do
            cat >> "$config_dir/user-data" <<EOF
      - $key
EOF
        done
    fi

    echo "" >> "$config_dir/user-data"

    # Add packages
    if [ ${#packages[@]} -gt 0 ]; then
        cat >> "$config_dir/user-data" <<EOF
packages:
EOF
        for pkg in "${packages[@]}"; do
            cat >> "$config_dir/user-data" <<EOF
  - $pkg
EOF
        done
        echo "" >> "$config_dir/user-data"
    fi

    # Add network configuration if static
    if [ "$network_type" = "static" ] && [ -n "$static_ip" ]; then
        cat > "$config_dir/network-config" <<EOF
version: 2
ethernets:
  eth0:
    addresses:
      - $static_ip
EOF

        if [ -n "$gateway" ]; then
            cat >> "$config_dir/network-config" <<EOF
    gateway4: $gateway
EOF
        fi

        cat >> "$config_dir/network-config" <<EOF
    nameservers:
      addresses:
        - $dns_server
EOF
    fi

    # Add custom script
    if [ -n "$run_script" ] && [ -f "$run_script" ]; then
        cat >> "$config_dir/user-data" <<EOF
runcmd:
EOF
        # Read script line by line
        while IFS= read -r line; do
            cat >> "$config_dir/user-data" <<EOF
  - $line
EOF
        done < "$run_script"
        echo "" >> "$config_dir/user-data"
    fi

    # Add final message
    cat >> "$config_dir/user-data" <<EOF
final_message: "Cloud-init configuration completed for $hostname"
EOF

    log_message "Cloud-init configuration created in $config_dir"
    echo "Configuration created: $config_dir"
    echo ""
    echo "Next steps:"
    echo "  1. Review configuration: ls -la $config_dir"
    echo "  2. Generate ISO: virtos-cloud-init generate $vm_name"
    echo "  3. Attach to VM: virtos-cloud-init attach $vm_name <iso-path>"
}

generate_iso() {
    local vm_name="$1"
    local config_dir="$CLOUD_INIT_DIR/$vm_name"
    local iso_path="$CLOUD_INIT_DIR/${vm_name}-cloud-init.iso"

    if [ ! -d "$config_dir" ]; then
        echo "Error: Configuration not found for $vm_name"
        echo "Run: virtos-cloud-init create $vm_name"
        return 1
    fi

    if ! command -v genisoimage >/dev/null 2>&1 && ! command -v mkisofs >/dev/null 2>&1; then
        echo "Error: genisoimage or mkisofs required"
        echo "Install with: tce-load -i cdrkit"
        return 1
    fi

    log_message "Generating cloud-init ISO for $vm_name"

    # Use genisoimage or mkisofs
    local iso_cmd="genisoimage"
    command -v genisoimage >/dev/null 2>&1 || iso_cmd="mkisofs"

    $iso_cmd -output "$iso_path" \
        -volid cidata \
        -joliet -rock \
        "$config_dir"/* \
        >/dev/null 2>&1

    if [ $? -eq 0 ]; then
        log_message "ISO generated: $iso_path"
        echo "Cloud-init ISO generated: $iso_path"
        echo ""
        echo "Attach to VM with:"
        echo "  virtos-cloud-init attach $vm_name $iso_path"
        echo "  or"
        echo "  virsh change-media $vm_name sda $iso_path --insert"
        return 0
    else
        echo "Error: Failed to generate ISO"
        return 1
    fi
}

attach_iso() {
    local vm_name="$1"
    local iso_path="$2"

    if [ ! -f "$iso_path" ]; then
        echo "Error: ISO file not found: $iso_path"
        return 1
    fi

    if ! virsh list --all | grep -q " $vm_name "; then
        echo "Error: VM '$vm_name' not found"
        return 1
    fi

    log_message "Attaching cloud-init ISO to $vm_name"

    # Check if VM has a CDROM device
    if ! virsh dumpxml "$vm_name" | grep -q "device='cdrom'"; then
        echo "Adding CDROM device to VM..."
        # This is a simplified approach; in production, you'd modify the XML
        echo "Warning: VM may not have a CDROM device"
        echo "Manually attach with: virsh attach-disk $vm_name $iso_path sdb --type cdrom --mode readonly"
        return 1
    fi

    # Attach the ISO
    virsh change-media "$vm_name" sda "$iso_path" --insert --force

    if [ $? -eq 0 ]; then
        log_message "ISO attached to $vm_name"
        echo "Cloud-init ISO attached to $vm_name"
        echo ""
        echo "Start the VM to apply cloud-init configuration:"
        echo "  virsh start $vm_name"
        return 0
    else
        echo "Error: Failed to attach ISO"
        echo "Try manually: virsh attach-disk $vm_name $iso_path sdb --type cdrom --mode readonly"
        return 1
    fi
}

list_templates() {
    echo "Cloud-Init Templates:"
    echo "===================="
    echo ""
    echo "1. basic - Basic configuration with SSH key"
    echo "2. ubuntu - Ubuntu server configuration"
    echo "3. debian - Debian server configuration"
    echo "4. static-ip - Static IP configuration"
    echo "5. webserver - Web server with nginx"
    echo "6. docker - Docker host configuration"
    echo ""
    echo "Use: virtos-cloud-init template-show <template-name>"
}

show_template() {
    local template="$1"

    case "$template" in
        basic)
            cat <<'EOF'
# Basic cloud-init configuration
virtos-cloud-init create myvm \
  --hostname myhost \
  --user admin \
  --ssh-key ~/.ssh/id_rsa.pub
EOF
            ;;
        ubuntu)
            cat <<'EOF'
# Ubuntu server
virtos-cloud-init create ubuntu-server \
  --hostname ubuntu-01 \
  --user ubuntu \
  --ssh-key ~/.ssh/id_rsa.pub \
  --packages curl,wget,vim,git
EOF
            ;;
        static-ip)
            cat <<'EOF'
# Static IP configuration
virtos-cloud-init create static-vm \
  --hostname server-01 \
  --network static \
  --ip 192.168.1.100/24 \
  --gateway 192.168.1.1 \
  --dns 8.8.8.8 \
  --ssh-key ~/.ssh/id_rsa.pub
EOF
            ;;
        webserver)
            cat <<'EOF'
# Web server with nginx
virtos-cloud-init create webserver \
  --hostname web-01 \
  --user www \
  --ssh-key ~/.ssh/id_rsa.pub \
  --packages nginx,git,certbot
EOF
            ;;
        docker)
            cat <<'EOF'
# Docker host
virtos-cloud-init create docker-host \
  --hostname docker-01 \
  --user docker \
  --ssh-key ~/.ssh/id_rsa.pub \
  --packages docker.io,docker-compose
EOF
            ;;
        *)
            echo "Unknown template: $template"
            echo "Use: virtos-cloud-init template-list"
            return 1
            ;;
    esac
}

# Main command handler
COMMAND="$1"
shift

case "$COMMAND" in
    create)
        create_cloud_init "$@"
        ;;
    generate)
        generate_iso "$1"
        ;;
    attach)
        attach_iso "$1" "$2"
        ;;
    template-list)
        list_templates
        ;;
    template-show)
        show_template "$1"
        ;;
    --help|-h|help|"")
        usage
        exit 0
        ;;
    *)
        echo "Error: Unknown command: $COMMAND"
        usage
        exit 1
        ;;
esac
