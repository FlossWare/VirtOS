#!/bin/bash
set -e

# VirtOS DevOps Integration
# GitOps, CI/CD, and Infrastructure as Code tools

VERSION="1"

# Configuration
DEVOPS_CONFIG_DIR="/etc/virtos/devops"
DEVOPS_LOG="/var/log/virtos-devops.log"

# Ensure config directory exists
mkdir -p "$DEVOPS_CONFIG_DIR"

# Logging function
log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$DEVOPS_LOG"
}

# GitOps - ArgoCD installation
install_argocd() {
    log_message "Installing ArgoCD for GitOps..."

    # Requires Kubernetes
    if ! command -v kubectl &> /dev/null; then
        log_message "ERROR: kubectl required for ArgoCD"
        return 1
    fi

    # Create ArgoCD namespace
    kubectl create namespace argocd 2>/dev/null || true

    # Install ArgoCD
    kubectl apply -n argocd -f https://raw.githubusercontent.com/argoproj/argo-cd/stable/manifests/install.yaml

    # Wait for ArgoCD to be ready
    kubectl wait --for=condition=available --timeout=300s deployment/argocd-server -n argocd

    # Get initial admin password
    local admin_pass=$(kubectl -n argocd get secret argocd-initial-admin-secret -o jsonpath="{.data.password}" | base64 -d)

    # Port forward for access
    kubectl port-forward svc/argocd-server -n argocd 8080:443 &
    echo $! > "$DEVOPS_CONFIG_DIR/argocd-port-forward.pid"

    log_message "ArgoCD installed successfully"
    log_message "ArgoCD available at https://localhost:8080"
    echo ""
    echo "=========================================="
    echo "  ArgoCD Initial Admin Credentials"
    echo "=========================================="
    echo "Username: admin"
    echo "Password: $admin_pass"
    echo ""
    echo "SECURITY WARNING:"
    echo "  1. Change this password immediately in the ArgoCD UI"
    echo "  2. This password is NOT saved to disk for security"
    echo "  3. To retrieve it again, run:"
    echo "     kubectl -n argocd get secret argocd-initial-admin-secret -o jsonpath=\"{.data.password}\" | base64 -d"
    echo "=========================================="
}

# GitOps - Flux installation
install_flux() {
    log_message "Installing Flux for GitOps..."

    # Install Flux CLI
    curl -s https://fluxcd.io/install.sh | bash

    # Verify installation
    flux check --pre

    log_message "Flux CLI installed. Run 'flux bootstrap' to configure."

    cat > "$DEVOPS_CONFIG_DIR/flux-bootstrap.sh" <<'EOF'
#!/bin/bash
# Bootstrap Flux with GitHub
flux bootstrap github \
  --owner=$GITHUB_USER \
  --repository=virtos-fleet \
  --branch=main \
  --path=./clusters/production \
  --personal
EOF

    chmod +x "$DEVOPS_CONFIG_DIR/flux-bootstrap.sh"
    log_message "Flux bootstrap script: $DEVOPS_CONFIG_DIR/flux-bootstrap.sh"
}

# CI/CD - Jenkins setup
install_jenkins() {
    log_message "Installing Jenkins CI/CD server..."

    local runtime="docker"
    command -v docker &> /dev/null || runtime="podman"

    # Run Jenkins container
    $runtime run -d \
        --name=jenkins \
        --restart=always \
        -p 8081:8080 \
        -p 50000:50000 \
        -v jenkins_home:/var/jenkins_home \
        jenkins/jenkins:lts

    # Wait for Jenkins to start
    sleep 30

    # Get initial admin password
    local admin_pass=$($runtime exec jenkins cat /var/jenkins_home/secrets/initialAdminPassword)

    log_message "Jenkins installed successfully"
    log_message "Jenkins available at http://localhost:8081"
    echo ""
    echo "=========================================="
    echo "  Jenkins Initial Admin Credentials"
    echo "=========================================="
    echo "Username: admin"
    echo "Password: $admin_pass"
    echo ""
    echo "SECURITY WARNING:"
    echo "  1. Complete the setup wizard and change this password"
    echo "  2. This password is NOT saved to disk for security"
    echo "  3. To retrieve it again, run:"
    echo "     $runtime exec jenkins cat /var/jenkins_home/secrets/initialAdminPassword"
    echo "=========================================="
}

# CI/CD - GitLab Runner setup
install_gitlab_runner() {
    log_message "Installing GitLab Runner..."

    local runtime="docker"
    command -v docker &> /dev/null || runtime="podman"

    # Run GitLab Runner container
    $runtime run -d \
        --name gitlab-runner \
        --restart always \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v gitlab-runner-config:/etc/gitlab-runner \
        gitlab/gitlab-runner:latest

    log_message "GitLab Runner installed. Configure with: docker exec -it gitlab-runner gitlab-runner register"

    cat > "$DEVOPS_CONFIG_DIR/gitlab-runner-register.sh" <<'EOF'
#!/bin/bash
# Register GitLab Runner
docker exec -it gitlab-runner gitlab-runner register \
  --url https://gitlab.com/ \
  --registration-token YOUR_TOKEN \
  --executor docker \
  --docker-image docker:latest \
  --description "VirtOS Runner"
EOF

    chmod +x "$DEVOPS_CONFIG_DIR/gitlab-runner-register.sh"
}

# CI/CD - GitHub Actions runner setup
install_github_actions_runner() {
    local repo="$1"
    local token="$2"

    log_message "Installing GitHub Actions self-hosted runner..."

    mkdir -p /opt/github-actions-runner
    cd /opt/github-actions-runner

    # Download latest runner
    curl -o actions-runner-linux-x64.tar.gz -L \
        https://github.com/actions/runner/releases/download/v2.304.0/actions-runner-linux-x64-2.304.0.tar.gz

    tar xzf actions-runner-linux-x64.tar.gz
    rm actions-runner-linux-x64.tar.gz

    # Configure runner
    ./config.sh --url "https://github.com/$repo" --token "$token" --unattended

    # Install as service
    ./svc.sh install
    ./svc.sh start

    log_message "GitHub Actions runner installed for $repo"
}

# IaC - Terraform setup
install_terraform() {
    log_message "Installing Terraform for Infrastructure as Code..."

    # Download Terraform
    local tf_version="1.5.0"
    wget -q https://releases.hashicorp.com/terraform/${tf_version}/terraform_${tf_version}_linux_amd64.zip

    unzip -o terraform_${tf_version}_linux_amd64.zip -d /usr/local/bin/
    rm terraform_${tf_version}_linux_amd64.zip

    chmod +x /usr/local/bin/terraform

    # Verify installation
    terraform version

    # Create example Terraform config for VirtOS
    mkdir -p "$DEVOPS_CONFIG_DIR/terraform-examples"

    cat > "$DEVOPS_CONFIG_DIR/terraform-examples/vm.tf" <<'EOF'
# Example Terraform configuration for VirtOS VM

terraform {
  required_providers {
    libvirt = {
      source = "dmacvicar/libvirt"
    }
  }
}

provider "libvirt" {
  uri = "qemu:///system"
}

resource "libvirt_volume" "vm_disk" {
  name   = "vm-disk.qcow2"
  pool   = "default"
  format = "qcow2"
  size   = 21474836480  # 20GB
}

resource "libvirt_domain" "vm" {
  name   = "terraform-vm"
  memory = "2048"
  vcpu   = 2

  disk {
    volume_id = libvirt_volume.vm_disk.id
  }

  network_interface {
    network_name = "default"
  }

  console {
    type        = "pty"
    target_port = "0"
  }
}
EOF

    log_message "Terraform installed. Examples: $DEVOPS_CONFIG_DIR/terraform-examples/"
}

# IaC - Ansible setup
install_ansible() {
    log_message "Installing Ansible for configuration management..."

    # Install Ansible via pip
    pip3 install ansible

    # Verify installation
    ansible --version

    # Create Ansible inventory for VirtOS
    mkdir -p "$DEVOPS_CONFIG_DIR/ansible"

    cat > "$DEVOPS_CONFIG_DIR/ansible/inventory.ini" <<'EOF'
[virtos_hosts]
virtos-1 ansible_host=192.168.1.10
virtos-2 ansible_host=192.168.1.11
virtos-3 ansible_host=192.168.1.12

[virtos_hosts:vars]
ansible_user=tc
ansible_ssh_private_key_file=~/.ssh/id_rsa
EOF

    cat > "$DEVOPS_CONFIG_DIR/ansible/virtos-setup.yml" <<'EOF'
---
# Example Ansible playbook for VirtOS setup
- name: Configure VirtOS hosts
  hosts: virtos_hosts
  become: yes
  tasks:
    - name: Update system packages
      command: tce-update

    - name: Ensure KVM modules loaded
      modprobe:
        name: kvm
        state: present

    - name: Create VM directory
      file:
        path: /mnt/sda1/vms
        state: directory
        mode: '0755'

    - name: Deploy VM template
      copy:
        src: templates/vm.xml
        dest: /etc/libvirt/qemu/
EOF

    log_message "Ansible installed. Inventory: $DEVOPS_CONFIG_DIR/ansible/inventory.ini"
}

# IaC - Pulumi setup
install_pulumi() {
    log_message "Installing Pulumi for cloud infrastructure..."

    # Install Pulumi
    curl -fsSL https://get.pulumi.com | sh

    # Add to PATH
    export PATH=$PATH:$HOME/.pulumi/bin

    # Create example Pulumi project
    mkdir -p "$DEVOPS_CONFIG_DIR/pulumi-examples"
    cd "$DEVOPS_CONFIG_DIR/pulumi-examples"

    pulumi new python -y --name virtos-infra

    log_message "Pulumi installed. Example project: $DEVOPS_CONFIG_DIR/pulumi-examples/"
}

# Container Registry - Harbor installation
install_harbor() {
    log_message "Installing Harbor container registry..."

    local runtime="docker"
    command -v docker &> /dev/null || runtime="podman"

    # Requires docker-compose
    if ! command -v docker-compose &> /dev/null; then
        log_message "Installing docker-compose..."
        curl -L "https://github.com/docker/compose/releases/download/v2.18.0/docker-compose-$(uname -s)-$(uname -m)" -o /usr/local/bin/docker-compose
        chmod +x /usr/local/bin/docker-compose
    fi

    # Download Harbor installer
    mkdir -p /opt/harbor
    cd /opt/harbor

    wget -q https://github.com/goharbor/harbor/releases/download/v2.8.0/harbor-offline-installer-v2.8.0.tgz
    tar xzf harbor-offline-installer-v2.8.0.tgz

    # Configure Harbor
    cd harbor
    cp harbor.yml.tmpl harbor.yml

    # Update hostname
    sed -i "s/hostname: reg.mydomain.com/hostname: $(hostname)/" harbor.yml

    # Install Harbor
    ./install.sh

    log_message "Harbor installed at https://$(hostname)"
    log_message "Default credentials: admin / Harbor12345"
}

# Build automation - Create CI pipeline
create_ci_pipeline() {
    local pipeline_type="$1"  # github-actions, gitlab-ci, jenkins
    local project_dir="$2"

    log_message "Creating $pipeline_type CI pipeline in $project_dir..."

    mkdir -p "$project_dir"

    case "$pipeline_type" in
        github-actions)
            mkdir -p "$project_dir/.github/workflows"
            cat > "$project_dir/.github/workflows/virtos-build.yml" <<'EOF'
name: VirtOS Build

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Build VirtOS ISO
        run: |
          cd build/scripts
          ./build-all.sh

      - name: Test ISO
        run: |
          qemu-system-x86_64 -enable-kvm -m 2048 \
            -cdrom build/output/*.iso \
            -display none -daemonize
          sleep 30

      - name: Upload ISO
        uses: actions/upload-artifact@v3
        with:
          name: virtos-iso
          path: build/output/*.iso
EOF
            log_message "GitHub Actions pipeline created: $project_dir/.github/workflows/virtos-build.yml"
            ;;

        gitlab-ci)
            cat > "$project_dir/.gitlab-ci.yml" <<'EOF'
stages:
  - build
  - test
  - deploy

build_iso:
  stage: build
  script:
    - cd build/scripts
    - ./build-all.sh
  artifacts:
    paths:
      - build/output/*.iso

test_iso:
  stage: test
  script:
    - qemu-system-x86_64 -enable-kvm -m 2048 -cdrom build/output/*.iso -display none &
    - sleep 30

deploy_iso:
  stage: deploy
  script:
    - scp build/output/*.iso deploy@server:/var/www/releases/
  only:
    - main
EOF
            log_message "GitLab CI pipeline created: $project_dir/.gitlab-ci.yml"
            ;;

        jenkins)
            cat > "$project_dir/Jenkinsfile" <<'EOF'
pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                sh 'cd build/scripts && ./build-all.sh'
            }
        }

        stage('Test') {
            steps {
                sh '''
                    qemu-system-x86_64 -enable-kvm -m 2048 \
                        -cdrom build/output/*.iso \
                        -display none -daemonize
                    sleep 30
                '''
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                sh 'scp build/output/*.iso deploy@server:/var/www/releases/'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'build/output/*.iso', fingerprint: true
        }
    }
}
EOF
            log_message "Jenkins pipeline created: $project_dir/Jenkinsfile"
            ;;
    esac
}

# Deployment automation
create_deployment() {
    local app_name="$1"
    local deployment_type="$2"  # kubernetes, docker-compose, systemd

    log_message "Creating deployment for $app_name ($deployment_type)..."

    case "$deployment_type" in
        kubernetes)
            cat > "$DEVOPS_CONFIG_DIR/$app_name-deployment.yaml" <<EOF
apiVersion: apps/v1
kind: Deployment
metadata:
  name: $app_name
spec:
  replicas: 3
  selector:
    matchLabels:
      app: $app_name
  template:
    metadata:
      labels:
        app: $app_name
    spec:
      containers:
      - name: $app_name
        image: registry.local/$app_name:latest
        ports:
        - containerPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: $app_name
spec:
  selector:
    app: $app_name
  ports:
  - port: 80
    targetPort: 8080
  type: LoadBalancer
EOF
            log_message "Kubernetes deployment created: $DEVOPS_CONFIG_DIR/$app_name-deployment.yaml"
            ;;

        docker-compose)
            cat > "$DEVOPS_CONFIG_DIR/$app_name-compose.yml" <<EOF
version: '3'
services:
  $app_name:
    image: registry.local/$app_name:latest
    ports:
      - "80:8080"
    restart: always
    environment:
      - ENV=production
    volumes:
      - app-data:/data

volumes:
  app-data:
EOF
            log_message "Docker Compose file created: $DEVOPS_CONFIG_DIR/$app_name-compose.yml"
            ;;

        systemd)
            cat > "/etc/systemd/system/$app_name.service" <<EOF
[Unit]
Description=$app_name Service
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/$app_name
Restart=always
User=virtos

[Install]
WantedBy=multi-user.target
EOF
            systemctl daemon-reload
            log_message "Systemd service created: /etc/systemd/system/$app_name.service"
            ;;
    esac
}

# DevOps status
devops_status() {
    echo "=== VirtOS DevOps Status ==="
    echo

    # Check ArgoCD
    if kubectl get namespace argocd &>/dev/null; then
        echo "ArgoCD: Installed"
    else
        echo "ArgoCD: Not installed"
    fi

    # Check Flux
    if command -v flux &> /dev/null; then
        echo "Flux: $(flux version --client)"
    else
        echo "Flux: Not installed"
    fi

    # Check Jenkins
    if docker ps | grep -q jenkins; then
        echo "Jenkins: Running on http://localhost:8081"
    else
        echo "Jenkins: Not running"
    fi

    # Check Terraform
    if command -v terraform &> /dev/null; then
        echo "Terraform: $(terraform version | head -1)"
    else
        echo "Terraform: Not installed"
    fi

    # Check Ansible
    if command -v ansible &> /dev/null; then
        echo "Ansible: $(ansible --version | head -1)"
    else
        echo "Ansible: Not installed"
    fi

    echo
    echo "Configuration: $DEVOPS_CONFIG_DIR"
    echo "Logs: $DEVOPS_LOG"
}

# Interactive wizard
devops_wizard() {
    dialog --title "VirtOS DevOps Setup" \
        --msgbox "This wizard will help you set up DevOps tools for VirtOS.\n\nChoose GitOps, CI/CD, or IaC tools to install." 12 60

    # Choose category
    local category=$(dialog --title "Choose Category" \
        --menu "Select DevOps category:" 15 60 3 \
        1 "GitOps (ArgoCD/Flux)" \
        2 "CI/CD (Jenkins/GitLab/GitHub)" \
        3 "IaC (Terraform/Ansible/Pulumi)" \
        2>&1 >/dev/tty)

    case "$category" in
        1)
            local choice=$(dialog --title "Choose GitOps Tool" \
                --menu "Select GitOps tool:" 12 60 2 \
                1 "ArgoCD" \
                2 "Flux" \
                2>&1 >/dev/tty)

            case "$choice" in
                1) install_argocd ;;
                2) install_flux ;;
            esac
            ;;
        2)
            local choice=$(dialog --title "Choose CI/CD Tool" \
                --menu "Select CI/CD tool:" 13 60 3 \
                1 "Jenkins" \
                2 "GitLab Runner" \
                3 "GitHub Actions Runner" \
                2>&1 >/dev/tty)

            case "$choice" in
                1) install_jenkins ;;
                2) install_gitlab_runner ;;
                3)
                    local repo=$(dialog --inputbox "GitHub repository (owner/repo):" 10 60 2>&1 >/dev/tty)
                    local token=$(dialog --inputbox "Runner token:" 10 60 2>&1 >/dev/tty)
                    install_github_actions_runner "$repo" "$token"
                    ;;
            esac
            ;;
        3)
            local choice=$(dialog --title "Choose IaC Tool" \
                --menu "Select IaC tool:" 13 60 3 \
                1 "Terraform" \
                2 "Ansible" \
                3 "Pulumi" \
                2>&1 >/dev/tty)

            case "$choice" in
                1) install_terraform ;;
                2) install_ansible ;;
                3) install_pulumi ;;
            esac
            ;;
    esac

    dialog --title "Setup Complete" \
        --msgbox "DevOps setup complete!\n\nRun 'virtos-devops status' to see installed tools." 10 50
}

# Show usage
usage() {
    cat <<EOF
VirtOS DevOps Integration - GitOps, CI/CD, and IaC tools

Usage: virtos-devops <command> [options]

GitOps Commands:
  install-argocd               Install ArgoCD for GitOps
  install-flux                 Install Flux for GitOps

CI/CD Commands:
  install-jenkins              Install Jenkins CI/CD server
  install-gitlab-runner        Install GitLab Runner
  install-github-actions <repo> <token>  Install GitHub Actions runner
  create-ci-pipeline <type> <dir>  Create CI pipeline (github-actions/gitlab-ci/jenkins)

IaC Commands:
  install-terraform            Install Terraform
  install-ansible              Install Ansible
  install-pulumi               Install Pulumi

Registry Commands:
  install-harbor               Install Harbor container registry

Deployment Commands:
  create-deployment <name> <type>  Create deployment (kubernetes/docker-compose/systemd)

Status Commands:
  status                       Show DevOps tools status
  wizard                       Interactive setup wizard

Examples:
  virtos-devops install-terraform
  virtos-devops install-jenkins
  virtos-devops create-ci-pipeline github-actions /path/to/project
  virtos-devops create-deployment myapp kubernetes
  virtos-devops wizard

Version: $VERSION
EOF
}

# Main command dispatcher
case "$1" in
    install-argocd)
        install_argocd
        ;;
    install-flux)
        install_flux
        ;;
    install-jenkins)
        install_jenkins
        ;;
    install-gitlab-runner)
        install_gitlab_runner
        ;;
    install-github-actions)
        install_github_actions_runner "$2" "$3"
        ;;
    install-terraform)
        install_terraform
        ;;
    install-ansible)
        install_ansible
        ;;
    install-pulumi)
        install_pulumi
        ;;
    install-harbor)
        install_harbor
        ;;
    create-ci-pipeline)
        create_ci_pipeline "$2" "$3"
        ;;
    create-deployment)
        create_deployment "$2" "$3"
        ;;
    status)
        devops_status
        ;;
    wizard)
        devops_wizard
        ;;
    *)
        usage
        ;;
esac
